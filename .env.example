PORT=3000
NODE_ENV=development

# Database - SQLite (default for local dev)
DB_CLIENT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_auto_dashboard_builder
DB_USER=root
DB_PASSWORD=
SQLITE_STORAGE=./data/app.db

# For MySQL (future production)
# DB_CLIENT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=ai_auto_dashboard_builder
# DB_USER=root
# DB_PASSWORD=your_password

SESSION_SECRET=change_me_in_production
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Optional: OpenAI API key for future AI-powered prompt parsing
OPENAI_API_KEY=
