<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'Content Management' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --blue:#2563EB; --blue-dark:#1D4ED8; --blue-soft:#EFF6FF;
      --ink:#0F172A; --ink-2:#1E293B; --muted:#64748B; --muted-2:#94A3B8;
      --border:#E2E8F0; --border-2:#EEF2F7; --bg:#F8FAFC; --bg-2:#F1F5F9;
      --green:#10B981; --red:#EF4444; --amber:#F59E0B;
    }
    * { box-sizing: border-box; }
    html, body { margin:0; padding:0; height:100%; }
    body {
      font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
      color:var(--ink); background:var(--bg);
      -webkit-font-smoothing:antialiased;
      overflow:hidden;
    }
    a { color:inherit; text-decoration:none; }

    .cms-shell {
      display:grid;
      grid-template-columns: 244px minmax(0, 1fr) minmax(0, 1.05fr);
      grid-template-rows: 56px 1fr;
      height:100vh;
    }

    /* ───── topbar ───── */
    .cms-topbar {
      grid-column: 1 / -1;
      display:flex; align-items:center; gap:16px;
      background:#fff;
      border-bottom:1px solid var(--border);
      padding: 0 16px;
      z-index: 5;
    }
    .cms-brand { display:flex; align-items:center; gap:10px; padding-right:16px; border-right:1px solid var(--border); height: 56px; min-width: 228px; }
    .cms-brand-icon { width:30px; height:30px; background:var(--blue); color:#fff; border-radius:8px; display:grid; place-items:center; font-size:15px; }
    .cms-brand-text { display:flex; flex-direction:column; line-height:1.05; }
    .cms-brand-name { font-weight:800; font-size:14px; }
    .cms-brand-name .ai { color:var(--blue); }
    .cms-brand-tag { font-size:10px; color:var(--muted); }
    .cms-section-title { font-size:14px; font-weight:600; color:var(--ink); display:flex; align-items:center; gap:8px; }
    .cms-section-title .bi { color:var(--blue); }
    .cms-topbar-spacer { flex: 1; }
    .cms-actions { display:flex; align-items:center; gap:8px; }
    .cms-btn {
      display:inline-flex; align-items:center; gap:6px;
      padding:7px 14px;
      font-size:13px; font-weight:600;
      border-radius:8px; border:1px solid var(--border);
      background:#fff; color:var(--ink-2);
      cursor:pointer; font-family:inherit;
      transition: all .12s;
    }
    .cms-btn:hover { border-color: var(--blue); color: var(--blue); }
    .cms-btn-primary { background:var(--blue); border-color:var(--blue); color:#fff; }
    .cms-btn-primary:hover { background:var(--blue-dark); border-color:var(--blue-dark); color:#fff; }
    .cms-btn-ghost { border-color: transparent; }
    .cms-btn-danger { color: var(--red); }
    .cms-btn-danger:hover { border-color: var(--red); color: var(--red); }
    .cms-save-status { font-size: 12px; color: var(--muted); display:flex; align-items:center; gap:6px; min-width: 120px; }
    .cms-save-status .dot { width:8px; height:8px; border-radius:999px; background:var(--muted-2); }
    .cms-save-status.saving .dot { background: var(--amber); animation: pulse 1s infinite; }
    .cms-save-status.saved  .dot { background: var(--green); }
    .cms-save-status.error  .dot { background: var(--red); }
    @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:.4 } }

    /* ───── sidebar ───── */
    .cms-sidebar {
      background:#fff;
      border-right:1px solid var(--border);
      overflow-y:auto;
      padding: 12px 8px;
    }
    .cms-side-group { padding: 12px 12px 6px; font-size: 11px; font-weight: 700; color: var(--muted-2); text-transform: uppercase; letter-spacing: .08em; }
    .cms-side-link {
      display:flex; align-items:center; gap:10px;
      padding: 8px 12px; border-radius: 8px;
      font-size:13.5px; color:var(--ink-2); font-weight: 500;
      margin-bottom: 2px;
    }
    .cms-side-link i { font-size: 15px; width: 18px; text-align: center; color: var(--muted); }
    .cms-side-link:hover { background: var(--bg-2); }
    .cms-side-link.active { background: var(--blue-soft); color: var(--blue); font-weight: 600; }
    .cms-side-link.active i { color: var(--blue); }

    .cms-side-foot {
      margin-top: 12px; padding: 12px; border-top: 1px solid var(--border-2);
      display:flex; flex-direction:column; gap:6px;
    }
    .cms-side-foot a { font-size: 12.5px; color: var(--muted); padding: 6px 4px; display:flex; align-items:center; gap:8px; }
    .cms-side-foot a:hover { color: var(--blue); }

    /* ───── editor pane ───── */
    .cms-editor {
      overflow-y:auto;
      background:#fff;
      border-right:1px solid var(--border);
    }
    .cms-editor-inner { max-width: 720px; margin: 0 auto; padding: 32px 32px 80px; }
    .cms-editor h1 { font-size: 22px; font-weight: 800; color: var(--ink); margin: 0 0 4px; letter-spacing: -.01em; }
    .cms-editor .lead { color: var(--muted); font-size: 14px; margin: 0 0 22px; }
    .cms-flash { padding: 12px 14px; border-radius: 10px; font-size: 14px; margin-bottom: 16px; display:flex; align-items:center; gap:10px; }
    .cms-flash-success { background:#DCFCE7; color:#166534; border:1px solid #BBF7D0; }
    .cms-flash-error   { background:#FEE2E2; color:#991B1B; border:1px solid #FECACA; }

    /* ───── form ───── */
    .field { display:block; margin-bottom: 14px; }
    .field-label { display:block; font-size:12.5px; font-weight:600; color:var(--ink); margin-bottom: 6px; }
    .field-hint  { font-size:11px; color: var(--muted-2); font-weight:500; margin-left: 6px; }
    .input, .textarea, .select {
      display:block; width:100%; padding:9px 12px;
      border:1px solid var(--border); border-radius:8px;
      font: inherit; font-size: 13.5px; color: var(--ink); background:#fff;
      transition: border-color .12s, box-shadow .12s;
    }
    .input:focus, .textarea:focus, .select:focus {
      outline:none; border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,.15);
    }
    .textarea { font-family: inherit; resize: vertical; min-height: 64px; line-height: 1.5; }
    .textarea.code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12.5px; background: #F8FAFC; min-height: 320px;
    }
    .row-2 { display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .row-3 { display:grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .check-row { display:flex; align-items:center; gap:10px; padding: 8px 0; }
    .check-row input[type=checkbox] { width: 16px; height: 16px; }

    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 12px;
    }
    .card-head {
      display:flex; align-items:center; justify-content:space-between;
      gap: 8px; margin-bottom: 10px;
    }
    .card-head h4 { margin: 0; font-size: 13px; font-weight: 700; color: var(--ink-2); }
    .card-head .controls { display:flex; gap: 4px; }
    .icon-btn {
      width: 26px; height: 26px;
      border-radius: 6px; border: 1px solid transparent;
      background: transparent; color: var(--muted);
      display:grid; place-items:center; cursor:pointer; font-size:13px;
    }
    .icon-btn:hover { background: var(--bg-2); color: var(--ink); }
    .icon-btn-danger:hover { background: #FEE2E2; color: var(--red); }

    .group-head {
      display:flex; align-items:center; justify-content:space-between;
      margin: 24px 0 10px;
    }
    .group-head h3 {
      margin: 0; font-size: 12px; font-weight: 700;
      color: var(--muted); text-transform: uppercase; letter-spacing: .08em;
    }
    .add-btn {
      display:inline-flex; align-items:center; gap:6px;
      padding: 7px 12px; border-radius: 8px;
      background: var(--blue-soft); color: var(--blue);
      font-size: 12.5px; font-weight: 600;
      border: 1px dashed var(--blue);
      cursor: pointer; font-family: inherit;
    }
    .add-btn:hover { background: var(--blue); color: #fff; }

    /* ───── preview pane ───── */
    .cms-preview {
      background: var(--bg-2);
      display:flex; flex-direction:column;
      overflow:hidden;
    }
    .cms-preview-bar {
      display:flex; align-items:center; gap:8px;
      padding: 10px 14px;
      background:#fff; border-bottom:1px solid var(--border);
    }
    .cms-preview-bar .url {
      flex:1; font-size: 12px; color: var(--muted);
      background: var(--bg-2); border-radius: 6px;
      padding: 6px 10px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    .cms-preview-toggle {
      display:flex; gap: 2px; padding: 2px;
      background: var(--bg-2); border-radius: 8px;
    }
    .cms-preview-toggle button {
      border: none; background: transparent;
      padding: 5px 10px; font-size: 12px; font-weight: 500;
      color: var(--muted); border-radius: 6px;
      cursor: pointer; font-family: inherit;
    }
    .cms-preview-toggle button.active { background: #fff; color: var(--ink); box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,.05)); }
    .cms-preview-frame {
      flex:1;
      background: #fff;
      border: none;
      width: 100%;
      transition: max-width .25s ease, margin .25s ease;
    }
    .cms-preview-stage {
      flex:1; display:flex; align-items:flex-start; justify-content:center;
      padding: 14px;
      overflow:auto;
    }
    .cms-preview-stage iframe {
      width: 100%; height: 100%;
      background:#fff;
      border: 1px solid var(--border);
      border-radius: 10px;
      box-shadow: 0 12px 40px rgba(15,23,42,.08);
    }
    .device-desktop iframe { max-width: 100%; }
    .device-tablet  iframe { max-width: 820px; }
    .device-mobile  iframe { max-width: 390px; }

    @media (max-width: 1280px) {
      .cms-shell { grid-template-columns: 220px minmax(0, 1fr) minmax(0, 1fr); }
    }
    @media (max-width: 1024px) {
      .cms-shell { grid-template-columns: 200px minmax(0, 1fr); grid-template-rows: 56px 1fr 1fr; }
      .cms-preview { grid-column: 1 / -1; border-top: 1px solid var(--border); }
      .cms-editor { border-right: none; }
    }
  </style>
</head>
<body>
<div class="cms-shell">
  <!-- ════════ TOPBAR ════════ -->
  <header class="cms-topbar">
    <a href="/admin/content" class="cms-brand">
      <span class="cms-brand-icon"><i class="bi bi-bar-chart-line-fill"></i></span>
      <span class="cms-brand-text">
        <span class="cms-brand-name">AutoDash <span class="ai">AI</span></span>
        <span class="cms-brand-tag">Content Studio</span>
      </span>
    </a>
    <div class="cms-section-title">
      <i class="bi <%= current.icon %>"></i>
      <span>Editing: <%= current.label %></span>
    </div>
    <div class="cms-topbar-spacer"></div>
    <div class="cms-save-status" id="saveStatus"><span class="dot"></span><span class="lbl">Up to date</span></div>
    <div class="cms-actions">
      <button class="cms-btn" id="btnReload" title="Reload preview"><i class="bi bi-arrow-clockwise"></i></button>
      <button class="cms-btn" id="btnSaveDraft" form="cmsForm" type="submit" name="__action" value="draft"><i class="bi bi-bookmark"></i> Save Draft</button>
      <button class="cms-btn cms-btn-primary" id="btnPublish" form="cmsForm" type="submit" name="__action" value="publish"><i class="bi bi-cloud-upload"></i> Publish</button>
      <a href="/dashboard" class="cms-btn cms-btn-ghost" title="Back to App"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </header>

  <!-- ════════ SIDEBAR ════════ -->
  <aside class="cms-sidebar">
    <% Object.keys(groups).forEach(function(g){ %>
      <div class="cms-side-group"><%= g %></div>
      <% groups[g].forEach(function(s){ %>
        <a href="/admin/content/<%= s.key %>" class="cms-side-link <%= s.key === activeSection ? 'active' : '' %>">
          <i class="bi <%= s.icon %>"></i>
          <span><%= s.label %></span>
        </a>
      <% }); %>
    <% }); %>

    <div class="cms-side-foot">
      <form method="POST" action="/admin/content/publish" style="margin:0">
        <button class="cms-btn cms-btn-primary" type="submit" style="width:100%; justify-content:center;">
          <i class="bi bi-cloud-upload"></i> Publish All Drafts
        </button>
      </form>
      <form method="POST" action="/admin/content/revert" style="margin:0">
        <button class="cms-btn cms-btn-danger" type="submit" style="width:100%; justify-content:center;">
          <i class="bi bi-arrow-counterclockwise"></i> Discard All Drafts
        </button>
      </form>
      <form method="POST" action="/admin/content/<%= activeSection %>/reset" onsubmit="return confirm('Reset this section to defaults? This cannot be undone.');" style="margin:0">
        <button class="cms-btn" type="submit" style="width:100%; justify-content:center;">
          <i class="bi bi-arrow-clockwise"></i> Reset Section
        </button>
      </form>
      <a href="/" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i> View Live Site</a>
    </div>
  </aside>

  <!-- ════════ EDITOR ════════ -->
  <main class="cms-editor">
    <div class="cms-editor-inner">
      <% if (typeof messages !== 'undefined' && messages && messages.success) { %>
        <div class="cms-flash cms-flash-success"><i class="bi bi-check-circle-fill"></i> <%= messages.success %></div>
      <% } %>
      <% if (typeof messages !== 'undefined' && messages && messages.error) { %>
        <div class="cms-flash cms-flash-error"><i class="bi bi-exclamation-circle-fill"></i> <%= messages.error %></div>
      <% } %>

      <h1><i class="bi <%= current.icon %>" style="color:var(--blue); margin-right:6px;"></i><%= current.label %></h1>
      <p class="lead">Edit the <%= current.label.toLowerCase() %> section. Changes appear in the live preview on the right.</p>

      <form id="cmsForm" method="POST" action="/admin/content/<%= activeSection %>" autocomplete="off">
        <%- include('cms/section-' + activeSection, { data: data }) %>
      </form>
    </div>
  </main>

  <!-- ════════ PREVIEW ════════ -->
  <section class="cms-preview">
    <div class="cms-preview-bar">
      <span class="url"><%= '/' %><%= activeSection === 'pricing' ? '#pricing' : (activeSection === 'faq' ? '#faq' : '') %></span>
      <div class="cms-preview-toggle" id="deviceToggle">
        <button data-device="desktop" class="active" title="Desktop"><i class="bi bi-laptop"></i></button>
        <button data-device="tablet"  title="Tablet"><i class="bi bi-tablet"></i></button>
        <button data-device="mobile"  title="Mobile"><i class="bi bi-phone"></i></button>
      </div>
    </div>
    <div class="cms-preview-stage device-desktop" id="previewStage">
      <iframe id="previewFrame" src="/?cms_preview=1#<%= activeSection %>" title="Preview"></iframe>
    </div>
  </section>
</div>

<script>
  // Reload preview after the form submits successfully (page reloads anyway).
  // Also expose a simple reload button & device-mode toggle.
  (function(){
    var btnReload = document.getElementById('btnReload');
    var frame = document.getElementById('previewFrame');
    if (btnReload) btnReload.addEventListener('click', function(){
      frame.src = frame.src.split('#')[0] + '?cms_preview=1&t=' + Date.now() + '#<%= activeSection %>';
    });

    var stage = document.getElementById('previewStage');
    var toggle = document.getElementById('deviceToggle');
    if (toggle) toggle.addEventListener('click', function(e){
      var btn = e.target.closest('button[data-device]');
      if (!btn) return;
      [].forEach.call(toggle.querySelectorAll('button'), function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      stage.className = 'cms-preview-stage device-' + btn.dataset.device;
    });

    // Mark "saving" while form submits, "saved" on full reload (handled by flash).
    var form = document.getElementById('cmsForm');
    var status = document.getElementById('saveStatus');
    if (form && status) {
      form.addEventListener('submit', function(){
        status.classList.remove('saved','error');
        status.classList.add('saving');
        status.querySelector('.lbl').textContent = 'Saving…';
      });
    }
  })();
</script>
</body>
</html>
