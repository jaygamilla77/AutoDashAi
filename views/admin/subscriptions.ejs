<h1>Subscriptions</h1>
<p style="color:#6b7280; margin-top:-16px; margin-bottom:24px;">Trial pipeline, active paying customers, and churned workspaces.</p>

<!-- Stats -->
<div class="row g-3 mb-3">
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="label">In Trial</div><div class="value"><%= stats.trialing %></div></div>
      <div class="icon" style="background:linear-gradient(135deg,#f59e0b,#d97706);"><i class="bi bi-stopwatch"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="label">Trial Expiring Soon (≤3d)</div><div class="value"><%= stats.expiring %></div></div>
      <div class="icon" style="background:linear-gradient(135deg,#ef4444,#dc2626);"><i class="bi bi-exclamation-triangle"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="label">Active Paying</div><div class="value"><%= stats.active %></div></div>
      <div class="icon" style="background:linear-gradient(135deg,#10b981,#059669);"><i class="bi bi-credit-card"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="label">Est. MRR (USD)</div><div class="value">$<%= stats.mrrEstimate %></div></div>
      <div class="icon" style="background:linear-gradient(135deg,#6366f1,#4f46e5);"><i class="bi bi-cash-stack"></i></div>
    </div>
  </div>
</div>

<% function row(item) { %>
  <tr>
    <td><strong><%= item.name %></strong></td>
    <td>
      <% if (item.owner) { %>
        <div style="font-size:0.85rem;"><%= item.owner.name || item.owner.email %></div>
        <div style="font-size:0.78rem; color:#6b7280;"><%= item.owner.email %></div>
      <% } else { %>—<% } %>
    </td>
    <td><span class="badge bg-secondary"><%= item.plan %></span></td>
    <td>
      <% if (item.trialEndsAt) { %>
        <%= new Date(item.trialEndsAt).toLocaleDateString() %>
      <% } else { %>—<% } %>
    </td>
    <td>
      <% if (item.daysLeft !== null && item.daysLeft !== undefined) { %>
        <% var col = item.daysLeft <= 0 ? '#ef4444' : (item.daysLeft <= 3 ? '#f59e0b' : '#10b981'); %>
        <span style="color:<%= col %>; font-weight:600;">
          <%= item.daysLeft <= 0 ? 'Expired' : (item.daysLeft + ' day' + (item.daysLeft === 1 ? '' : 's')) %>
        </span>
      <% } else { %>—<% } %>
    </td>
    <td style="text-align:right;">
      <a href="/admin/workspaces?q=<%= encodeURIComponent(item.name) %>" class="btn btn-sm btn-outline-primary">Manage</a>
    </td>
  </tr>
<% } %>

<!-- Expiring soon (priority section) -->
<% if (expiringSoon.length) { %>
  <h5 class="mt-4 mb-2"><i class="bi bi-exclamation-triangle text-danger"></i> Expiring within 3 days</h5>
  <div class="card" style="border:1px solid #fecaca; background:#fef2f2;">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead><tr><th>Workspace</th><th>Owner</th><th>Plan</th><th>Trial Ends</th><th>Time Left</th><th></th></tr></thead>
        <tbody><% expiringSoon.forEach(row); %></tbody>
      </table>
    </div>
  </div>
<% } %>

<!-- All trials -->
<h5 class="mt-4 mb-2">In Trial</h5>
<div class="card" style="border:1px solid #e5e7eb;">
  <div class="table-responsive">
    <table class="table mb-0 align-middle">
      <thead class="table-light"><tr><th>Workspace</th><th>Owner</th><th>Plan</th><th>Trial Ends</th><th>Time Left</th><th></th></tr></thead>
      <tbody>
        <% if (!trialing.length) { %>
          <tr><td colspan="6" class="text-center text-muted py-3">No active trials.</td></tr>
        <% } %>
        <% trialing.forEach(row); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Active paying -->
<h5 class="mt-4 mb-2">Active Paying</h5>
<div class="card" style="border:1px solid #e5e7eb;">
  <div class="table-responsive">
    <table class="table mb-0 align-middle">
      <thead class="table-light"><tr><th>Workspace</th><th>Owner</th><th>Plan</th><th>Trial Ends</th><th>Days</th><th></th></tr></thead>
      <tbody>
        <% if (!active.length) { %>
          <tr><td colspan="6" class="text-center text-muted py-3">No paying subscribers yet.</td></tr>
        <% } %>
        <% active.forEach(row); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Expired / Cancelled -->
<% if (expired.length) { %>
  <h5 class="mt-4 mb-2 text-muted">Expired / Cancelled</h5>
  <div class="card" style="border:1px solid #e5e7eb;">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead class="table-light"><tr><th>Workspace</th><th>Owner</th><th>Plan</th><th>Trial Ends</th><th>Status</th><th></th></tr></thead>
        <tbody><% expired.forEach(row); %></tbody>
      </table>
    </div>
  </div>
<% } %>
