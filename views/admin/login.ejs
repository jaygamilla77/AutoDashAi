<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign in — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #0b1020, #1e1b4b);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
    }
    .login-card {
      background: #fff;
      width: 100%;
      max-width: 420px;
      padding: 36px 32px;
      border-radius: 14px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.35);
    }
    .login-card h1 { font-size: 24px; font-weight: 700; margin: 0 0 6px; }
    .login-card .sub { color: #6b7280; font-size: 14px; margin-bottom: 24px; }
    .form-control { border-radius: 8px; padding: 10px 14px; font-size: 14px; }
    .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.18); }
    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
      border: none;
      padding: 11px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 15px;
      margin-top: 4px;
    }
    .btn-login:hover { color: #fff; opacity: 0.94; }
    .brand { display:flex; align-items:center; gap:10px; margin-bottom: 18px; color:#0b1020; }
    .brand i { color:#6366f1; font-size: 22px; }
    .brand strong { font-weight: 700; font-size: 18px; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="brand">
      <i class="bi bi-bar-chart-line-fill"></i>
      <strong>AutoDash AI Admin</strong>
    </div>
    <h1>Sign in</h1>
    <p class="sub">Enter your admin password to continue.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" style="font-size:13px;"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <div class="mb-3">
        <label class="form-label" style="font-size:13px;font-weight:600;color:#374151;">Password</label>
        <input type="password" name="password" class="form-control" required autofocus>
      </div>
      <button type="submit" class="btn-login">
        <i class="bi bi-box-arrow-in-right"></i> Sign in
      </button>
    </form>
  </div>
  <script>
    try { localStorage.removeItem('autodash_admin'); } catch(_) {}
  </script>
</body>
</html>
