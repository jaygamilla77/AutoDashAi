<h1>Dashboard</h1>

<div class="row g-3 mb-4">
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Total Pages</div>
        <div class="value"><%= stats.pages %></div>
      </div>
      <div class="icon"><i class="bi bi-file-earmark-text"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Total FAQs</div>
        <div class="value"><%= stats.faqs %></div>
      </div>
      <div class="icon"><i class="bi bi-patch-question"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Total Features</div>
        <div class="value"><%= stats.features %></div>
      </div>
      <div class="icon"><i class="bi bi-stars"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Total Inquiries</div>
        <div class="value"><%= stats.inquiries %></div>
      </div>
      <div class="icon"><i class="bi bi-inbox"></i></div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Templates</div>
        <div class="value"><%= stats.templates %></div>
      </div>
      <div class="icon" style="background:linear-gradient(135deg,#10b981,#059669);"><i class="bi bi-grid-3x3-gap"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Blog Posts</div>
        <div class="value"><%= stats.blogPosts %></div>
      </div>
      <div class="icon" style="background:linear-gradient(135deg,#f59e0b,#d97706);"><i class="bi bi-journal-text"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Testimonials</div>
        <div class="value"><%= stats.testimonials %></div>
      </div>
      <div class="icon" style="background:linear-gradient(135deg,#ec4899,#db2777);"><i class="bi bi-chat-quote"></i></div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div>
        <div class="label">Portfolio Items</div>
        <div class="value"><%= stats.portfolio %></div>
      </div>
      <div class="icon" style="background:linear-gradient(135deg,#0ea5e9,#0284c7);"><i class="bi bi-collection"></i></div>
    </div>
  </div>
</div>

<div class="admin-card">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 style="margin:0;">Recent Inquiries</h2>
    <a href="/admin/inquiries" class="btn btn-sm btn-outline-secondary">View all</a>
  </div>
  <% if (!recentInquiries || !recentInquiries.length) { %>
    <div class="empty-state"><i class="bi bi-inbox"></i><p>No inquiries yet.</p></div>
  <% } else { %>
    <div class="table-responsive">
      <table class="admin-table" style="border:none;">
        <thead>
          <tr><th>Name</th><th>Email</th><th>Message</th><th>Date</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% recentInquiries.forEach(function(i) { %>
            <tr>
              <td><strong><%= i.name %></strong></td>
              <td><%= i.email %></td>
              <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= i.message %></td>
              <td><%= new Date(i.createdAt).toLocaleDateString() %></td>
              <td><span class="badge-pill badge-<%= i.status %>"><%= i.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
