<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle + ' — Admin' : 'Admin' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --admin-bg: #f3f4f6;
      --admin-card: #ffffff;
      --admin-border: #e5e7eb;
      --admin-text: #111827;
      --admin-muted: #6b7280;
      --admin-primary: #6366f1;
      --admin-primary-2: #8b5cf6;
      --admin-header: #0b1020;
      --admin-active-bg: #eef2ff;
      --admin-active-text: #4f46e5;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--admin-bg);
      color: var(--admin-text);
      font-size: 14.5px;
    }
    .admin-header {
      background: var(--admin-header);
      color: #fff;
      padding: 14px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .admin-header .brand {
      font-weight: 700;
      font-size: 18px;
      letter-spacing: -0.01em;
    }
    .admin-header .brand .accent { opacity: 0.7; font-weight: 500; margin-left: 4px; }
    .admin-header .actions { display: flex; gap: 12px; align-items: center; }
    .admin-header .actions a, .admin-header .actions button {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.18);
      color: #e5e7eb;
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 13px;
      text-decoration: none;
      cursor: pointer;
    }
    .admin-header .actions a:hover, .admin-header .actions button:hover { background: rgba(255,255,255,0.08); }

    .admin-shell {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: calc(100vh - 56px);
    }
    .admin-sidebar {
      background: #ffffff;
      border-right: 1px solid var(--admin-border);
      padding: 20px 14px;
    }
    .admin-sidebar .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #374151;
      padding: 10px 14px;
      border-radius: 8px;
      font-weight: 500;
      font-size: 14px;
      margin-bottom: 2px;
      text-decoration: none;
    }
    .admin-sidebar .nav-link:hover { background: #f9fafb; color: #111827; }
    .admin-sidebar .nav-link.active {
      background: var(--admin-active-bg);
      color: var(--admin-active-text);
      font-weight: 600;
    }
    .admin-sidebar .nav-link i { font-size: 17px; width: 20px; text-align: center; }
    .admin-sidebar .nav-section {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #9ca3af;
      padding: 14px 14px 6px;
      font-weight: 600;
    }

    .admin-main {
      padding: 28px 36px;
      max-width: 1200px;
    }
    .admin-main h1 {
      font-size: 28px;
      font-weight: 700;
      margin: 0 0 24px;
      letter-spacing: -0.02em;
    }
    .admin-card {
      background: var(--admin-card);
      border: 1px solid var(--admin-border);
      border-radius: 10px;
      padding: 22px;
      margin-bottom: 20px;
    }
    .admin-card h2 {
      font-size: 16px;
      font-weight: 600;
      margin: 0 0 16px;
      color: #111827;
    }
    .admin-card .form-label {
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 6px;
    }
    .admin-card .form-control,
    .admin-card .form-select {
      font-size: 14px;
      border-radius: 8px;
      border-color: #d1d5db;
    }
    .admin-card .form-control:focus,
    .admin-card .form-select:focus {
      border-color: var(--admin-primary);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    .stat-card {
      background: var(--admin-card);
      border: 1px solid var(--admin-border);
      border-radius: 10px;
      padding: 20px;
    }
    .stat-card .label { color: var(--admin-muted); font-size: 13px; font-weight: 500; }
    .stat-card .value { font-size: 28px; font-weight: 700; margin-top: 6px; letter-spacing: -0.02em; }
    .stat-card .icon {
      width: 38px; height: 38px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff; font-size: 18px;
    }

    .btn-primary-pill {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
      border: none;
      padding: 10px 20px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 14px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-primary-pill:hover { color: #fff; opacity: 0.92; }

    .admin-table {
      width: 100%;
      background: var(--admin-card);
      border: 1px solid var(--admin-border);
      border-radius: 10px;
      overflow: hidden;
    }
    .admin-table th {
      text-align: left;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #6b7280;
      background: #f9fafb;
      padding: 12px 18px;
      font-weight: 600;
      border-bottom: 1px solid var(--admin-border);
    }
    .admin-table td {
      padding: 14px 18px;
      border-bottom: 1px solid var(--admin-border);
      font-size: 14px;
      vertical-align: middle;
    }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table .actions { white-space: nowrap; text-align: right; }
    .admin-table .actions .btn { padding: 4px 10px; font-size: 13px; margin-left: 6px; }

    .badge-pill {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }
    .badge-active { background: #dcfce7; color: #166534; }
    .badge-inactive { background: #f3f4f6; color: #6b7280; }
    .badge-draft { background: #fef3c7; color: #92400e; }
    .badge-published { background: #dbeafe; color: #1e40af; }
    .badge-new { background: #fee2e2; color: #991b1b; }
    .badge-read { background: #e0e7ff; color: #3730a3; }
    .badge-replied { background: #dcfce7; color: #166534; }
    .badge-archived { background: #f3f4f6; color: #6b7280; }

    .empty-state {
      text-align: center;
      padding: 50px 20px;
      color: var(--admin-muted);
    }
    .empty-state i { font-size: 48px; opacity: 0.3; }
    .empty-state p { margin-top: 14px; font-size: 14px; }

    .alert { border-radius: 8px; }
  </style>
</head>
<body>
  <%- include('_header') %>
  <div class="admin-shell">
    <%- include('_sidebar') %>
    <main class="admin-main">
      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
      <% } %>
      <%- body %>
    </main>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Mirror admin auth flag in localStorage for client-side UX consistency
    try { localStorage.setItem('autodash_admin', '1'); } catch(_) {}
  </script>
</body>
</html>
