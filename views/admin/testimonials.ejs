<h1>Testimonials</h1>

<div class="admin-card">
  <h2 id="formTitle">Add Testimonial</h2>
  <form method="POST" action="/admin/testimonials" id="tForm">
    <input type="hidden" name="index" id="t-index" value="">
    <div class="row g-3">
      <div class="col-md-6"><label class="form-label">Customer Name</label><input class="form-control" name="name" id="t-name" required></div>
      <div class="col-md-4"><label class="form-label">Role / Company</label><input class="form-control" name="role" id="t-role"></div>
      <div class="col-md-2">
        <label class="form-label">Rating (1-5)</label>
        <input type="number" class="form-control" name="rating" id="t-rating" min="1" max="5" value="5">
      </div>
      <div class="col-md-12"><label class="form-label">Quote</label><textarea class="form-control" name="quote" id="t-quote" rows="3" required></textarea></div>
    </div>
    <div class="d-flex gap-2 mt-3">
      <button type="submit" class="btn-primary-pill" id="t-submit"><i class="bi bi-plus-lg"></i> Add Testimonial</button>
      <button type="button" class="btn btn-outline-secondary" id="t-cancel" style="border-radius:999px;padding:10px 20px;display:none;">Cancel</button>
    </div>
  </form>
</div>

<div class="admin-card" style="padding:0;">
  <% if (!items.length) { %>
    <div class="empty-state"><i class="bi bi-chat-quote"></i><p>No testimonials yet.</p></div>
  <% } else { %>
    <table class="admin-table" style="border:none;">
      <thead><tr><th>Name</th><th>Role</th><th>Rating</th><th>Quote</th><th class="actions">Actions</th></tr></thead>
      <tbody>
        <% items.forEach(function(t, i) { %>
          <tr>
            <td><strong><%= t.name %></strong></td>
            <td style="color:#6b7280;"><%= t.role || '' %></td>
            <td><% for (var k=0;k<5;k++) { %><i class="bi bi-star<%= k < (t.rating || 5) ? '-fill' : '' %>" style="color:#f59e0b;"></i><% } %></td>
            <td style="max-width:340px;color:#6b7280;"><%= (t.quote || '').slice(0,140) %></td>
            <td class="actions">
              <button class="btn btn-sm btn-outline-primary t-edit"
                data-i="<%= i %>" data-name="<%= t.name %>" data-role="<%= t.role || '' %>"
                data-quote="<%= t.quote || '' %>" data-rating="<%= t.rating || 5 %>">
                <i class="bi bi-pencil"></i>
              </button>
              <form method="POST" action="/admin/testimonials/<%= i %>/delete" style="display:inline;" onsubmit="return confirm('Delete this testimonial?');">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
  document.querySelectorAll('.t-edit').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('t-index').value = btn.dataset.i;
      document.getElementById('t-name').value = btn.dataset.name;
      document.getElementById('t-role').value = btn.dataset.role;
      document.getElementById('t-quote').value = btn.dataset.quote;
      document.getElementById('t-rating').value = btn.dataset.rating;
      document.getElementById('formTitle').textContent = 'Edit Testimonial';
      document.getElementById('t-submit').innerHTML = '<i class="bi bi-check-lg"></i> Save Testimonial';
      document.getElementById('t-cancel').style.display = '';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
  document.getElementById('t-cancel').addEventListener('click', function() {
    document.getElementById('tForm').reset();
    document.getElementById('t-index').value = '';
    document.getElementById('formTitle').textContent = 'Add Testimonial';
    document.getElementById('t-submit').innerHTML = '<i class="bi bi-plus-lg"></i> Add Testimonial';
    this.style.display = 'none';
  });
</script>
