<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'AutoDash AI' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <a href="/"><i class="bi bi-bar-chart-line-fill"></i></a>
    </div>
    <nav class="sidebar-nav">
      <a href="/" class="sidebar-link" title="Home">
        <i class="bi bi-house-fill"></i>
        <span>Home</span>
      </a>
      <a href="/dashboard/history" class="sidebar-link" title="Dashboards">
        <i class="bi bi-grid-3x3-gap-fill"></i>
        <span>Dashboards</span>
      </a>
      <a href="/sources" class="sidebar-link" title="Sources">
        <i class="bi bi-database-fill"></i>
        <span>Sources</span>
      </a>
      <a href="/templates" class="sidebar-link" title="Templates">
        <i class="bi bi-palette2"></i>
        <span>Templates</span>
      </a>
      <a href="/" class="sidebar-link" title="AI Assistant">
        <i class="bi bi-stars"></i>
        <span>AI</span>
      </a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/ai-settings" class="sidebar-link" title="AI Settings">
        <i class="bi bi-gear-fill"></i>
        <span>Settings</span>
      </a>
      <a href="#" class="sidebar-link" title="Help" onclick="return false">
        <i class="bi bi-question-circle-fill"></i>
        <span>Help</span>
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="main-wrapper">
    <%- include('../partials/alerts') %>
    <main class="main-content">
      <%- body %>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <!-- Apache ECharts — primary rendering engine for advanced chart types -->
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
  <!-- SheetJS — Excel export -->
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <!-- jsPDF + html2canvas — PDF export -->
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <!-- GridStack.js — drag-and-drop dashboard layout -->
  <link href="https://cdn.jsdelivr.net/npm/gridstack@8.4.0/dist/gridstack.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/gridstack@8.4.0/dist/gridstack-all.compat.min.js"></script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/layout-manager.js"></script>
  <script>
    // Highlight active sidebar link
    document.querySelectorAll('.sidebar-link').forEach(function(link) {
      var href = link.getAttribute('href');
      var path = window.location.pathname;
      if (!href || href === '#') return;
      if (href === '/') {
        if (path === '/' || path.startsWith('/dashboard/') && path.endsWith('/edit-canvas')) link.classList.add('active');
      } else if (href === '/dashboard/history') {
        if (path === '/dashboard/history' || (path.startsWith('/dashboard/') && !path.endsWith('/edit-canvas'))) link.classList.add('active');
      } else {
        if (path === href || path.startsWith(href + '/')) link.classList.add('active');
      }
    });
  </script>
</body>
</html>
