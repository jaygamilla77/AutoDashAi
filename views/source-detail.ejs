<div class="page-header d-flex justify-content-between align-items-center">
  <div>
    <h1><%= source.name %></h1>
    <p><%= source.sourceType %> &middot; <%= source.status %> &middot; Created <%= new Date(source.createdAt).toLocaleDateString() %></p>
  </div>
  <div class="d-flex gap-2">
    <form action="/sources/<%= source.id %>/analyze" method="POST">
      <button type="submit" class="btn btn-outline-secondary btn-sm" title="Re-run relationship detection and prompt suggestions">
        <i class="bi bi-lightbulb me-1"></i>Analyze
      </button>
    </form>
    <form action="/sources/<%= source.id %>/test" method="POST">
      <button type="submit" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh Data
      </button>
    </form>
  </div>
</div>

<% if (typeof source !== 'undefined' && source) { %>

<% if (typeof config !== 'undefined' && config) { %>
<%
  function renderConfigValue(val) {
    if (val === null || val === undefined) return '<span class="text-muted">—</span>';
    if (typeof val === 'boolean') return '<span class="badge bg-' + (val ? 'success' : 'secondary') + '">' + val + '</span>';
    if (typeof val === 'number') return '<code>' + val + '</code>';
    if (typeof val === 'string') {
      const esc = String(val).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      if (/^https?:\/\//i.test(val)) return '<a href="' + esc + '" target="_blank" rel="noopener">' + esc + '</a>';
      return esc || '<span class="text-muted">(empty)</span>';
    }
    if (Array.isArray(val)) {
      if (val.length === 0) return '<span class="text-muted">(empty list)</span>';
      return '<code style="font-size:0.78rem">' + JSON.stringify(val) + '</code>';
    }
    if (typeof val === 'object') {
      const keys = Object.keys(val);
      if (keys.length === 0) return '<span class="text-muted">(none)</span>';
      let html = '<table class="table table-sm mb-0" style="background:transparent"><tbody>';
      keys.forEach(function(k) {
        html += '<tr><td class="text-muted" style="width:35%;border:0;padding:2px 8px 2px 0"><small>' + k + '</small></td>'
             + '<td style="border:0;padding:2px 0"><small>' + renderConfigValue(val[k]) + '</small></td></tr>';
      });
      html += '</tbody></table>';
      return html;
    }
    return String(val);
  }
%>
<div class="row mb-3">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-white">
        <h6 class="mb-0">Configuration</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th style="width:25%">Field</th>
                <th>Value</th>
              </tr>
            </thead>
            <tbody>
              <% Object.keys(config).forEach(function(key) { %>
              <tr>
                <td><strong><%= key %></strong></td>
                <td><%- renderConfigValue(config[key]) %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Schema / Profile — tabbed per dataset/sheet -->
<% if (typeof datasets !== 'undefined' && datasets && datasets.length > 0) { %>

<% if (datasets.length > 1) { %>
<!-- Tab navigation (multi-sheet Excel) -->
<div class="card mb-3">
  <div class="card-header bg-white p-0">
    <ul class="nav nav-tabs border-0 px-3" id="sheetTabs" role="tablist">
      <% datasets.forEach(function(ds, i) { %>
        <li class="nav-item" role="presentation">
          <button class="nav-link <%= i === 0 ? 'active' : '' %>" id="tab-<%= i %>"
            data-bs-toggle="tab" data-bs-target="#panel-<%= i %>"
            type="button" role="tab">
            <i class="bi bi-table me-1"></i><%= ds.datasetName %>
          </button>
        </li>
      <% }); %>
      <% if (unifiedDataset) { %>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-unified"
          data-bs-toggle="tab" data-bs-target="#panel-unified"
          type="button" role="tab">
          <i class="bi bi-layers me-1"></i>Unified Table
        </button>
      </li>
      <% } %>
      <% if (analysis) { %>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-analysis"
          data-bs-toggle="tab" data-bs-target="#panel-analysis"
          type="button" role="tab">
          <i class="bi bi-lightbulb me-1"></i>Analysis & Prompts
        </button>
      </li>
      <% } %>
    </ul>
  </div>
</div>
<% } %>

<div class="tab-content" id="sheetTabsContent">
  <% datasets.forEach(function(ds, i) { %>
  <div class="tab-pane fade <%= i === 0 ? 'show active' : '' %>" id="panel-<%= i %>" role="tabpanel">

    <!-- Profile Stats -->
    <% if (ds.profileData) { %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="card text-center">
          <div class="card-body py-3">
            <h3 class="kpi-value"><%= ds.profileData.totalRows || 0 %></h3>
            <p class="kpi-label mb-0">Rows</p>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card text-center">
          <div class="card-body py-3">
            <h3 class="kpi-value"><%= ds.profileData.totalColumns || 0 %></h3>
            <p class="kpi-label mb-0">Columns</p>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card text-center">
          <div class="card-body py-3">
            <h3 class="kpi-value"><%= (ds.profileData.measures || []).length %></h3>
            <p class="kpi-label mb-0">Measures</p>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card text-center">
          <div class="card-body py-3">
            <h3 class="kpi-value"><%= (ds.profileData.dateFields || []).length %></h3>
            <p class="kpi-label mb-0">Date Fields</p>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Schema Table -->
    <% if (ds.schemaData && ds.schemaData.length > 0) { %>
    <div class="card mb-4">
      <div class="card-header bg-white">
        <h6 class="mb-0">Schema</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Column</th>
                <th>Type</th>
                <th>Role</th>
                <th>Distinct</th>
                <th>Nulls</th>
                <th>Sample Values</th>
              </tr>
            </thead>
            <tbody>
              <% ds.schemaData.forEach(function(field) { %>
              <tr>
                <td><strong><%= field.name %></strong></td>
                <td><span class="badge bg-secondary"><%= field.type %></span></td>
                <td><span class="badge bg-secondary"><%= field.role %></span></td>
                <td><%= field.distinctCount %></td>
                <td><%= field.nullCount %></td>
                <td><small class="text-muted"><%= (field.sampleValues || []).slice(0, 3).join(', ') %></small></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Preview Table -->
    <% if (ds.previewData && ds.previewData.length > 0) { %>
    <div class="card mb-4">
      <div class="card-header bg-white">
        <h6 class="mb-0">Preview — <%= ds.previewData.length %> rows</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover table-sm mb-0">
            <thead class="table-dark">
              <tr>
                <% Object.keys(ds.previewData[0]).forEach(function(key) { %>
                  <th><%= key %></th>
                <% }); %>
              </tr>
            </thead>
            <tbody>
              <% ds.previewData.slice(0, 50).forEach(function(row) { %>
              <tr>
                <% Object.keys(ds.previewData[0]).forEach(function(key) { %>
                  <td><small><%= row[key] != null ? String(row[key]).substring(0, 60) : '-' %></small></td>
                <% }); %>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

  </div>
  <% }); %>

<!-- Unified Table Panel -->
<% if (unifiedDataset && unifiedDataset.previewData && unifiedDataset.previewData.length > 0) { %>
<div class="tab-pane fade" id="panel-unified" role="tabpanel">
  <div class="row g-3 mb-4">
    <% if (unifiedDataset.profileData) { %>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="card-body py-3">
          <h3 class="kpi-value"><%= unifiedDataset.profileData.totalRows || unifiedDataset.previewData.length %></h3>
          <p class="kpi-label mb-0">Total Rows</p>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="card-body py-3">
          <h3 class="kpi-value"><%= unifiedDataset.profileData.totalColumns || 0 %></h3>
          <p class="kpi-label mb-0">Columns</p>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="card-body py-3">
          <h3 class="kpi-value"><%= (unifiedDataset.profileData.measures || []).length %></h3>
          <p class="kpi-label mb-0">Measures</p>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="card-body py-3">
          <h3 class="kpi-value"><%= datasets.length %></h3>
          <p class="kpi-label mb-0">Sheets Merged</p>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <div class="alert" style="background:#f0f9ff;border-color:#bae6fd;color:#075985;font-size:0.82rem">
    <i class="bi bi-info-circle me-1"></i>
    All sheets are merged into one table. The <code>_sheet</code> column identifies the origin sheet for each row.
  </div>

  <div class="card mb-4">
    <div class="card-header">Unified Preview — <%= unifiedDataset.previewData.length %> rows shown</div>
    <div class="card-body p-0">
      <div class="table-responsive" style="max-height:400px;overflow:auto">
        <table class="table table-striped table-hover table-sm mb-0">
          <thead class="table-dark" style="position:sticky;top:0">
            <tr>
              <% Object.keys(unifiedDataset.previewData[0]).forEach(function(key) { %>
                <th style="white-space:nowrap"><%= key %></th>
              <% }); %>
            </tr>
          </thead>
          <tbody>
            <% unifiedDataset.previewData.forEach(function(row) { %>
            <tr>
              <% Object.keys(unifiedDataset.previewData[0]).forEach(function(key) { %>
                <td>
                  <% if (key === '_sheet') { %>
                    <span class="badge bg-secondary" style="font-size:0.65rem"><%= row[key] %></span>
                  <% } else { %>
                    <small><%= row[key] != null ? String(row[key]).substring(0, 60) : '-' %></small>
                  <% } %>
                </td>
              <% }); %>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Analysis & Prompts Panel -->
<% if (analysis) { %>
<div class="tab-pane fade" id="panel-analysis" role="tabpanel">

  <!-- Relationship Map -->
  <% if (analysis.relationships && analysis.relationships.length > 0) { %>
  <div class="card mb-4">
    <div class="card-header"><i class="bi bi-diagram-3 me-1"></i>Detected Relationships</div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Sheet A</th>
            <th>Sheet B</th>
            <th>Common Columns (Potential Join Keys)</th>
            <th>Strength</th>
          </tr>
        </thead>
        <tbody>
          <% analysis.relationships.forEach(function(rel) { %>
          <tr>
            <td><span class="badge bg-secondary"><%= rel.sheetA %></span></td>
            <td><span class="badge bg-secondary"><%= rel.sheetB %></span></td>
            <td>
              <% rel.sharedColumns.forEach(function(col) { %>
                <code style="font-size:0.78rem;margin-right:4px"><%= col %></code>
              <% }); %>
            </td>
            <td>
              <span class="badge" style="background:<%= rel.type === 'strong' ? '#15803d' : '#b45309' %>;font-size:0.65rem">
                <%= rel.type === 'strong' ? 'Strong' : 'Possible' %>
              </span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } else { %>
  <div class="alert mb-4" style="background:#f9fafb;border-color:#e5e7eb;color:#6b7280;font-size:0.82rem">
    <i class="bi bi-info-circle me-1"></i>No column-level relationships detected between sheets.
  </div>
  <% } %>

  <!-- Suggested Prompts -->
  <% if (analysis.suggestedPrompts && analysis.suggestedPrompts.length > 0) { %>
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span><i class="bi bi-lightbulb me-1"></i>Suggested Dashboard Prompts</span>
      <span class="text-muted" style="font-size:0.75rem"><%= analysis.suggestedPrompts.length %> ideas generated</span>
    </div>
    <div class="card-body">
      <p class="text-muted mb-3" style="font-size:0.8rem">
        Click any prompt to open the dashboard builder with it pre-filled and this data source selected.
      </p>

      <%
        var categories = [];
        analysis.suggestedPrompts.forEach(function(p) {
          if (!categories.includes(p.category)) categories.push(p.category);
        });
        var catColors = {
          'Trend': '#1d4ed8', 'Comparison': '#7c3aed', 'Breakdown': '#0891b2',
          'Ranking': '#be123c', 'Distribution': '#15803d', 'Summary': '#374151',
          'KPI': '#b45309', 'Cross-Sheet': '#6d28d9', 'General': '#4b5563'
        };
      %>

      <% categories.forEach(function(cat) { %>
        <div class="mb-4">
          <p class="mb-2" style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.4px;color:<%= catColors[cat] || '#374151' %>">
            <%= cat %>
          </p>
          <div class="d-flex flex-wrap gap-2">
            <% analysis.suggestedPrompts.filter(function(p) { return p.category === cat; }).forEach(function(p) { %>
              <a href="/?prompt=<%= encodeURIComponent(p.text) %>&sourceId=<%= source.id %>"
                 class="btn btn-sm"
                 style="font-size:0.78rem;border:1px solid #e5e7eb;background:#fff;color:#374151;border-radius:4px"
                 title="Click to open dashboard builder with this prompt">
                <i class="bi bi-arrow-right-circle me-1" style="color:<%= catColors[cat] || '#374151' %>"></i>
                <%= p.text %>
              </a>
            <% }); %>
          </div>
        </div>
      <% }); %>

    </div>
  </div>
  <% } %>

</div><!-- /tab-pane analysis -->
</div><!-- /tab-content -->
<% } %>

<% } %>

<% } else { %>
  <div class="text-center py-5">
    <p class="text-muted">Source not found.</p>
    <a href="/sources" class="btn btn-primary">Back to Sources</a>
  </div>
<% } %>
