<% if (typeof dashboard !== 'undefined' && dashboard) { %>

<!-- Dashboard Header -->
<div class="page-header d-flex justify-content-between align-items-start">
  <div>
    <h1><%= dashboard.title %></h1>
    <p><%= dashboard.subtitle %></p>
  </div>
  <div class="d-flex gap-2">
    <span class="badge bg-secondary"><%= dashboard.dataSourceName %></span>
    <span class="badge bg-secondary"><%= dashboard.chartType %></span>
  </div>
</div>

<!-- KPI Cards -->
<% if (dashboard.kpis && dashboard.kpis.length > 0) { %>
  <% var kpis = dashboard.kpis; %>
  <%- include('partials/kpiCards') %>
<% } %>

<% if (dashboard.hasData) { %>

  <!-- Chart Section -->
  <% if (dashboard.chartConfig && dashboard.chartType !== 'table') { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-body">
          <div class="chart-container" style="position: relative; height: 400px;">
            <canvas id="dashboardChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    window.__chartConfig = <%- JSON.stringify(dashboard.chartConfig) %>;
  </script>
  <% } %>

  <!-- Data Table -->
  <% if (dashboard.tableData && dashboard.tableData.rows && dashboard.tableData.rows.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-white">
          <h6 class="mb-0">Data</h6>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
              <thead class="table-dark">
                <tr>
                  <% dashboard.tableData.columns.forEach(function(col) { %>
                    <th><%= col %></th>
                  <% }); %>
                </tr>
              </thead>
              <tbody>
                <% dashboard.tableData.rows.forEach(function(row) { %>
                <tr>
                  <% dashboard.tableData.columns.forEach(function(col) { %>
                    <td><%= row[col] != null ? row[col] : '-' %></td>
                  <% }); %>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

<% } else { %>
  <!-- No Data State -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-body text-center py-5">
          <h5 class="text-muted">No Data Found</h5>
          <p class="text-muted">
            The query returned no results. Try a different prompt or check your data source.
            <% if (dashboard.summary && dashboard.summary.message) { %>
              <br><small><%= dashboard.summary.message %></small>
            <% } %>
          </p>
          <a href="/" class="btn btn-primary">Try Another Prompt</a>
        </div>
      </div>
    </div>
  </div>
<% } %>

<!-- Prompt Interpretation -->
<% if (dashboard.structuredRequest) { %>
<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-white">
        <h6 class="mb-0">Prompt Interpretation</h6>
      </div>
      <div class="card-body">
        <pre class="bg-light p-3 rounded mb-0"><code><%= JSON.stringify(dashboard.structuredRequest, null, 2) %></code></pre>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Save Dashboard -->
<div class="row mb-4">
  <div class="col-12">
    <form action="/dashboard/save" method="POST" class="d-inline">
      <input type="hidden" name="title" value="<%= dashboard.title %>">
      <input type="hidden" name="promptText" value="<%= dashboard.originalPrompt %>">
      <input type="hidden" name="dashboardConfigJson" value='<%- JSON.stringify({ kpis: dashboard.kpis, chartConfig: dashboard.chartConfig, tableData: dashboard.tableData, summary: dashboard.summary }) %>'>
      <input type="hidden" name="dataSourceId" value="<%= dashboard.dataSourceId || '' %>">
      <button type="submit" class="btn btn-primary btn-sm me-2">
        Save Dashboard
      </button>
    </form>
    <a href="/" class="btn btn-outline-secondary btn-sm">
      New Query
    </a>
  </div>
</div>

<% } else { %>
  <div class="text-center py-5">
    <p class="text-muted">No dashboard data available.</p>
    <a href="/" class="btn btn-primary">Go Home</a>
  </div>
<% } %>
