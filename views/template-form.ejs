<div class="page-header">
  <h1><%= typeof template !== 'undefined' && template ? 'Edit Template' : 'New Template' %></h1>
  <p>Define a color palette and font to apply to your generated dashboards.</p>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">

    <% var isEdit = typeof template !== 'undefined' && template; %>
    <% var action = isEdit ? '/templates/' + template.id : '/templates'; %>
    <% var palette = isEdit ? JSON.parse(template.colorPalette || '[]') : ['#1e40af','#2563eb','#3b82f6','#60a5fa','#93c5fd','#bfdbfe','#1e3a8a','#dbeafe']; %>
    <% while (palette.length < 8) { palette.push('#cccccc'); } %>

    <div class="card mb-4">
      <div class="card-header">Template Settings</div>
      <div class="card-body p-4">
        <form action="<%= action %>" method="POST" id="templateForm">

          <div class="mb-3">
            <label class="form-label">Template Name</label>
            <input type="text" class="form-control" name="name" required
              value="<%= isEdit ? template.name : '' %>"
              placeholder="e.g., Corporate Blue, Warm Sunset">
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <input type="text" class="form-control" name="description"
              value="<%= isEdit ? (template.description || '') : '' %>"
              placeholder="Short description of this theme">
          </div>

          <div class="mb-4">
            <label class="form-label">Font Family</label>
            <select class="form-select" name="fontFamily" id="fontSelect">
              <% var fonts = ['Inter','Lato','Roboto','Merriweather','Georgia','Trebuchet MS']; %>
              <% fonts.forEach(function(f) { %>
                <option value="<%= f %>" <%= (isEdit && template.fontFamily === f) ? 'selected' : (!isEdit && f === 'Inter' ? 'selected' : '') %>>
                  <%= f %>
                </option>
              <% }); %>
            </select>
            <p id="fontPreview" class="mt-2 text-muted mb-0" style="font-size:1rem">
              The quick brown fox jumps over the lazy dog.
            </p>
          </div>

          <!-- Color Palette -->
          <div class="mb-4">
            <label class="form-label">Color Palette <span class="text-muted fw-normal">(8 colors for chart data)</span></label>
            <div class="row g-2" id="colorPickers">
              <% for (var i = 0; i < 8; i++) { %>
              <div class="col-6 col-md-3">
                <div class="color-picker-cell d-flex align-items-center gap-2 p-2 border rounded">
                  <input type="color" class="form-control form-control-color palette-color flex-shrink-0"
                    name="c<%= i %>" id="c<%= i %>"
                    value="<%= palette[i] %>" title="Color <%= i + 1 %>">
                  <div>
                    <div class="text-muted" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.3px">Color <%= i + 1 %></div>
                    <div class="color-hex" style="font-size:0.78rem;font-family:monospace"><%= palette[i] %></div>
                  </div>
                </div>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Accent Color -->
          <div class="mb-4">
            <label class="form-label">Accent Color <span class="text-muted fw-normal">(used for KPI values and headings)</span></label>
            <div class="d-flex align-items-center gap-3">
              <input type="color" class="form-control form-control-color" name="accentColor" id="accentColor"
                value="<%= isEdit ? template.accentColor : '#1e40af' %>" style="width:60px;height:38px">
              <span class="text-muted" style="font-size:0.85rem">Primary accent</span>
            </div>
          </div>

          <!-- Preferred Chart Types -->
          <% var ALL_CHART_TYPES = ['bar','line','pie','doughnut','scatter','table']; %>
          <% var savedChartTypes = []; %>
          <% if (isEdit && template.preferredChartTypes) { try { savedChartTypes = JSON.parse(template.preferredChartTypes); } catch(e) {} } %>
          <div class="mb-4">
            <label class="form-label">Preferred Chart Types <span class="text-muted fw-normal">(select all that suit this theme)</span></label>
            <div class="d-flex flex-wrap gap-2">
              <% ALL_CHART_TYPES.forEach(function(ct) { %>
                <% var checked = savedChartTypes.includes(ct); %>
                <label class="chart-type-toggle d-flex align-items-center gap-1 px-3 py-2 border rounded" style="cursor:pointer;font-size:0.8rem;user-select:none;background:<%= checked ? 'var(--accent)' : '#fff' %>;color:<%= checked ? '#fff' : 'inherit' %>">
                  <input type="checkbox" name="chartTypes" value="<%= ct %>" class="chart-type-cb d-none" <%= checked ? 'checked' : '' %>>
                  <i class="bi bi-<%= ct === 'bar' ? 'bar-chart' : ct === 'line' ? 'graph-up' : ct === 'pie' ? 'pie-chart' : ct === 'doughnut' ? 'pie-chart-fill' : ct === 'scatter' ? 'diagram-3' : 'table' %>"></i>
                  <%= ct.charAt(0).toUpperCase() + ct.slice(1) %>
                </label>
              <% }); %>
            </div>
            <p class="text-muted mt-2 mb-0" style="font-size:0.75rem">When a user selects this template, the chart type dropdown auto-filters to these options.</p>
          </div>

          <!-- Live Preview -->
          <div class="mb-4">
            <label class="form-label">Live Preview <span class="text-muted fw-normal">(updates as you change settings)</span></label>
            <div id="miniDashContainer" class="border rounded" style="overflow:hidden;background:#f0f2f5"></div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><%= isEdit ? 'Save Changes' : 'Create Template' %></button>
            <a href="/templates" class="btn btn-outline-secondary">Cancel</a>
          </div>

        </form>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  var fontSelect = document.getElementById('fontSelect');
  var accentInput = document.getElementById('accentColor');
  var container = document.getElementById('miniDashContainer');

  var KPI_LABELS = ['Total Hrs', 'Employees', 'Projects', 'Avg Hrs/Wk'];
  var KPI_VALS   = ['1,260', '26', '6', '12.1'];
  var BAR_H      = [82,55,67,90,48,72,55,78,65,85,43,70];
  var TABLE_ROWS = [['Alice Martin','98.5',0],['Bob Chen','76.0',1],['Carol Wu','54.2',2]];

  function getPalette() {
    var pickers = document.querySelectorAll('.palette-color');
    return Array.from(pickers).map(function(inp) { return inp.value; });
  }

  function buildMiniDash() {
    var p = getPalette();
    while (p.length < 8) p.push('#cccccc');
    var font = fontSelect.value;
    var templateName = document.querySelector('input[name="name"]').value || 'Preview';

    function kpiCard(i) {
      return '<div style="flex:1;background:' + p[i] + ';border-radius:3px;padding:5px 6px">' +
        '<div style="font-size:0.3rem;color:rgba(255,255,255,0.72);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:1px">' + KPI_LABELS[i] + '</div>' +
        '<div style="font-size:0.72rem;font-weight:700;color:#fff">' + KPI_VALS[i] + '</div>' +
        '<div style="font-size:0.28rem;color:rgba(255,255,255,0.55);margin-top:1px">&#9650; 8.5%</div>' +
        '</div>';
    }

    function bar(h, i) {
      return '<div style="flex:1;background:' + p[i % p.length] + ';height:' + h + '%;border-radius:1px 1px 0 0;opacity:0.82"></div>';
    }

    function tableRow(row) {
      return '<div style="display:flex;align-items:center;padding:3px 6px;border-bottom:1px solid #f3f4f6">' +
        '<div style="flex:2;font-size:0.32rem;color:#374151">' + row[0] + '</div>' +
        '<div style="flex:1;font-size:0.32rem;color:#374151">' + row[1] + '</div>' +
        '<div style="flex:1"><span style="font-size:0.28rem;background:' + p[row[2]] + ';color:#fff;border-radius:2px;padding:1px 4px">Active</span></div>' +
        '</div>';
    }

    container.innerHTML =
      '<div style="font-family:\'' + font + '\',sans-serif;background:#f0f2f5">' +
        // Chrome
        '<div style="background:#1e1e1e;padding:6px 10px;display:flex;align-items:center;gap:5px">' +
          '<div style="width:7px;height:7px;border-radius:50%;background:#ff5f57"></div>' +
          '<div style="width:7px;height:7px;border-radius:50%;background:#febc2e"></div>' +
          '<div style="width:7px;height:7px;border-radius:50%;background:#28c840"></div>' +
          '<span style="font-size:0.45rem;color:#888;margin-left:6px;letter-spacing:0.5px">' + templateName + ' — Dashboard Preview</span>' +
        '</div>' +
        // Toolbar
        '<div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:5px 10px;display:flex;gap:8px;align-items:center">' +
          '<div style="width:55px;height:5px;background:#e5e7eb;border-radius:2px"></div>' +
          '<div style="width:55px;height:5px;background:#e5e7eb;border-radius:2px"></div>' +
          '<div style="width:55px;height:5px;background:#e5e7eb;border-radius:2px"></div>' +
          '<div style="flex:1"></div>' +
          '<div style="width:32px;height:14px;background:' + p[0] + ';border-radius:3px;opacity:0.85;font-size:0.3rem;color:#fff;display:flex;align-items:center;justify-content:center">Refresh</div>' +
          '<div style="width:32px;height:14px;background:' + p[1] + ';border-radius:3px;opacity:0.85;font-size:0.3rem;color:#fff;display:flex;align-items:center;justify-content:center">Export</div>' +
        '</div>' +
        // KPI row
        '<div style="display:flex;gap:6px;padding:10px 10px 5px">' +
          [0,1,2,3].map(kpiCard).join('') +
        '</div>' +
        // Charts row
        '<div style="display:flex;gap:6px;padding:3px 10px 5px">' +
          // Bar chart
          '<div style="flex:2;background:#fff;border-radius:4px;padding:6px 8px;border:1px solid #e5e7eb">' +
            '<div style="font-size:0.32rem;color:#9ca3af;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.4px">Productivity Trend (Weekly Hours)</div>' +
            '<div style="display:flex;align-items:flex-end;gap:2px;height:60px">' + BAR_H.map(bar).join('') + '</div>' +
          '</div>' +
          // Donut chart
          '<div style="flex:1;background:#fff;border-radius:4px;padding:6px 8px;border:1px solid #e5e7eb;display:flex;flex-direction:column;align-items:center">' +
            '<div style="font-size:0.32rem;color:#9ca3af;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.4px;align-self:flex-start">Hours by WBS</div>' +
            '<div style="width:50px;height:50px;border-radius:50%;background:conic-gradient(' +
              p[0] + ' 0% 28%, ' + p[1] + ' 28% 52%, ' + p[2] + ' 52% 68%, ' + p[3] + ' 68% 79%, ' + p[4] + ' 79% 88%, ' + p[5] + ' 88% 100%' +
            ');position:relative;flex-shrink:0">' +
              '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:24px;height:24px;border-radius:50%;background:#fff"></div>' +
            '</div>' +
            '<div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:4px;justify-content:center">' +
              p.slice(0,4).map(function(c,i){ return '<div style="display:flex;align-items:center;gap:2px"><div style="width:5px;height:5px;border-radius:50%;background:'+c+'"></div><div style="font-size:0.26rem;color:#6b7280">WBS '+(i+1)+'</div></div>'; }).join('') +
            '</div>' +
          '</div>' +
        '</div>' +
        // Table
        '<div style="padding:3px 10px 10px">' +
          '<div style="background:#fff;border-radius:4px;border:1px solid #e5e7eb;overflow:hidden">' +
            '<div style="padding:4px 8px;background:#f9fafb;border-bottom:1px solid #e5e7eb;font-size:0.32rem;color:#374151;font-weight:600">Top Contributors</div>' +
            '<div style="display:flex;padding:3px 8px;background:#f9fafb;border-bottom:1px solid #e5e7eb">' +
              '<div style="flex:2;font-size:0.28rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.3px">Employee</div>' +
              '<div style="flex:1;font-size:0.28rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.3px">Hours</div>' +
              '<div style="flex:1;font-size:0.28rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.3px">Status</div>' +
            '</div>' +
            TABLE_ROWS.map(tableRow).join('') +
          '</div>' +
        '</div>' +
      '</div>';
  }

  // Chart type toggle buttons
  document.querySelectorAll('.chart-type-toggle').forEach(function(label) {
    label.addEventListener('click', function(e) {
      e.preventDefault();
      var cb = label.querySelector('.chart-type-cb');
      cb.checked = !cb.checked;
      label.style.background = cb.checked ? '#333' : '#fff';
      label.style.color = cb.checked ? '#fff' : '';
    });
  });

  // Update hex label when picker changes
  document.querySelectorAll('.palette-color').forEach(function(p) {
    p.addEventListener('input', function() {
      var hexEl = p.closest('.color-picker-cell').querySelector('.color-hex');
      if (hexEl) hexEl.textContent = p.value;
      buildMiniDash();
    });
  });

  fontSelect.addEventListener('change', buildMiniDash);
  accentInput.addEventListener('input', buildMiniDash);
  document.querySelector('input[name="name"]').addEventListener('input', buildMiniDash);

  // Initial render
  buildMiniDash();
})();
</script>
