<%
  // Defensive defaults
  var threads = (typeof threads !== 'undefined' && threads) ? threads : [];
  var workspaceContext = (typeof workspaceContext !== 'undefined' && workspaceContext) ? workspaceContext : [];
  var starterPrompts = (typeof starterPrompts !== 'undefined' && starterPrompts) ? starterPrompts : [];
%>

<style>
  .ask-ai-shell {
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    gap: 14px;
    height: calc(100vh - 110px);
    min-height: 520px;
    padding: 14px 18px 0;
  }
  @media (max-width: 1100px) { .ask-ai-shell { grid-template-columns: 240px 1fr; } .ask-ai-right { display: none; } }
  @media (max-width: 760px)  { .ask-ai-shell { grid-template-columns: 1fr; } .ask-ai-left { display: none; } }
  .ask-pane {
    background: #ffffff;
    border: 1px solid #ECEEF2;
    border-radius: 12px;
    overflow: hidden;
    display: flex; flex-direction: column;
  }
  .ask-pane-header {
    padding: 12px 14px; border-bottom: 1px solid #ECEEF2;
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    font-weight: 600; font-size: 13px; color: #111827;
  }
  .ask-pane-body { flex: 1; overflow: auto; padding: 8px; }
  .ask-pane-footer { padding: 10px 12px; border-top: 1px solid #ECEEF2; background: #fafbff; }

  /* Sessions list */
  .session-item {
    display: flex; align-items: center; justify-content: space-between; gap: 6px;
    padding: 8px 10px; border-radius: 8px; cursor: pointer;
    font-size: 13px; color: #1f2937; line-height: 1.3;
  }
  .session-item:hover { background: #f4f6fb; }
  .session-item.active { background: #eef2ff; color: #3730a3; font-weight: 600; }
  .session-item .session-title { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .session-item .session-actions { opacity: 0; transition: opacity .15s; display: flex; gap: 4px; }
  .session-item:hover .session-actions { opacity: 1; }
  .session-actions button { background: none; border: 0; color: #6b7280; padding: 2px 4px; font-size: 12px; cursor: pointer; }
  .session-actions button:hover { color: #ef4444; }

  /* Chat */
  .ask-center { display: flex; flex-direction: column; }
  .chat-thread { display: flex; flex-direction: column; gap: 14px; padding: 18px 22px; }
  .msg { display: flex; gap: 10px; align-items: flex-start; }
  .msg .avatar {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px; font-weight: 600;
  }
  .msg.user .avatar { background: #1f2937; }
  .msg.assistant .avatar { background: linear-gradient(135deg,#6366f1,#8b5cf6); }
  .msg .bubble {
    flex: 1; min-width: 0; padding: 10px 14px; border-radius: 10px;
    font-size: 14px; line-height: 1.55; color: #111827;
  }
  .msg.user .bubble { background: #f9fafb; }
  .msg.assistant .bubble { background: #f5f3ff; }
  .msg .bubble pre { background: #0f172a; color: #e2e8f0; padding: 10px 12px; border-radius: 8px; overflow: auto; font-size: 12.5px; }
  .msg .bubble code { background: rgba(99,102,241,0.12); color: #4338ca; padding: 1px 5px; border-radius: 4px; font-size: 12.5px; }
  .msg .bubble p { margin: 0 0 8px; }
  .msg .bubble p:last-child { margin: 0; }
  .msg .bubble ul, .msg .bubble ol { margin: 4px 0 8px 20px; }
  .msg .meta { font-size: 11px; color: #9ca3af; margin-top: 4px; }
  .msg .action-btn {
    display: inline-flex; gap: 6px; align-items: center;
    margin-top: 8px; padding: 6px 12px; border-radius: 8px;
    background: #fff; border: 1px solid #c7d2fe; color: #4338ca;
    font-size: 12.5px; font-weight: 600; text-decoration: none;
  }
  .msg .action-btn:hover { background: #eef2ff; }

  /* Composer */
  .composer { padding: 12px 18px 18px; border-top: 1px solid #ECEEF2; background: #fff; }
  .composer-box { display: flex; gap: 8px; align-items: flex-end; background: #f9fafb; border: 1px solid #d1d5db; border-radius: 12px; padding: 8px 10px; }
  .composer-box textarea {
    flex: 1; resize: none; border: 0; outline: 0; background: transparent;
    font-size: 14px; line-height: 1.5; max-height: 180px; padding: 6px 4px;
  }
  .composer-box button.send {
    background: linear-gradient(135deg,#6366f1,#8b5cf6); color: #fff; border: 0;
    width: 36px; height: 36px; border-radius: 9px; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .composer-box button.send[disabled] { opacity: .5; cursor: not-allowed; }
  .composer .hint { color: #6b7280; font-size: 11px; margin-top: 6px; }

  /* Right rail */
  .ctx-section { padding: 10px 14px; border-bottom: 1px solid #ECEEF2; font-size: 13px; }
  .ctx-section h6 { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: #9ca3af; margin: 0 0 8px; font-weight: 600; }
  .ctx-source { padding: 8px 10px; border: 1px solid #ECEEF2; border-radius: 8px; margin-bottom: 6px; }
  .ctx-source .src-name { font-weight: 600; color: #1f2937; font-size: 13px; }
  .ctx-source .src-meta { color: #6b7280; font-size: 11px; }
  .starter-chip {
    display: inline-block; margin: 0 4px 6px 0;
    padding: 6px 10px; border-radius: 999px;
    background: #f4f6fb; color: #374151; font-size: 12px; cursor: pointer;
    border: 1px solid transparent;
  }
  .starter-chip:hover { border-color: #c7d2fe; background: #eef2ff; color: #3730a3; }

  .empty-state { text-align: center; color: #6b7280; padding: 36px 24px; }
  .empty-state i { font-size: 38px; opacity: 0.3; }
  .empty-state h3 { margin-top: 12px; color: #111827; font-size: 18px; }
  .empty-state p { font-size: 13px; margin-top: 4px; }

  .typing-dots span {
    display: inline-block; width: 6px; height: 6px; margin: 0 2px;
    background: #9ca3af; border-radius: 50%;
    animation: typing 1.2s infinite ease-in-out;
  }
  .typing-dots span:nth-child(2) { animation-delay: .15s; }
  .typing-dots span:nth-child(3) { animation-delay: .3s; }
  @keyframes typing { 0%, 80%, 100% { transform: scale(0.8); opacity: .4; } 40% { transform: scale(1.1); opacity: 1; } }
</style>

<div class="ask-ai-shell">
  <!-- LEFT: sessions -->
  <div class="ask-pane ask-pane-left ask-pane">
    <div class="ask-pane-header">
      <span><i class="bi bi-chat-square-dots"></i> Conversations</span>
      <button class="btn btn-sm btn-primary" id="newThreadBtn" title="New conversation"><i class="bi bi-plus-lg"></i></button>
    </div>
    <div class="ask-pane-body" id="sessionList">
      <% if (!threads.length) { %>
        <div class="empty-state" style="padding:18px 14px;">
          <p style="font-size:12.5px;">No conversations yet. Start one with the <strong>+</strong> button or pick a starter prompt on the right.</p>
        </div>
      <% } else { %>
        <% threads.forEach(function(t) { %>
          <div class="session-item" data-thread-id="<%= t.id %>">
            <span class="session-title" title="<%= t.title %>"><%= t.title %></span>
            <span class="session-actions">
              <button class="rename-btn" title="Rename"><i class="bi bi-pencil"></i></button>
              <button class="delete-btn" title="Delete"><i class="bi bi-trash"></i></button>
            </span>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- CENTER: chat -->
  <div class="ask-pane ask-center">
    <div class="ask-pane-header">
      <span id="threadHeading"><i class="bi bi-stars"></i> Ask AI</span>
      <span class="text-muted" style="font-weight:400; font-size:12px;" id="threadSubtitle">Talk to your data</span>
    </div>
    <div class="ask-pane-body" id="chatThread" style="padding: 0;">
      <div class="empty-state" id="emptyState">
        <i class="bi bi-stars"></i>
        <h3>Ask AI — your data analyst</h3>
        <p>Ask questions, request KPIs, or have it design dashboards for your data.</p>
        <% if (starterPrompts && starterPrompts.length) { %>
          <div style="max-width: 520px; margin: 14px auto 0;">
            <% starterPrompts.forEach(function(p) { %>
              <span class="starter-chip" data-prompt="<%= p %>"><%= p %></span>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
    <div class="composer">
      <div class="composer-box">
        <textarea id="composerInput" rows="1" placeholder="Ask anything about your data..." onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();window.AskAI.send();}"></textarea>
        <button class="send" id="sendBtn" onclick="window.AskAI.send()" title="Send (Enter)">
          <i class="bi bi-send-fill"></i>
        </button>
      </div>
      <div class="hint">Press <kbd>Enter</kbd> to send · <kbd>Shift</kbd>+<kbd>Enter</kbd> for newline</div>
    </div>
  </div>

  <!-- RIGHT: context / suggestions -->
  <div class="ask-pane ask-pane-right">
    <div class="ask-pane-header"><span><i class="bi bi-lightbulb"></i> Workspace context</span></div>
    <div class="ask-pane-body" style="padding: 0;">
      <div class="ctx-section">
        <h6>Try asking</h6>
        <div>
          <% (starterPrompts || []).forEach(function(p) { %>
            <span class="starter-chip" data-prompt="<%= p %>"><%= p %></span>
          <% }); %>
        </div>
      </div>
      <div class="ctx-section">
        <h6>Connected sources (<%= workspaceContext.length %>)</h6>
        <% if (!workspaceContext.length) { %>
          <p class="text-muted" style="font-size:12px; margin:0;">No data sources yet. <a href="/sources">Connect one →</a></p>
        <% } else { %>
          <% workspaceContext.forEach(function(s) { %>
            <div class="ctx-source">
              <div class="src-name"><%= s.name %></div>
              <div class="src-meta">
                <%= s.type %> · <%= s.datasets.length %> dataset<%= s.datasets.length === 1 ? '' : 's' %>
                <% if (s.datasets[0]) { %> · <%= s.datasets[0].columns.length %> cols<% } %>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
      <div class="ctx-section" style="border-bottom: 0;">
        <h6>Tips</h6>
        <ul class="text-muted" style="font-size:12px; padding-left:18px; margin:0;">
          <li>Be specific — mention dataset name &amp; metric.</li>
          <li>For charts use words like "show", "top", "trend", "compare".</li>
          <li>For dashboards say "build", "create", "executive", "HR".</li>
          <li>Follow up with "now compare by region" — context is remembered.</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<script src="/js/ask-ai.js"></script>
