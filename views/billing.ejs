<div class="container py-4" style="max-width: 980px;">

    <header style="margin-bottom: 28px;">
      <h1 style="font-size: 1.75rem; font-weight: 700; color: var(--ink, #1A1F36); margin: 0 0 6px;">Billing & Subscription</h1>
      <p style="color: var(--muted, #6B7280); margin: 0;">Manage your plan, view usage, and update payment methods.</p>
    </header>

    <!-- Current Plan card -->
    <div style="background: #fff; border: 1px solid #E6E8F0; border-radius: 12px; padding: 24px; margin-bottom: 20px;">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; flex-wrap: wrap;">
        <div>
          <div style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; color: #6B7280; margin-bottom: 8px;">Current Plan</div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <h2 style="font-size: 1.5rem; font-weight: 700; margin: 0;"><%= plan.name || plan.id %></h2>
            <% if (workspace && workspace.subscriptionStatus === 'trialing' && trialDaysLeft != null) { %>
              <span style="background: #FEF3C7; color: #92400E; font-size: 0.75rem; font-weight: 600; padding: 4px 10px; border-radius: 999px;">
                Trial — <%= trialDaysLeft %> day<%= trialDaysLeft === 1 ? '' : 's' %> left
              </span>
            <% } else if (workspace && workspace.subscriptionStatus) { %>
              <span style="background: #DCFCE7; color: #166534; font-size: 0.75rem; font-weight: 600; padding: 4px 10px; border-radius: 999px;">
                <%= workspace.subscriptionStatus.charAt(0).toUpperCase() + workspace.subscriptionStatus.slice(1) %>
              </span>
            <% } %>
          </div>
          <% if (workspace) { %>
            <div style="color: #6B7280; font-size: 0.9rem; margin-top: 8px;">Workspace: <strong><%= workspace.name %></strong></div>
          <% } %>
        </div>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          <a href="/pricing" class="btn" style="background: var(--primary, #3366FF); color: #fff; padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem;">
            <i class="bi bi-arrow-up-circle"></i> Upgrade Plan
          </a>
        </div>
      </div>
    </div>

    <!-- Usage card -->
    <div style="background: #fff; border: 1px solid #E6E8F0; border-radius: 12px; padding: 24px; margin-bottom: 20px;">
      <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 16px;">Plan Limits</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
        <% var fmt = function(v){ return (v === Infinity || v === null || typeof v === 'undefined') ? 'Unlimited' : String(v); }; %>
        <div>
          <div style="font-size: 0.78rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em;">Dashboards</div>
          <div style="font-size: 1.5rem; font-weight: 700; margin-top: 4px;"><%= fmt(limits.dashboards) %></div>
        </div>
        <div>
          <div style="font-size: 0.78rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em;">Data Sources</div>
          <div style="font-size: 1.5rem; font-weight: 700; margin-top: 4px;"><%= fmt(limits.dataSources) %></div>
        </div>
        <div>
          <div style="font-size: 0.78rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em;">AI Generations / month</div>
          <div style="font-size: 1.5rem; font-weight: 700; margin-top: 4px;"><%= fmt(limits.aiGenerationsPerMonth) %></div>
        </div>
      </div>
    </div>

    <!-- Payment methods placeholder -->
    <div style="background: #fff; border: 1px solid #E6E8F0; border-radius: 12px; padding: 24px;">
      <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 8px;">Payment Methods</h3>
      <p style="color: #6B7280; margin: 0 0 16px; font-size: 0.9rem;">
        Card, GCash, Maya, and bank transfer support is coming soon. Contact
        <a href="mailto:billing@liknaya.com">billing@liknaya.com</a> to upgrade in the meantime.
      </p>
      <div style="background: #F6F7FB; border: 1px dashed #C4C7D2; border-radius: 8px; padding: 24px; text-align: center; color: #6B7280;">
        <i class="bi bi-credit-card" style="font-size: 1.5rem;"></i>
        <div style="margin-top: 8px;">No payment method on file</div>
      </div>
    </div>

</div>
