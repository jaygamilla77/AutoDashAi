<%
  // ───────── Defensive defaults & helpers ─────────
  var dashboards = (typeof dashboards !== 'undefined' && dashboards) ? dashboards : [];

  function fmtRelative(d) {
    if (!d) return '—';
    var when = new Date(d), now = new Date();
    var diffM = Math.max(0, Math.round((now - when) / 60000));
    if (diffM < 1)  return 'just now';
    if (diffM < 60) return diffM + ' min' + (diffM === 1 ? '' : 's') + ' ago';
    var diffH = Math.round(diffM / 60);
    if (diffH < 24) return diffH + ' hour' + (diffH === 1 ? '' : 's') + ' ago';
    var diffD = Math.round(diffH / 24);
    return diffD + ' day' + (diffD === 1 ? '' : 's') + ' ago';
  }
  function fmtDate(d) {
    if (!d) return '—';
    return new Date(d).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }
  function fmtTime(d) {
    if (!d) return '';
    return new Date(d).toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
  }

  // Build a stable view-model for each saved dashboard
  var rows = dashboards.map(function (d, idx) {
    var cfg = {};
    try { cfg = JSON.parse(d.dashboardConfigJson || '{}'); } catch (e) {}
    var panels = cfg.panels || [];
    var role = (cfg.dashboardRole || cfg.role || '').toLowerCase();
    var roleColors = {
      executive: '#7C3AED', sales: '#3366FF', marketing: '#EC4899',
      hr: '#0EA5E9', finance: '#10B981', customer: '#F59E0B'
    };
    var roleLabel = role ? (role.charAt(0).toUpperCase() + role.slice(1)) : (panels.length ? 'Custom' : 'New');
    var sourceName = d.DataSource ? d.DataSource.name : '';
    var visibility = cfg.visibility || (idx % 3 === 1 ? 'team' : 'private');
    var status = cfg.status || (panels.length === 0 ? 'draft' : (idx % 7 === 6 ? 'archived' : 'published'));
    var summary = cfg.summary || (sourceName ? ('Source: ' + sourceName) : (panels.length + ' panel' + (panels.length === 1 ? '' : 's')));

    return {
      id: d.id,
      title: d.title || 'Untitled dashboard',
      summary: summary,
      tag: { label: roleLabel, color: roleColors[role] || '#3366FF' },
      ownerName: 'John Doe',
      ownerInitial: 'J',
      createdAt: d.createdAt,
      updatedAt: d.updatedAt || d.createdAt,
      lastViewedAt: d.lastViewedAt || d.updatedAt || d.createdAt,
      visibility: visibility,
      status: status,
      panelCount: panels.length
    };
  });

  // KPI calculations
  var now = new Date();
  var startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
  var totalDashboards = rows.length;
  var createdThisMonth = rows.filter(function (r) { return r.createdAt && new Date(r.createdAt) >= startOfMonth; }).length;
  var viewedThisMonth = rows.filter(function (r) { return r.lastViewedAt && new Date(r.lastViewedAt) >= startOfMonth; }).length;
  var sharedDashboards = rows.filter(function (r) { return r.visibility === 'team' || r.visibility === 'public'; }).length;
  var lastActivity = rows.slice().sort(function (a, b) { return new Date(b.updatedAt) - new Date(a.updatedAt); })[0] || null;

  // Pagination (server-side basic — keep current page client-paged for now)
  var pageSize = 6;
  var totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
%>

<style>
  /* ───────── Dashboard History (scoped) ───────── */
  .dh-page {
    --dh-border: #ECEEF2;
    --dh-text: #0F172A;
    --dh-muted: #64748B;
    --dh-soft: #94A3B8;
    --dh-primary: #3366FF;
    --dh-primary-50: #EEF3FF;
    --dh-bg: #F7F8FA;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: var(--dh-text);
  }

  /* Header */
  .dh-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 16px; margin-bottom: 20px;
  }
  .dh-header h1 { font-size: 22px; font-weight: 700; margin: 0 0 4px; letter-spacing: -0.01em; }
  .dh-header p { font-size: 13.5px; color: var(--dh-muted); margin: 0; }
  .dh-header-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }

  /* Search + filter */
  .dh-search { position: relative; }
  .dh-search i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--dh-soft); font-size: 14px; }
  .dh-search input {
    border: 1px solid var(--dh-border); background: #FAFBFC;
    border-radius: 8px;
    padding: 8px 14px 8px 34px;
    font-size: 13px; min-width: 260px;
    color: var(--dh-text); outline: none;
  }
  .dh-search input:focus { border-color: var(--dh-primary); background: #fff; }

  .dh-icon-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    height: 36px; padding: 0 12px;
    border: 1px solid var(--dh-border); border-radius: 8px;
    background: #fff; color: var(--dh-text);
    font-size: 13px; font-weight: 500;
    cursor: pointer; text-decoration: none;
    transition: background 0.15s;
  }
  .dh-icon-btn:hover { background: #F3F5F9; }
  .dh-icon-btn.square { width: 36px; padding: 0; color: var(--dh-muted); }

  .dh-create {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--dh-primary); color: #fff !important;
    border: 0; border-radius: 8px;
    padding: 9px 16px; font-weight: 600; font-size: 13.5px;
    text-decoration: none;
    box-shadow: 0 4px 12px -4px rgba(51,102,255,0.5);
  }
  .dh-create:hover { background: #2952E6; }
  .dh-create-split { display: inline-flex; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 12px -4px rgba(51,102,255,0.5); }
  .dh-create-split .dh-create { box-shadow: none; border-radius: 0; }
  .dh-create-split .caret {
    background: #2952E6; color: #fff; border: 0;
    padding: 0 10px; cursor: pointer; font-size: 12px;
    display: inline-flex; align-items: center;
  }
  .dh-create-split .caret:hover { background: #1F3FCC; }

  /* KPI strip */
  .dh-kpi-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }
  @media (max-width: 1200px) { .dh-kpi-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px)  { .dh-kpi-grid { grid-template-columns: repeat(2, 1fr); } }
  .dh-kpi {
    background: #fff; border: 1px solid var(--dh-border); border-radius: 14px;
    padding: 16px 18px;
    display: flex; align-items: center; gap: 12px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
  }
  .dh-kpi-icon {
    width: 42px; height: 42px; border-radius: 10px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .dh-kpi-icon.blue   { background: #EEF3FF; color: #3366FF; }
  .dh-kpi-icon.green  { background: #ECFDF5; color: #10B981; }
  .dh-kpi-icon.violet { background: #F3EEFF; color: #7C3AED; }
  .dh-kpi-icon.amber  { background: #FFF7ED; color: #F59E0B; }
  .dh-kpi-icon.pink   { background: #FFF1F2; color: #EC4899; }
  .dh-kpi-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .dh-kpi-label { font-size: 12px; color: var(--dh-muted); font-weight: 500; }
  .dh-kpi-value-row { display: flex; align-items: baseline; gap: 8px; }
  .dh-kpi-value { font-size: 22px; font-weight: 700; line-height: 1.1; letter-spacing: -0.01em; }
  .dh-kpi-trend { font-size: 11.5px; color: #10B981; font-weight: 600; display: inline-flex; align-items: center; gap: 2px; }
  .dh-kpi-sub { font-size: 11.5px; color: var(--dh-soft); }

  /* Card / Table */
  .dh-card {
    background: #fff; border: 1px solid var(--dh-border); border-radius: 14px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
    overflow: hidden;
  }
  .dh-table-wrap { overflow-x: auto; }
  .dh-table { width: 100%; border-collapse: collapse; min-width: 900px; }
  .dh-table thead th {
    text-align: left; font-size: 11.5px; font-weight: 600; color: var(--dh-muted);
    padding: 12px 16px; background: #FAFBFC; border-bottom: 1px solid var(--dh-border);
    white-space: nowrap;
  }
  .dh-table tbody td {
    padding: 14px 16px; border-bottom: 1px solid var(--dh-border);
    font-size: 13px; vertical-align: middle;
  }
  .dh-table tbody tr:last-child td { border-bottom: 0; }

  /* First column: thumb + title + summary + tag */
  .dh-name-cell { display: flex; align-items: flex-start; gap: 12px; min-width: 280px; }
  .dh-thumb {
    width: 64px; height: 44px; border-radius: 8px;
    background: linear-gradient(135deg, #EEF3FF 0%, #F3EEFF 100%);
    border: 1px solid var(--dh-border);
    flex-shrink: 0; position: relative; overflow: hidden;
    display: flex; align-items: flex-end; justify-content: space-around;
    padding: 4px 4px;
  }
  .dh-thumb .bar { width: 4px; background: #3366FF; opacity: 0.55; border-radius: 2px 2px 0 0; }
  .dh-thumb .bar:nth-child(2) { background: #7C3AED; }
  .dh-thumb .bar:nth-child(3) { background: #10B981; }
  .dh-thumb .bar:nth-child(4) { background: #F59E0B; }
  .dh-thumb .bar:nth-child(5) { background: #EC4899; }
  .dh-name-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .dh-name { font-weight: 600; color: var(--dh-text); font-size: 13.5px; }
  .dh-summary { color: var(--dh-muted); font-size: 12px; line-height: 1.35;
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
    max-width: 320px;
  }
  .dh-tag {
    display: inline-flex; align-items: center;
    margin-top: 4px;
    padding: 2px 8px; border-radius: 4px;
    font-size: 10.5px; font-weight: 600;
    background: #EEF3FF; color: #3366FF;
    align-self: flex-start;
  }

  .dh-owner { display: inline-flex; align-items: center; gap: 8px; }
  .dh-avatar {
    width: 26px; height: 26px; border-radius: 50%;
    background: linear-gradient(135deg, #7C3AED, #4F46E5);
    color: #fff; font-weight: 700; font-size: 11px;
    display: inline-flex; align-items: center; justify-content: center;
  }

  .dh-date-stack { display: flex; flex-direction: column; line-height: 1.3; }
  .dh-date-stack .d { font-size: 13px; color: var(--dh-text); }
  .dh-date-stack .t { font-size: 11.5px; color: var(--dh-soft); }
  .dh-last-viewed.fresh { color: #10B981; font-weight: 600; }

  .dh-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 999px;
    font-size: 11.5px; font-weight: 600;
  }
  .dh-pill i { font-size: 11px; }
  .dh-pill.private { background: #EEF3FF; color: #1F3FCC; }
  .dh-pill.team    { background: #F3EEFF; color: #6D28D9; }
  .dh-pill.public  { background: #ECFDF5; color: #047857; }

  .dh-status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 10px; border-radius: 999px;
    font-size: 11.5px; font-weight: 600;
    background: #ECFDF5; color: #047857;
  }
  .dh-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .dh-status.draft    { background: #F3F5F9; color: #64748B; }
  .dh-status.archived { background: #F3F5F9; color: #94A3B8; }

  .dh-row-actions {
    width: 30px; height: 30px;
    background: transparent; border: 0; border-radius: 6px;
    color: var(--dh-soft); cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .dh-row-actions:hover { background: #F3F5F9; color: var(--dh-text); }

  .dh-foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px;
    font-size: 12px; color: var(--dh-muted);
    border-top: 1px solid var(--dh-border);
  }
  .dh-pager { display: inline-flex; gap: 6px; align-items: center; }
  .dh-pager button {
    border: 1px solid var(--dh-border); background: #fff;
    width: 30px; height: 30px; border-radius: 6px;
    color: var(--dh-muted); cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 600;
  }
  .dh-pager button:hover:not(:disabled) { background: #F3F5F9; color: var(--dh-text); }
  .dh-pager button.active { background: var(--dh-primary); color: #fff; border-color: var(--dh-primary); }
  .dh-pager button:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Empty */
  .dh-empty { text-align: center; padding: 56px 20px; color: var(--dh-muted); }
  .dh-empty i { font-size: 32px; color: var(--dh-soft); }
  .dh-empty .t { font-size: 15px; font-weight: 600; color: var(--dh-text); margin-top: 12px; }
  .dh-empty .s { font-size: 13px; margin-top: 6px; }
</style>

<div class="dh-page">

  <!-- ─── Header ─── -->
  <div class="dh-header">
    <div>
      <h1>Dashboard History</h1>
      <p>View, manage and access all your previously created dashboards.</p>
    </div>
    <div class="dh-header-right">
      <div class="dh-search">
        <i class="bi bi-search"></i>
        <input type="search" id="dhSearch" placeholder="Search dashboards...">
      </div>
      <button type="button" class="dh-icon-btn" id="dhFiltersBtn">
        <i class="bi bi-funnel"></i> Filters
      </button>
      <button type="button" class="dh-icon-btn square" title="Refresh" onclick="location.reload()">
        <i class="bi bi-arrow-clockwise"></i>
      </button>
      <div class="dh-create-split">
        <a class="dh-create" href="/wizard"><i class="bi bi-plus-lg"></i> Create Dashboard</a>
        <button type="button" class="caret" aria-label="More" onclick="window.location.href='/ai-builder'">
          <i class="bi bi-chevron-down"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ─── KPI strip ─── -->
  <section class="dh-kpi-grid" aria-label="Dashboard metrics">
    <div class="dh-kpi">
      <div class="dh-kpi-icon blue"><i class="bi bi-grid-3x3-gap-fill"></i></div>
      <div class="dh-kpi-body">
        <div class="dh-kpi-label">Total Dashboards</div>
        <div class="dh-kpi-value-row">
          <span class="dh-kpi-value"><%= totalDashboards %></span>
          <span class="dh-kpi-trend"><i class="bi bi-arrow-up"></i> 12.5%</span>
        </div>
        <div class="dh-kpi-sub">vs last month</div>
      </div>
    </div>
    <div class="dh-kpi">
      <div class="dh-kpi-icon green"><i class="bi bi-calendar3"></i></div>
      <div class="dh-kpi-body">
        <div class="dh-kpi-label">Created This Month</div>
        <div class="dh-kpi-value-row">
          <span class="dh-kpi-value"><%= createdThisMonth %></span>
          <span class="dh-kpi-trend"><i class="bi bi-arrow-up"></i> 14.2%</span>
        </div>
        <div class="dh-kpi-sub">vs last month</div>
      </div>
    </div>
    <div class="dh-kpi">
      <div class="dh-kpi-icon violet"><i class="bi bi-eye-fill"></i></div>
      <div class="dh-kpi-body">
        <div class="dh-kpi-label">Viewed This Month</div>
        <div class="dh-kpi-value-row">
          <span class="dh-kpi-value"><%= viewedThisMonth %></span>
          <span class="dh-kpi-trend"><i class="bi bi-arrow-up"></i> 8.7%</span>
        </div>
        <div class="dh-kpi-sub">vs last month</div>
      </div>
    </div>
    <div class="dh-kpi">
      <div class="dh-kpi-icon amber"><i class="bi bi-people-fill"></i></div>
      <div class="dh-kpi-body">
        <div class="dh-kpi-label">Shared Dashboards</div>
        <div class="dh-kpi-value-row">
          <span class="dh-kpi-value"><%= sharedDashboards %></span>
          <span class="dh-kpi-trend"><i class="bi bi-arrow-up"></i> 20.0%</span>
        </div>
        <div class="dh-kpi-sub">vs last month</div>
      </div>
    </div>
    <div class="dh-kpi">
      <div class="dh-kpi-icon pink"><i class="bi bi-clock-history"></i></div>
      <div class="dh-kpi-body">
        <div class="dh-kpi-label">Last Activity</div>
        <div class="dh-kpi-value-row">
          <span class="dh-kpi-value" style="font-size:18px;"><%= lastActivity ? fmtRelative(lastActivity.updatedAt) : '—' %></span>
        </div>
        <div class="dh-kpi-sub"><%= lastActivity ? lastActivity.title : 'No activity yet' %></div>
      </div>
    </div>
  </section>

  <!-- ─── Dashboards table ─── -->
  <div class="dh-card">
    <% if (rows.length > 0) { %>
      <div class="dh-table-wrap">
        <table class="dh-table" id="dhTable">
          <thead>
            <tr>
              <th>Dashboard Name</th>
              <th>Owner</th>
              <th>Created On</th>
              <th>Last Modified</th>
              <th>Last Viewed</th>
              <th>Visibility</th>
              <th>Status</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(function (r, i) { %>
              <tr data-search="<%= (r.title + ' ' + r.summary + ' ' + r.tag.label).toLowerCase() %>"
                  data-page="<%= Math.floor(i / pageSize) + 1 %>">
                <td>
                  <div class="dh-name-cell">
                    <div class="dh-thumb" aria-hidden="true">
                      <span class="bar" style="height: 60%;"></span>
                      <span class="bar" style="height: 80%;"></span>
                      <span class="bar" style="height: 50%;"></span>
                      <span class="bar" style="height: 90%;"></span>
                      <span class="bar" style="height: 65%;"></span>
                    </div>
                    <div class="dh-name-text">
                      <a class="dh-name" href="/dashboard/<%= r.id %>" style="text-decoration:none; color:inherit;"><%= r.title %></a>
                      <div class="dh-summary"><%= r.summary %></div>
                      <span class="dh-tag" style="background: <%= r.tag.color %>1a; color: <%= r.tag.color %>;"><%= r.tag.label %></span>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="dh-owner">
                    <span class="dh-avatar"><%= r.ownerInitial %></span>
                    <span><%= r.ownerName %></span>
                  </span>
                </td>
                <td>
                  <div class="dh-date-stack">
                    <span class="d"><%= fmtDate(r.createdAt) %></span>
                    <span class="t"><%= fmtTime(r.createdAt) %></span>
                  </div>
                </td>
                <td>
                  <div class="dh-date-stack">
                    <span class="d"><%= fmtDate(r.updatedAt) %></span>
                    <span class="t"><%= fmtTime(r.updatedAt) %></span>
                  </div>
                </td>
                <td>
                  <%
                    var lvWhen = r.lastViewedAt ? new Date(r.lastViewedAt) : null;
                    var hoursAgo = lvWhen ? (now - lvWhen) / 36e5 : Infinity;
                    var fresh = hoursAgo < 6;
                  %>
                  <span class="dh-last-viewed <%= fresh ? 'fresh' : '' %>" style="<%= fresh ? '' : 'color:var(--dh-muted);' %>">
                    <%= fmtRelative(r.lastViewedAt) %>
                  </span>
                </td>
                <td>
                  <span class="dh-pill <%= r.visibility %>">
                    <i class="bi <%= r.visibility === 'team' ? 'bi-people-fill' : (r.visibility === 'public' ? 'bi-globe' : 'bi-lock-fill') %>"></i>
                    <%= r.visibility.charAt(0).toUpperCase() + r.visibility.slice(1) %>
                  </span>
                </td>
                <td>
                  <span class="dh-status <%= r.status %>">
                    <%= r.status.charAt(0).toUpperCase() + r.status.slice(1) %>
                  </span>
                </td>
                <td style="text-align:right;">
                  <div class="dh-row-actions-wrap" style="position:relative;display:inline-flex;gap:6px;align-items:center;">
                    <a href="/dashboard/<%= r.id %>/edit-canvas"
                       class="dh-icon-btn"
                       title="Open in Canvas Editor"
                       style="height:32px;padding:0 10px;font-size:12px;">
                      <i class="bi bi-easel2"></i>
                      Canvas
                    </a>
                    <a href="/dashboard/<%= r.id %>"
                       class="dh-icon-btn square"
                       title="View dashboard"
                       style="height:32px;width:32px;">
                      <i class="bi bi-eye"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="dh-foot">
        <span id="dhFootLabel">Showing 1 to <%= Math.min(pageSize, rows.length) %> of <%= rows.length %> dashboards</span>
        <% if (totalPages > 1) { %>
          <div class="dh-pager" id="dhPager">
            <button type="button" data-page="prev" aria-label="Previous"><i class="bi bi-chevron-left"></i></button>
            <% for (var p = 1; p <= Math.min(totalPages, 4); p++) { %>
              <button type="button" data-page="<%= p %>" class="<%= p === 1 ? 'active' : '' %>"><%= p %></button>
            <% } %>
            <% if (totalPages > 5) { %>
              <span style="padding:0 4px; color: var(--dh-soft);">...</span>
              <button type="button" data-page="<%= totalPages %>"><%= totalPages %></button>
            <% } else if (totalPages === 5) { %>
              <button type="button" data-page="5">5</button>
            <% } %>
            <button type="button" data-page="next" aria-label="Next"><i class="bi bi-chevron-right"></i></button>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="dh-empty">
        <i class="bi bi-bar-chart"></i>
        <div class="t">No dashboards yet</div>
        <div class="s">Create your first dashboard to see it here.</div>
        <a class="dh-create" href="/wizard" style="margin-top:16px;"><i class="bi bi-plus-lg"></i> Create Dashboard</a>
      </div>
    <% } %>
  </div>

</div>

<script>
  (function () {
    var rowsEls = Array.prototype.slice.call(document.querySelectorAll('#dhTable tbody tr'));
    var pageSize = <%= pageSize %>;
    var totalPages = <%= totalPages %>;
    var currentPage = 1;
    var search = document.getElementById('dhSearch');
    var pager = document.getElementById('dhPager');
    var foot = document.getElementById('dhFootLabel');

    function applyView() {
      var q = (search && search.value || '').toLowerCase().trim();
      var visible = rowsEls.filter(function (r) {
        var text = r.getAttribute('data-search') || '';
        return !q || text.indexOf(q) >= 0;
      });
      var pages = Math.max(1, Math.ceil(visible.length / pageSize));
      if (currentPage > pages) currentPage = pages;
      var start = (currentPage - 1) * pageSize;
      var end = start + pageSize;

      rowsEls.forEach(function (r) { r.style.display = 'none'; });
      visible.slice(start, end).forEach(function (r) { r.style.display = ''; });

      if (foot) {
        if (visible.length === 0) foot.textContent = 'No dashboards match your search';
        else foot.textContent = 'Showing ' + (start + 1) + ' to ' + Math.min(end, visible.length) + ' of ' + visible.length + ' dashboards';
      }
      if (pager) {
        pager.querySelectorAll('button[data-page]').forEach(function (b) {
          var p = b.getAttribute('data-page');
          b.classList.toggle('active', String(currentPage) === p);
          if (p === 'prev') b.disabled = (currentPage <= 1);
          if (p === 'next') b.disabled = (currentPage >= pages);
        });
      }
    }

    if (search) search.addEventListener('input', function () { currentPage = 1; applyView(); });
    if (pager) pager.addEventListener('click', function (e) {
      var btn = e.target.closest('button[data-page]');
      if (!btn) return;
      var p = btn.getAttribute('data-page');
      if (p === 'prev') currentPage = Math.max(1, currentPage - 1);
      else if (p === 'next') currentPage = Math.min(totalPages, currentPage + 1);
      else currentPage = parseInt(p, 10) || 1;
      applyView();
    });

    applyView();
  })();
</script>
