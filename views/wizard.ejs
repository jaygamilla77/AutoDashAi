<%
  // Wizard data passed from controller
  var allThemes = themes || [];
  var allLayouts = layouts || [];
  var allDashboardTypes = dashboardTypes || [];
  var allDataSources = dataSources || [];
  var allTemplates = templates || [];
%>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Dashboard via Wizard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue: #2563EB;
      --blue-dark: #1D4ED8;
      --blue-soft: #EFF6FF;
      --ink: #0F172A;
      --muted: #64748B;
      --border: #E2E8F0;
      --bg: #F8FAFC;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* â”€â”€ App shell (sidebar + main) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .app-shell { display: flex; min-height: 100vh; }
    .app-sidebar {
      width: 220px;
      background: #fff;
      border-right: 1px solid var(--border);
      padding: 22px 16px;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }
    .app-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 20px;
      text-decoration: none;
      flex-shrink: 0;
    }
    .app-brand-icon {
      width: 38px; height: 38px;
      background: var(--blue);
      color: #fff;
      border-radius: 10px;
      display: grid; place-items: center;
      font-size: 20px;
      box-shadow: 0 8px 24px rgba(37,99,235,.25);
      flex-shrink: 0;
    }
    .app-brand-text { display: flex; flex-direction: column; line-height: 1.05; }
    .app-brand-name { font-weight: 800; font-size: 17px; color: var(--ink); letter-spacing: -.01em; }
    .app-brand-name .ai { color: var(--blue); }
    .app-brand-tag { font-size: 11px; color: var(--muted); font-weight: 500; margin-top: 2px; }

    .app-nav { display: flex; flex-direction: column; gap: 4px; flex: 1; }
    .app-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 8px;
      color: #475569; font-size: 0.92rem; font-weight: 500;
      text-decoration: none;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .app-nav a:hover { background: var(--bg); color: var(--ink); }
    .app-nav a.active { background: var(--blue-soft); color: var(--blue); font-weight: 600; }
    .app-nav a i { font-size: 1rem; }

    .app-foot { display: flex; flex-direction: column; gap: 4px; padding-top: 12px; border-top: 1px solid var(--border); }
    .app-foot a, .app-foot button {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 8px;
      color: #475569; font-size: 0.92rem; font-weight: 500;
      text-decoration: none; background: none; border: 0; cursor: pointer; text-align: left;
      font-family: inherit;
    }
    .app-foot a:hover, .app-foot button:hover { background: var(--bg); color: var(--ink); }

    .app-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }

    /* â”€â”€ Top bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .topbar {
      height: 64px;
      background: #fff;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
    }
    .topbar-left a {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--blue); font-weight: 500; font-size: 0.92rem;
      text-decoration: none;
    }
    .topbar-left a:hover { color: var(--blue-dark); }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .topbar-icon-btn {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid var(--border); background: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      color: var(--muted); cursor: pointer;
      transition: border-color 0.15s ease, color 0.15s ease;
    }
    .topbar-icon-btn:hover { border-color: var(--blue); color: var(--blue); }
    .topbar-user { display: flex; align-items: center; gap: 10px; }
    .topbar-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--blue); color: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.92rem;
    }
    .topbar-user-info { line-height: 1.2; }
    .topbar-user-name { font-weight: 600; font-size: 0.9rem; color: var(--ink); }
    .topbar-user-role { font-size: 0.76rem; color: var(--muted); }

    /* â”€â”€ Wizard card â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .wizard-page { padding: 28px 32px; max-width: 1600px; width: 100%; margin: 0 auto; }
    .wizard-container {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 4px 16px rgba(15,23,42,0.04);
      overflow: hidden;
    }

    .wizard-header {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 16px;
      padding: 24px 28px 20px;
      border-bottom: 1px solid var(--border);
    }
    .wizard-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--ink);
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 4px;
    }
    .wizard-title i { color: var(--blue); font-size: 1.2rem; }
    .wizard-subtitle { font-size: 0.88rem; color: var(--muted); }

    .btn-exit {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 16px; border-radius: 8px;
      background: #fff; color: var(--ink);
      border: 1px solid var(--border);
      font-size: 0.86rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      font-family: inherit;
    }
    .btn-exit:hover { border-color: var(--blue); color: var(--blue); }

    /* â”€â”€ Stepper â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .wizard-stepper {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4px;
      padding: 22px 28px;
      border-bottom: 1px solid var(--border);
      background: #fff;
      overflow-x: auto;
    }
    .stepper-step {
      display: flex; align-items: center; gap: 10px;
      flex: 1; min-width: 0;
      position: relative;
    }
    .stepper-step:not(:last-child)::after {
      content: '';
      flex: 1;
      height: 2px;
      background: var(--border);
      margin: 0 8px;
    }
    .stepper-step.completed:not(:last-child)::after { background: var(--blue); }
    .stepper-circle {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: #F1F5F9;
      color: var(--muted);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 0.85rem; font-weight: 700;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s;
    }
    .stepper-step.active .stepper-circle {
      background: var(--blue); color: #fff;
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }
    .stepper-step.completed .stepper-circle { background: var(--blue); color: #fff; }
    .stepper-label {
      font-size: 0.86rem;
      color: var(--muted);
      font-weight: 500;
      white-space: nowrap;
    }
    .stepper-step.active .stepper-label { color: var(--blue); font-weight: 600; }
    .stepper-step.completed .stepper-label { color: var(--ink); }

    /* â”€â”€ Body â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .wizard-body { padding: 28px; min-height: 360px; }
    .wizard-step { display: none; }
    .wizard-step.active { display: block; }

    .step-title {
      font-size: 1.15rem; font-weight: 700; color: var(--ink);
      margin-bottom: 6px;
      display: flex; align-items: center; gap: 8px;
    }
    .step-title i { color: var(--blue); }
    .step-description {
      font-size: 0.92rem; color: var(--muted);
      margin-bottom: 22px;
    }

    /* â”€â”€ Step 1: Source cards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .source-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 22px;
    }
    .source-option {
      padding: 30px 20px;
      border: 1px solid var(--border);
      border-radius: 12px;
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
      text-align: center;
      background: #fff;
    }
    .source-option:hover {
      border-color: var(--blue);
      box-shadow: 0 6px 18px rgba(37, 99, 235, 0.08);
      transform: translateY(-2px);
    }
    .source-option.selected {
      border-color: var(--blue);
      background: var(--blue-soft);
    }
    .source-icon {
      font-size: 2rem;
      margin-bottom: 12px;
      color: var(--blue);
    }
    .source-label {
      font-size: 0.98rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 4px;
    }
    .source-option .source-hint {
      font-size: 0.78rem;
      color: var(--muted);
    }

    /* â”€â”€ Upload area / DB / API â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .upload-area {
      border: 2px dashed #CBD5E1;
      border-radius: 12px;
      padding: 40px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: var(--bg);
      margin-top: 8px;
    }
    .upload-area:hover, .upload-area.dragover {
      border-color: var(--blue);
      background: var(--blue-soft);
    }
    .upload-icon { font-size: 2.4rem; color: var(--blue); margin-bottom: 12px; }
    .upload-text { font-size: 0.95rem; color: var(--ink); margin-bottom: 6px; }
    .upload-subtext { font-size: 0.82rem; color: var(--muted); }
    #dataFileInput { display: none; }

    .db-form { display: grid; gap: 14px; margin-top: 8px; }
    .form-group { display: flex; flex-direction: column; }
    .form-group label {
      font-size: 0.8rem; font-weight: 600;
      color: #334155; margin-bottom: 6px;
    }
    .form-group input,
    .form-group select,
    .form-control {
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.92rem;
      font-family: inherit;
      background: #fff;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-control:focus {
      outline: none;
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    /* â”€â”€ Step 2: Analysis progress â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .analysis-progress { text-align: center; padding: 50px 20px; }
    .analysis-progress .spinner {
      display: inline-block;
      width: 48px; height: 48px;
      border: 4px solid var(--border);
      border-top-color: var(--blue);
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
      margin-bottom: 18px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .progress-text { font-size: 1rem; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
    .progress-subtext { font-size: 0.86rem; color: var(--muted); }

    .analysis-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 18px;
    }
    .analysis-stat {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 0.88rem;
    }
    .stat-label { color: var(--muted); }
    .stat-value { font-weight: 700; color: var(--ink); font-size: 1rem; }

    /* â”€â”€ Step 3: Recommendations â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .recommendations-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 14px;
      margin-top: 14px;
    }
    .recommendation-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    .recommendation-card:hover { border-color: var(--blue); background: var(--blue-soft); }
    .recommendation-card.selected { border-color: var(--blue); background: var(--blue-soft); }
    .recommendation-icon { font-size: 1.5rem; margin-bottom: 8px; color: var(--blue); }
    .recommendation-title { font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .recommendation-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }

    /* â”€â”€ Step 4: Style â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .style-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
      margin-top: 14px;
    }
    .style-option {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
    }
    .style-option:hover { border-color: var(--blue); box-shadow: 0 6px 16px rgba(15,23,42,0.06); }
    .style-option.selected { border-color: var(--blue); background: var(--blue-soft); }
    .style-name { font-size: 0.95rem; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .style-desc { font-size: 0.82rem; color: var(--muted); }
    .color-preview { display: flex; gap: 6px; margin-top: 10px; }
    .color-swatch { width: 24px; height: 24px; border-radius: 4px; border: 1px solid var(--border); }

    /* â”€â”€ Footer â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .wizard-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 28px;
      border-top: 1px solid var(--border);
      background: #fff;
    }
    .footer-nav { display: flex; gap: 10px; }
    .step-info { font-size: 0.86rem; color: var(--muted); }

    .btn {
      padding: 10px 18px;
      border: 1px solid transparent;
      border-radius: 8px;
      font-size: 0.92rem;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      font-family: inherit;
      transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
      text-decoration: none;
    }
    .btn-primary { background: var(--blue); color: #fff; border-color: var(--blue); }
    .btn-primary:hover { background: var(--blue-dark); border-color: var(--blue-dark); }
    .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }
    .btn-outline { background: #fff; color: var(--blue); border-color: var(--blue); }
    .btn-outline:hover { background: var(--blue-soft); }
    .btn-secondary { background: #F1F5F9; color: #475569; border-color: var(--border); }
    .btn-secondary:hover { background: #E2E8F0; color: var(--ink); }

    button:disabled { opacity: 0.55; cursor: not-allowed; }
    .hidden { display: none; }

    /* â”€â”€ Alerts â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .alert {
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 16px;
      font-size: 0.88rem;
      display: flex; align-items: center; gap: 10px;
    }
    .alert-success { background: #ECFDF5; color: #065F46; border: 1px solid #A7F3D0; }
    .alert-error { background: #FEF2F2; color: #991B1B; border: 1px solid #FECACA; }
    .alert-info { background: var(--blue-soft); color: #1E3A8A; border: 1px solid #BFDBFE; }

    /* â”€â”€ Responsive â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    @media (max-width: 900px) {
      .app-sidebar { width: 70px; padding: 18px 8px; }
      .app-brand-text, .app-nav a span, .app-foot a span, .app-foot button span,
      .app-brand-name, .app-brand-tag { display: none; }
      .app-nav a, .app-foot a, .app-foot button { justify-content: center; }
      .source-options { grid-template-columns: 1fr; }
      .recommendations-grid, .style-grid { grid-template-columns: 1fr; }
      .stepper-label { display: none; }
      .topbar-user-info { display: none; }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <!-- Sidebar -->
    <aside class="app-sidebar">
      <a href="/dashboard" class="app-brand" aria-label="AutoDash AI by Liknaya home">
        <span class="app-brand-icon"><i class="bi bi-bar-chart-line-fill"></i></span>
        <div class="app-brand-text">
          <div class="app-brand-name">AutoDash <span class="ai">AI</span></div>
          <div class="app-brand-tag">by Liknaya</div>
        </div>
      </a>
      <nav class="app-nav" aria-label="Primary">
        <a href="/dashboard"><i class="bi bi-house-fill"></i><span>Home</span></a>
        <a href="/dashboard/history"><i class="bi bi-grid-3x3-gap-fill"></i><span>Dashboards</span></a>
        <a href="/sources"><i class="bi bi-database-fill"></i><span>Sources</span></a>
        <a href="/templates"><i class="bi bi-palette-fill"></i><span>Templates</span></a>
        <a href="/ai-builder" class="active"><i class="bi bi-stars"></i><span>AI</span></a>
      </nav>
      <div class="app-foot">
        <a href="/ai/settings"><i class="bi bi-gear-fill"></i><span>Settings</span></a>
        <button type="button" onclick="autoDashLogout && autoDashLogout()" id="sidebarLogout"><i class="bi bi-box-arrow-right"></i><span>Sign out</span></button>
      </div>
    </aside>

    <!-- Main -->
    <main class="app-main">
      <header class="topbar">
        <div class="topbar-left">
          <a href="/dashboard"><i class="bi bi-arrow-left"></i> Back to Home</a>
        </div>
        <div class="topbar-right">
          <button type="button" class="topbar-icon-btn" aria-label="Help" title="Help"><i class="bi bi-question-circle"></i></button>
          <div class="topbar-user">
            <span class="topbar-avatar" id="topbarAvatar">J</span>
            <div class="topbar-user-info">
              <div class="topbar-user-name" id="topbarUserName">John Doe</div>
              <div class="topbar-user-role">Admin</div>
            </div>
          </div>
        </div>
      </header>

      <div class="wizard-page">
        <div class="wizard-container">
    <!-- Header -->
    <div class="wizard-header">
      <div>
        <div class="wizard-title">
          <i class="bi bi-magic"></i> Create Dashboard via Wizard
        </div>
        <div class="wizard-subtitle">Guided, AI-assisted dashboard creation in 6 simple steps</div>
      </div>
      <a href="/dashboard" class="btn-exit"><i class="bi bi-x-lg"></i> Exit Wizard</a>
    </div>

    <!-- Stepper -->
    <div class="wizard-stepper" id="wizardStepper">
      <div class="stepper-step active" data-step="1">
        <div class="stepper-circle">1</div>
        <div class="stepper-label">Data Source</div>
      </div>
      <div class="stepper-step" data-step="2">
        <div class="stepper-circle">2</div>
        <div class="stepper-label">Analyze</div>
      </div>
      <div class="stepper-step" data-step="3">
        <div class="stepper-circle">3</div>
        <div class="stepper-label">AI Recommend</div>
      </div>
      <div class="stepper-step" data-step="4">
        <div class="stepper-circle">4</div>
        <div class="stepper-label">Style</div>
      </div>
      <div class="stepper-step" data-step="5">
        <div class="stepper-circle">5</div>
        <div class="stepper-label">Generate</div>
      </div>
      <div class="stepper-step" data-step="6">
        <div class="stepper-circle">6</div>
        <div class="stepper-label">Save</div>
      </div>
    </div>

    <!-- Body -->
    <div class="wizard-body">
      <div id="alertBox" class="hidden"></div>

      <!-- Step 1: Data Source Selection -->
      <div class="wizard-step active" data-step="1">
        <div class="step-title"><i class="bi bi-cloud-upload"></i> Step 1: Select Your Data Source</div>
        <div class="step-description">Choose where your data lives. You can upload files or connect to databases.</div>

        <div>
          <label style="font-weight: 600; font-size: 13px; margin-bottom: 12px; display: block; color: #374151;">
            Data Source Type
          </label>
          <div class="source-options">
            <div class="source-option" data-source="file">
              <div class="source-icon"><i class="bi bi-file-earmark-arrow-up"></i></div>
              <div class="source-label">File Upload</div>
              <div class="source-hint">Upload Excel, CSV, or other files</div>
            </div>
            <div class="source-option" data-source="database">
              <div class="source-icon"><i class="bi bi-database"></i></div>
              <div class="source-label">Database</div>
              <div class="source-hint">Connect to your database</div>
            </div>
            <div class="source-option" data-source="api">
              <div class="source-icon"><i class="bi bi-plug"></i></div>
              <div class="source-label">API</div>
              <div class="source-hint">Connect to your API</div>
            </div>
          </div>
        </div>

        <!-- File Upload Section -->
        <div id="fileUploadSection" class="hidden">
          <div class="upload-area">
            <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
            <div class="upload-text"><strong>Click to upload</strong> or drag and drop</div>
            <div class="upload-subtext">CSV, Excel (.xlsx), or JSON files supported</div>
          </div>
          <input type="file" id="dataFileInput" accept=".csv,.xlsx,.xls,.json,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv,application/json">
          <div id="fileUploadStatus" style="margin-top: 16px; font-size: 13px; color: #6b7280;"></div>
        </div>

        <!-- Database Section -->
        <div id="databaseSection" class="hidden">
          <select id="dbSourceSelect" class="form-control" style="margin-bottom: 16px;">
            <option value="">Select existing connection or create newâ€¦</option>
            <% allDataSources.forEach(function(s) { %>
              <% if (s.sourceType === 'database') { %>
                <option value="<%= s.id %>"><%= s.name %></option>
              <% } %>
            <% }); %>
          </select>

          <div id="newDbForm" class="db-form hidden">
            <div class="form-group">
              <label>Database Type</label>
              <select id="dbType">
                <option value="mysql">MySQL</option>
                <option value="postgres">PostgreSQL</option>
                <option value="sqlserver">SQL Server</option>
                <option value="sqlite">SQLite</option>
              </select>
            </div>
            <div class="form-group">
              <label>Host</label>
              <input type="text" id="dbHost" placeholder="localhost">
            </div>
            <div class="form-group">
              <label>Port</label>
              <input type="text" id="dbPort" placeholder="3306">
            </div>
            <div class="form-group">
              <label>Database Name</label>
              <input type="text" id="dbName" placeholder="my_database">
            </div>
            <div class="form-group">
              <label>Username</label>
              <input type="text" id="dbUser" placeholder="root">
            </div>
            <div class="form-group">
              <label>Password</label>
              <input type="password" id="dbPassword" placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢">
            </div>
            <button class="btn btn-primary" onclick="testDatabaseConnection()" style="width: 100%;">
              <i class="bi bi-plug-fill"></i> Test Connection
            </button>
          </div>
        </div>

        <!-- API Section -->
        <div id="apiSection" class="hidden">
          <div class="db-form">
            <div class="form-group">
              <label>API Endpoint</label>
              <input type="text" id="apiUrl" placeholder="https://api.example.com/data">
            </div>
            <div class="form-group">
              <label>Authentication Token (Optional)</label>
              <input type="password" id="apiToken" placeholder="Bearer token">
            </div>
            <button class="btn btn-primary" onclick="testApiConnection()" style="width: 100%;">
              <i class="bi bi-plug-fill"></i> Test Connection
            </button>
          </div>
        </div>
      </div>

      <!-- Step 2: Analysis -->
      <div class="wizard-step" data-step="2">
        <div class="step-title"><i class="bi bi-graph-up"></i> Step 2: Data Analysis</div>
        <div class="step-description">AI is analyzing your dataâ€¦</div>

        <div id="analysisContent">
          <div class="analysis-progress">
            <div class="spinner"></div>
            <div class="progress-text">Analyzing your dataâ€¦</div>
            <div class="progress-subtext">This may take 10-30 seconds</div>
          </div>
        </div>

        <div id="analysisResults" class="hidden">
          <div id="sheetsInfo" class="hidden" style="margin-bottom: 16px; padding: 12px 16px; background: #eef2ff; border-left: 4px solid #667eea; border-radius: 6px; font-size: 13px; color: #1f2937;"></div>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px;">
            <div class="analysis-card">
              <div class="analysis-stat">
                <span class="stat-label">Total Rows</span>
                <span class="stat-value" id="stat-rows">-</span>
              </div>
            </div>
            <div class="analysis-card">
              <div class="analysis-stat">
                <span class="stat-label">Total Columns</span>
                <span class="stat-value" id="stat-cols">-</span>
              </div>
            </div>
            <div class="analysis-card">
              <div class="analysis-stat">
                <span class="stat-label">Data Quality</span>
                <span class="stat-value" id="stat-quality">-</span>
              </div>
            </div>
            <div class="analysis-card">
              <div class="analysis-stat">
                <span class="stat-label">Data Completeness</span>
                <span class="stat-value" id="stat-complete">-</span>
              </div>
            </div>
          </div>

          <div style="margin-top: 20px;">
            <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Key Metrics Found:</p>
            <div id="kpiList"></div>
          </div>
        </div>
      </div>

      <!-- Step 3: AI Recommendations -->
      <div class="wizard-step" data-step="3">
        <div class="step-title"><i class="bi bi-lightbulb"></i> Step 3: AI Recommendations</div>
        <div class="step-description">Based on your data, here are the best options for your dashboard:</div>

        <div id="recommendationsContent">
          <div class="analysis-progress">
            <div class="spinner"></div>
            <div class="progress-text">Getting AI recommendationsâ€¦</div>
          </div>
        </div>

        <div id="recommendationsResults" class="hidden">
          <div>
            <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Recommended Dashboard Type:</p>
            <div id="dashboardTypeRecommendation" class="recommendation-card" style="cursor: auto;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div id="typeIcon" style="font-size: 32px;"></div>
                <div>
                  <div id="typeName" style="font-size: 14px; font-weight: 700; color: #1f2937;"></div>
                  <div id="typeReason" style="font-size: 12px; color: #6b7280;"></div>
                </div>
              </div>
            </div>
          </div>

          <div style="margin-top: 24px;">
            <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Recommended KPIs:</p>
            <div id="kpiRecommendations" class="recommendations-grid"></div>
          </div>

          <div style="margin-top: 24px;">
            <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Recommended Charts:</p>
            <div id="chartRecommendations" class="recommendations-grid"></div>
          </div>
        </div>
      </div>

      <!-- Step 4: Style Selection -->
      <div class="wizard-step" data-step="4">
        <div class="step-title"><i class="bi bi-palette"></i> Step 4: Dashboard Style</div>
        <div class="step-description">Customize the look and feel of your dashboard</div>

        <div>
          <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Theme</p>
          <div class="style-grid" id="themeGrid"></div>
        </div>

        <div style="margin-top: 32px;">
          <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Layout</p>
          <div class="style-grid" id="layoutGrid"></div>
        </div>

        <div style="margin-top: 32px;">
          <p style="font-size: 13px; font-weight: 600; color: #1f2937; margin-bottom: 12px;">Dashboard Title</p>
          <input type="text" id="dashboardTitle" class="form-control" placeholder="e.g., Sales Performance Report" style="font-size: 14px;">
        </div>
      </div>

      <!-- Step 5: Generate Dashboard -->
      <div class="wizard-step" data-step="5">
        <div class="step-title"><i class="bi bi-lightning-fill"></i> Step 5: Generate Dashboard</div>
        <div class="step-description">Ready to create your professional dashboard?</div>

        <div style="background: linear-gradient(135deg, #f0f3ff 0%, #f9f5ff 100%); border: 1px solid #667eea; border-radius: 8px; padding: 24px; margin-top: 24px;">
          <div style="display: flex; gap: 16px; align-items: flex-start;">
            <div style="font-size: 32px; color: #667eea;">âœ¨</div>
            <div>
              <div style="font-size: 14px; font-weight: 600; color: #1f2937; margin-bottom: 8px;">Your dashboard will include:</div>
              <ul style="font-size: 13px; color: #6b7280; margin-left: 20px; line-height: 1.8;">
                <li>Premium KPI cards with real-time updates</li>
                <li>Executive summary with key insights</li>
                <li>AI-powered anomaly detection</li>
                <li>Interactive charts and visualizations</li>
                <li>Smart filters and drill-down capabilities</li>
                <li>Fully draggable and resizable widgets</li>
                <li>Professional styling and theme</li>
                <li>Export to PNG, PDF, or Excel</li>
              </ul>
            </div>
          </div>
        </div>

        <div id="generationProgress" class="analysis-progress hidden" style="margin-top: 32px;">
          <div class="spinner"></div>
          <div class="progress-text">Generating your dashboardâ€¦</div>
          <div class="progress-subtext">This may take 30-60 seconds</div>
        </div>

        <div id="generationSuccess" class="hidden" style="margin-top: 24px;">
          <div class="alert alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <div>Dashboard generated successfully! Review it before saving.</div>
          </div>
        </div>
      </div>

      <!-- Step 6: Save & Share -->
      <div class="wizard-step" data-step="6">
        <div class="step-title"><i class="bi bi-check-lg"></i> Step 6: Save & Share</div>
        <div class="step-description">Your dashboard is ready! Choose what to do next:</div>

        <div class="recommendations-grid" style="margin-top: 24px;">
          <div class="recommendation-card" onclick="saveDashboard()" style="cursor: pointer;">
            <div class="recommendation-icon"><i class="bi bi-save"></i></div>
            <div class="recommendation-title">Save Dashboard</div>
            <div class="recommendation-desc">Save to your dashboards library</div>
          </div>
          <div class="recommendation-card" onclick="editInCanvas()" style="cursor: pointer;">
            <div class="recommendation-icon"><i class="bi bi-pencil-square"></i></div>
            <div class="recommendation-title">Edit in Canvas</div>
            <div class="recommendation-desc">Customize and refine your dashboard</div>
          </div>
          <div class="recommendation-card" onclick="exportDashboard('png')" style="cursor: pointer;">
            <div class="recommendation-icon"><i class="bi bi-image"></i></div>
            <div class="recommendation-title">Export PNG</div>
            <div class="recommendation-desc">Download as image</div>
          </div>
          <div class="recommendation-card" onclick="exportDashboard('pdf')" style="cursor: pointer;">
            <div class="recommendation-icon"><i class="bi bi-file-earmark-pdf"></i></div>
            <div class="recommendation-title">Export PDF</div>
            <div class="recommendation-desc">Download as PDF report</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="wizard-footer">
      <div class="step-info">
        Step <span id="currentStep">1</span> of 6
      </div>
      <div class="footer-nav">
        <button class="btn btn-secondary" onclick="previousStep()" id="prevBtn" disabled>
          <i class="bi bi-chevron-left"></i> Back
        </button>
        <button class="btn btn-primary" onclick="nextStep()" id="nextBtn">
          Continue <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  </div>
      </div><!-- /.wizard-page -->
    </main>
  </div><!-- /.app-shell -->

  <script>
    // Mock-auth user info from cookie
    (function () {
      try {
        var raw = document.cookie.split(';').map(function(c){return c.trim();}).find(function(c){return c.indexOf('autodash_user=')===0;});
        if (raw) {
          var u = JSON.parse(decodeURIComponent(raw.split('=')[1]));
          if (u && u.name) {
            document.getElementById('topbarUserName').textContent = u.name;
            document.getElementById('topbarAvatar').textContent = (u.name[0] || 'U').toUpperCase();
          }
        }
      } catch (e) {}
    })();
    function autoDashLogout(){
      fetch('/auth/logout',{method:'POST'}).finally(function(){
        document.cookie='autodash_auth=; Path=/; Max-Age=0';
        document.cookie='autodash_user=; Path=/; Max-Age=0';
        try{localStorage.removeItem('autodash_auth');}catch(e){}
        window.location.href='/auth';
      });
    }
  </script>
  <script src="/js/wizard.js"></script>
</body>
</html>
