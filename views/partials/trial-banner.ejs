<%
  // ─── Trial banner ──────────────────────────────────────────────────
  // Shows when the current workspace is on a trialing subscription.
  // Hidden when status is active/expired or no workspace context.
  var __ws = (typeof currentWorkspace !== 'undefined') ? currentWorkspace : null;
  var __td = (typeof trialDaysLeft !== 'undefined') ? trialDaysLeft : null;
  if (__ws && __ws.subscriptionStatus === 'trialing' && __td !== null) {
    var __urgent = __td <= 3;
%>
<div class="trial-banner <%= __urgent ? 'urgent' : '' %>" role="status">
  <i class="bi bi-stopwatch-fill"></i>
  <span>
    <% if (__td > 1) { %>
      <strong><%= __td %> days</strong> left on your <strong><%= (__ws.plan || 'business').replace(/^./, function(c){return c.toUpperCase();}) %></strong> trial
    <% } else if (__td === 1) { %>
      <strong>Last day</strong> of your <strong><%= (__ws.plan || 'business').replace(/^./, function(c){return c.toUpperCase();}) %></strong> trial
    <% } else { %>
      Your <strong><%= (__ws.plan || 'business').replace(/^./, function(c){return c.toUpperCase();}) %></strong> trial ends today
    <% } %>
    — upgrade to keep unlimited dashboards, sources, and AI generations.
  </span>
  <a href="/billing" class="trial-banner-cta">Upgrade now <i class="bi bi-arrow-right"></i></a>
</div>
<style>
  .trial-banner {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 18px;
    background: linear-gradient(90deg, #FEF3C7 0%, #FDE68A 100%);
    color: #78350F;
    font-size: 0.9rem;
    border-bottom: 1px solid #F59E0B;
  }
  .trial-banner.urgent {
    background: linear-gradient(90deg, #FEE2E2 0%, #FECACA 100%);
    color: #7F1D1D;
    border-bottom-color: #DC2626;
  }
  .trial-banner i.bi-stopwatch-fill { font-size: 1.1rem; }
  .trial-banner span { flex: 1; }
  .trial-banner-cta {
    background: #1F2937; color: #fff !important;
    padding: 6px 14px; border-radius: 6px;
    font-weight: 600; text-decoration: none; font-size: 0.85rem;
    white-space: nowrap;
  }
  .trial-banner-cta:hover { background: #111827; color: #fff; }
</style>
<% } %>
