<script>
// Open template picker modal
function openTemplatePickerModal() {
  const modal = document.getElementById('templatePickerModal');
  const modalDialog = modal.querySelector('.modal-dialog');
  modal.style.display = 'block';
  modal.style.visibility = 'visible';
  modal.style.opacity = '1';
  modal.style.pointerEvents = 'auto';
  modalDialog.style.pointerEvents = 'auto';
  modal.removeAttribute('aria-hidden');
  modal.removeAttribute('inert');
  modal.setAttribute('aria-modal', 'true');
  
  loadTemplatesForPicker();
  document.body.style.overflow = 'hidden';
}

// Close template picker modal
function closeTemplatePickerModal() {
  const modal = document.getElementById('templatePickerModal');
  const modalDialog = modal.querySelector('.modal-dialog');
  // Move focus OUT of the modal before applying aria-hidden, otherwise
  // browsers warn that aria-hidden ancestors must not contain focused elements.
  if (modal.contains(document.activeElement) && typeof document.activeElement.blur === 'function') {
    document.activeElement.blur();
  }
  modal.style.display = 'none';
  modal.style.visibility = 'hidden';
  modal.style.opacity = '0';
  modal.style.pointerEvents = 'none';
  modalDialog.style.pointerEvents = 'none';
  modal.setAttribute('aria-hidden', 'true');
  modal.removeAttribute('aria-modal');
  // `inert` is the modern way to make a hidden subtree non-interactive AND
  // non-focusable for assistive tech, complementing aria-hidden cleanly.
  modal.setAttribute('inert', '');
  document.body.style.overflow = 'auto';
}

// Load templates for the picker
async function loadTemplatesForPicker() {
  const grid = document.getElementById('templatePickerGrid');
  if (grid) {
    // Skeleton loaders for premium feel
    grid.innerHTML = Array.from({ length: 6 }).map(() => '<div class="tpl-skeleton"></div>').join('');
  }
  try {
    const response = await fetch('/wizard-guided/templates');
    const data = await response.json();

    if (data.success) {
      renderTemplatePickerGrid(data.templates);
    }
  } catch (error) {
    console.error('Error loading templates:', error);
    if (grid) grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#94A3B8;padding:40px">Could not load templates. Please try again.</div>';
  }
}

// Map template name → premium category styling (icon + accent + badge)
function tplCategoryStyle(template) {
  const name = (template.name || '').toLowerCase();
  // Default fallback
  let cfg = {
    icon: 'bi-grid-1x2-fill',
    accent: '#4F46E5',
    iconBg: 'linear-gradient(135deg, #EEF2FF, #E0E7FF)',
    tint: 'rgba(79,70,229,0.10)',
    badge: 'Template',
    badgeBg: '#EEF2FF', badgeFg: '#4338CA', badgeBorder: '#E0E7FF'
  };
  if (name.includes('executive')) cfg = {
    icon: 'bi-bar-chart-line-fill', accent: '#0EA5E9',
    iconBg: 'linear-gradient(135deg, #E0F2FE, #BAE6FD)', tint: 'rgba(14,165,233,0.10)',
    badge: 'Premium', badgeBg: '#FEF3C7', badgeFg: '#92400E', badgeBorder: '#FDE68A'
  };
  else if (name.includes('hr') || name.includes('recruit')) cfg = {
    icon: name.includes('recruit') ? 'bi-person-plus-fill' : 'bi-people-fill', accent: '#10B981',
    iconBg: 'linear-gradient(135deg, #D1FAE5, #A7F3D0)', tint: 'rgba(16,185,129,0.10)',
    badge: 'People', badgeBg: '#D1FAE5', badgeFg: '#065F46', badgeBorder: '#A7F3D0'
  };
  else if (name.includes('sales')) cfg = {
    icon: 'bi-graph-up-arrow', accent: '#F59E0B',
    iconBg: 'linear-gradient(135deg, #FEF3C7, #FDE68A)', tint: 'rgba(245,158,11,0.12)',
    badge: 'Revenue', badgeBg: '#FEF3C7', badgeFg: '#92400E', badgeBorder: '#FDE68A'
  };
  else if (name.includes('finance')) cfg = {
    icon: 'bi-cash-coin', accent: '#059669',
    iconBg: 'linear-gradient(135deg, #ECFDF5, #D1FAE5)', tint: 'rgba(5,150,105,0.10)',
    badge: 'Business', badgeBg: '#ECFDF5', badgeFg: '#065F46', badgeBorder: '#A7F3D0'
  };
  else if (name.includes('operation')) cfg = {
    icon: 'bi-diagram-3-fill', accent: '#0891B2',
    iconBg: 'linear-gradient(135deg, #CFFAFE, #A5F3FC)', tint: 'rgba(8,145,178,0.10)',
    badge: 'Efficiency', badgeBg: '#CFFAFE', badgeFg: '#155E75', badgeBorder: '#A5F3FC'
  };
  else if (name.includes('customer') || name.includes('service')) cfg = {
    icon: 'bi-headset', accent: '#EC4899',
    iconBg: 'linear-gradient(135deg, #FCE7F3, #FBCFE8)', tint: 'rgba(236,72,153,0.10)',
    badge: 'Support', badgeBg: '#FCE7F3', badgeFg: '#9D174D', badgeBorder: '#FBCFE8'
  };
  else if (name.includes('it ') || name.includes('itsm') || name.includes('information')) cfg = {
    icon: 'bi-cpu-fill', accent: '#6366F1',
    iconBg: 'linear-gradient(135deg, #EEF2FF, #C7D2FE)', tint: 'rgba(99,102,241,0.10)',
    badge: 'Technology', badgeBg: '#EEF2FF', badgeFg: '#3730A3', badgeBorder: '#C7D2FE'
  };
  else if (name.includes('project')) cfg = {
    icon: 'bi-kanban-fill', accent: '#7C3AED',
    iconBg: 'linear-gradient(135deg, #F5F3FF, #DDD6FE)', tint: 'rgba(124,58,237,0.10)',
    badge: 'Delivery', badgeBg: '#F5F3FF', badgeFg: '#5B21B6', badgeBorder: '#DDD6FE'
  };
  else if (name.includes('inventory')) cfg = {
    icon: 'bi-box-seam-fill', accent: '#D97706',
    iconBg: 'linear-gradient(135deg, #FEF3C7, #FDE68A)', tint: 'rgba(217,119,6,0.10)',
    badge: 'Stock', badgeBg: '#FEF3C7', badgeFg: '#92400E', badgeBorder: '#FDE68A'
  };
  else if (name.includes('custom') || name.includes('ai')) cfg = {
    icon: 'bi-stars', accent: '#8B5CF6',
    iconBg: 'linear-gradient(135deg, #F3E8FF, #E9D5FF)', tint: 'rgba(139,92,246,0.12)',
    badge: 'AI', badgeBg: '#F3E8FF', badgeFg: '#6B21A8', badgeBorder: '#E9D5FF'
  };
  return cfg;
}

// Render template cards in the picker (uses shared TemplatePreviewCard component)
function renderTemplatePickerGrid(templates) {
  const grid = document.getElementById('templatePickerGrid');
  grid.innerHTML = '';

  // Switch container styling to use the shared rich card grid
  grid.classList.add('tpc-grid');
  grid.classList.remove('tpl-grid');

  templates.forEach(template => {
    if (!window.TemplatePreviewCard) return;
    const type = window.resolveTemplatePreviewType(template.id || template.name);
    const meta = window.getTemplateMeta(type);
    const kpis = Array.isArray(template.recommendedKpis) ? template.recommendedKpis
      : (Array.isArray(template.kpis) ? template.kpis
        : (typeof template.kpis === 'string' ? (function(){ try { return JSON.parse(template.kpis); } catch(e){ return []; } })() : []));

    const card = window.TemplatePreviewCard({
      templateId: template.id,
      title: template.name,
      description: template.description,
      category: template.category || meta.category,
      accentColor: meta.accent,
      recommendedKpis: kpis,
      previewLayoutType: type,
      onUseTemplate: (id, name) => selectTemplateAndGenerate(id, name)
    });
    grid.appendChild(card);
  });
}

// Select template and start generation
function selectTemplateAndGenerate(templateId, templateName) {
  closeTemplatePickerModal();
  
  // Show full-screen loading indicator
  showGeneratingOverlay(`Generating ${templateName}...`, 'Analyzing data sources and creating dashboard panels...');
  
  // Generate full dashboard
  generateFullDashboard(templateId, templateName);
}

// Generate full dashboard with all panels
async function generateFullDashboard(templateId, templateName) {
  try {
    // Resolve the currently-selected data source from the AI Builder sidebar.
    // Empty string ⇒ Internal Database (sourceId=null on the server).
    const srcSel = document.getElementById('aiSourceSel');
    const rawVal = srcSel ? (srcSel.value || '') : '';
    const selectedSourceId   = rawVal === '' ? null : (parseInt(rawVal, 10) || null);
    const selectedSourceName = srcSel
      ? (srcSel.options[srcSel.selectedIndex] ? srcSel.options[srcSel.selectedIndex].text : null)
      : null;

    console.log('[CreateDashboard] selected source:', { selectedSourceId, selectedSourceName, templateId });

    // Call the full dashboard generation endpoint
    const response = await fetch('/wizard-guided/generate-full', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        templateId: templateId,
        colorTheme: 'corporate',
        sourceId: selectedSourceId,
        sourceName: selectedSourceName,
        prompt: `Generate a complete ${templateName.toLowerCase()} dashboard using ONLY the fields available in the selected data source (${selectedSourceName || 'Internal Database'}). Skip charts whose required fields do not exist.`
      })
    });
    
    const result = await response.json();
    hideGeneratingOverlay();
    
    if (result.success) {
      // Display full dashboard immediately
      displayFullDashboard(result.dashboard);
    } else {
      alert('Error generating dashboard: ' + (result.message || 'Unknown error'));
    }
  } catch (error) {
    hideGeneratingOverlay();
    console.error('Error:', error);
    alert('Error generating dashboard');
  }
}

// Display full dashboard — render every generated panel as an editable card
// on the AI Builder canvas (drag, resize, properties, save all work for free).
function displayFullDashboard(dashboard) {
  // Store dashboard for reference / debugging
  window.generatedFullDashboard = dashboard;

  const canvasEl = document.getElementById('aiCanvas');
  if (!canvasEl) return;

  // Hide empty-state placeholder, ensure the panel grid is visible
  const emptyState = document.getElementById('aiEmptyState');
  if (emptyState) emptyState.style.display = 'none';
  const panelGrid = document.getElementById('aiPanelGrid');
  if (panelGrid) panelGrid.style.display = '';

  // Remove any prior static-grid container we may have rendered
  const existingDash = document.getElementById('aiFullDashboardContainer');
  if (existingDash) existingDash.remove();

  // Clear the canvas (queue + cards) so consecutive generations replace, not stack.
  resetAiCanvas();

  // Inject a header row showing dashboard title + description (visual only)
  injectGeneratedHeader(dashboard);

  // Show a notice for any template visuals the generator skipped because the
  // selected source did not contain the required fields.
  injectSkippedPanelsNotice(dashboard.skippedPanels || []);

  const colors = dashboard.colors || {};
  const accent = colors.accent || '#4F46E5';

  // Layout grid: split canvas into a 12-column logical grid that maps to pixels.
  // Each row gets a y position; we increment as we place panels.
  const GRID = computeCanvasGrid(canvasEl);
  let cursorY = GRID.startY;

  // Filter out sections that have no buildable panels (defence in depth — the
  // server already filters, but stale data may still arrive).
  const renderableSections = (dashboard.sections || []).filter(function(s) {
    return s && Array.isArray(s.panels) && s.panels.some(function(p) {
      // Insights panels are valid even without query data
      if (p && (p.type === 'insights' || p.type === 'kpi')) return true;
      return p && p.data && p.data.hasData;
    });
  });

  // Track a section label to attach onto each panel for save/restore
  renderableSections.forEach(function(section) {
    const panels = (section.panels || []);
    if (!panels.length) return;

    // Optional section divider (sticky text inside the canvas)
    injectSectionDivider(section.name, cursorY, GRID);
    cursorY += GRID.sectionGap;

    // Decide row layout based on panel kind
    const kpis = panels.filter(p => p.type === 'kpi');
    const insights = panels.filter(p => p.type === 'insights');
    const charts = panels.filter(p => p.type !== 'kpi' && p.type !== 'insights');

    // KPI row — one card per KPI, spread across width
    if (kpis.length) {
      const kpiW = Math.floor((GRID.width - GRID.gap * (kpis.length - 1)) / kpis.length);
      const kpiH = 150;
      kpis.forEach(function(p, i) {
        renderGeneratedPanelOnCanvas(p, section.name, accent, {
          left: GRID.startX + i * (kpiW + GRID.gap),
          top: cursorY,
          width: kpiW,
          height: kpiH,
        });
      });
      cursorY += kpiH + GRID.rowGap;
    }

    // Chart row(s) — 2 columns
    if (charts.length) {
      const cols = 2;
      const cw = Math.floor((GRID.width - GRID.gap * (cols - 1)) / cols);
      const ch = 340;
      charts.forEach(function(p, i) {
        const col = i % cols;
        const row = Math.floor(i / cols);
        renderGeneratedPanelOnCanvas(p, section.name, accent, {
          left: GRID.startX + col * (cw + GRID.gap),
          top: cursorY + row * (ch + GRID.rowGap),
          width: cw,
          height: ch,
        });
      });
      const rows = Math.ceil(charts.length / cols);
      cursorY += rows * ch + (rows - 1) * GRID.rowGap + GRID.rowGap;
    }

    // Insights — full width text panel
    if (insights.length) {
      insights.forEach(function(p) {
        renderGeneratedPanelOnCanvas(p, section.name, accent, {
          left: GRID.startX,
          top: cursorY,
          width: GRID.width,
          height: 180,
        });
        cursorY += 180 + GRID.rowGap;
      });
    }
  });

  // Mark this canvas as "generated full dashboard" so Save uses the executive
  // AJAX flow (persists positions / sizes / chartConfigs / fields).
  window.__aiExecutiveMeta = {
    dashboardType:     'executive',
    dashboardRole:     dashboard.title || 'Generated Dashboard',
    dashboardSubtitle: dashboard.description || '',
    schemaVersion:     'executive-dashboard-v1',
    generatedAt:       dashboard.generatedAt || new Date().toISOString(),
    sections:          (dashboard.sections || []).map(function(s) { return { name: s.name, type: s.type }; }),
    layoutHint:        'free-form',
    templateId:        dashboard.templateId || null,
    sourceId:          dashboard.sourceId   || null,
    sourceName:        dashboard.sourceName || null,
  };

  // Lock the SOURCE selector so the user can't change the database after
  // a dashboard was generated against it. They can still edit chart-type/prompt.
  lockSourceSelector(dashboard.sourceName);

  // Update empty-state flag
  if (typeof aiUpdateEmptyState === 'function') aiUpdateEmptyState();

  // Make sure Properties drawer is reset
  const propContent = document.getElementById('aiPropertiesContent');
  if (propContent) {
    propContent.innerHTML = '<div style="text-align:center;padding:20px 0;color:#9ca3af">' +
      '<i class="bi bi-click" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.3"></i>' +
      'Click any chart, KPI, or table to edit its calculations, fields, filters, and styling.' +
    '</div>';
  }

  canvasEl.scrollTop = 0;
}

// Compute the available grid metrics for the canvas based on its width.
function computeCanvasGrid(canvasEl) {
  const w = Math.max(canvasEl.clientWidth - 40, 720);
  return {
    startX: 16,
    startY: 16,
    width:  w,
    gap:    16,
    rowGap: 18,
    sectionGap: 36,
  };
}

// Render a single generated panel as an editable canvas card.
function renderGeneratedPanelOnCanvas(panel, sectionName, accent, rect) {
  const q = panel.query || {};
  const data = panel.data || {};
  const isKpi = panel.type === 'kpi';
  const isInsight = panel.type === 'insights';

  // Build the shape that aiRenderPanelOnCanvas expects
  const adapted = {
    title: panel.title || 'Untitled Panel',
    chartType: isKpi ? 'cards' : (isInsight ? 'table' : (panel.chartType || 'bar')),
    chartEngine: 'chartjs',
    labels: isKpi
      ? [panel.title || '']
      : (data.labels || []),
    values: isKpi
      ? [typeof data.kpiValue === 'number' ? data.kpiValue : 0]
      : (data.values || []),
    chartConfig: isKpi || isInsight ? null : (data.chartConfig || null),
    hasData: isKpi
      ? (typeof data.kpiValue === 'number')
      : !!data.hasData,
    bgColors: [],
    borderColors: [],
    table:       q.table       || null,
    dimension:   q.dimension   || null,
    measure:     q.measure     || null,
    aggregation: q.aggregation || null,
    limit:       q.limit       || null,
    sourceId:    panel._sourceId || null,
    section:     sectionName || null,
    _section:    sectionName || null,
    structuredRequest: {
      focusArea:   q.table || '',
      dimensions:  q.dimension ? [q.dimension] : [],
      metrics:     q.measure ? [q.measure] : [],
      aggregation: (q.aggregation || (isKpi ? 'count' : 'sum')).toLowerCase(),
      limit:       q.limit || null,
      filters:     [],
      sort:        null,
      chartPreference: isKpi ? 'cards' : (panel.chartType || null),
    },
    aiInsight: panel.insight || null,
    parsedByAI: true,
  };

  // Always store a per-panel dataConfig snapshot for the Properties → Data tab.
  // This is the single source of truth for what the element is bound to.
  (function attachDataConfig() {
    const dim = q.dimension || null;
    const met = q.measure || null;
    const table = q.table || '';
    const agg = (q.aggregation || (isKpi ? 'count' : 'sum')).toLowerCase();
    const aggLabel = agg.charAt(0).toUpperCase() + agg.slice(1);
    const qualMetric = met ? (table ? table + '.' + met : met) : '*';
    const qualDim = dim ? (table ? table + '.' + dim : dim) : '';
    let calc = aggLabel + '(' + qualMetric + ')';
    if (qualDim) calc += ' grouped by ' + qualDim;
    const labels = adapted.labels || [];
    const values = adapted.values || [];
    const preview = [];
    for (let i = 0; i < Math.min(labels.length, values.length, 10); i++) {
      const row = {};
      if (dim) row[dim] = labels[i];
      if (met) row[met] = values[i];
      preview.push(row);
    }
    adapted.dataConfig = {
      sourceId:   adapted.sourceId || null,
      sourceName: adapted.sourceId ? ('Source #' + adapted.sourceId) : 'Internal Database',
      table,
      groupByField: dim,
      valueField: met,
      metricField: met,
      aggregation: agg,
      filters: [],
      sortBy: null,
      sortDirection: 'desc',
      topN: q.limit || null,
      calculationLabel: calc,
      resultPreview: preview,
      currentValue: isKpi ? (data.kpiValue != null ? data.kpiValue : (values.length === 1 ? values[0] : null))
                          : (values.length === 1 ? values[0] : null),
    };
  })();

  if (isInsight) {
    // For insights we keep it as a small text-only card by reusing 'table'
    adapted.tableData = { columns: ['Insight'], rows: [{ Insight: panel.title || 'AI Insight' }] };
  }

  // Render via the existing AI Builder pipeline
  aiRenderPanelOnCanvas(adapted, false);

  // Now reposition + resize the freshly-created card to honor our layout.
  const uid = adapted._uid;
  const card = document.getElementById('aiCard-' + uid);
  if (card && rect) {
    card.style.left   = rect.left + 'px';
    card.style.top    = rect.top + 'px';
    card.style.width  = rect.width + 'px';
    card.style.height = rect.height + 'px';
    // Cache position so submitAiDashboard persists it
    adapted.position = { left: rect.left, top: rect.top };
    adapted.size     = { width: rect.width, height: rect.height };
  }
  // Tag the card with its section so aiCleanupEmptySections() can find it
  // when the user deletes panels.
  if (card && sectionName) {
    card.setAttribute('data-section-name', sectionName);
  }

  // Add to the queue so Save Dashboard includes it
  __aiQueue.push(adapted);

  // Status dot overlay for KPI cards (🟢 / 🟡 / 🔴)
  if (isKpi && panel.statusLevel && card) {
    applyKpiStatusDot(card, panel.statusLevel);
  }

  // Force chart re-fit after the resize
  setTimeout(function() {
    try { __aiCharts[uid] && __aiCharts[uid].resize(); } catch (e) {}
  }, 80);
}

// Add a colored status dot to the upper-right of a KPI card
function applyKpiStatusDot(card, level) {
  if (!card) return;
  const colors = { success:'#10b981', warning:'#f59e0b', danger:'#ef4444', info:'#3b82f6' };
  const c = colors[level] || colors.info;
  let dot = card.querySelector('.aiKpiStatusDot');
  if (!dot) {
    dot = document.createElement('span');
    dot.className = 'aiKpiStatusDot';
    dot.style.cssText = 'position:absolute;top:10px;right:12px;width:10px;height:10px;border-radius:50%;' +
      'box-shadow:0 0 0 3px rgba(255,255,255,0.9);z-index:5;pointer-events:none';
    card.style.position = card.style.position || 'absolute';
    card.appendChild(dot);
  }
  dot.style.background = c;
  dot.title = 'Status: ' + level;
}

