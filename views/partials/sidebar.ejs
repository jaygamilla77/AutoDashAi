<!-- Sidebar (shared across layout + standalone pages) -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <a href="/dashboard" aria-label="AutoDash AI Home"><i class="bi bi-bar-chart-line-fill"></i></a>
  </div>
  <nav class="sidebar-nav" aria-label="Primary">
    <a href="/dashboard" class="sidebar-link" title="Home">
      <i class="bi bi-house-fill"></i>
      <span>Home</span>
    </a>
    <a href="/dashboard/history" class="sidebar-link" title="Dashboards">
      <i class="bi bi-grid-3x3-gap-fill"></i>
      <span>Dashboards</span>
    </a>
    <a href="/sources" class="sidebar-link" title="Sources">
      <i class="bi bi-database-fill"></i>
      <span>Sources</span>
    </a>
    <a href="/templates" class="sidebar-link" title="Templates">
      <i class="bi bi-palette2"></i>
      <span>Templates</span>
    </a>
    <a href="/ai-builder" class="sidebar-link" title="AI Assistant">
      <i class="bi bi-stars"></i>
      <span>AI</span>
    </a>
    <a href="/billing" class="sidebar-link" title="Billing & Subscription">
      <i class="bi bi-credit-card-fill"></i>
      <span>Billing</span>
    </a>
    <% if (typeof currentUser !== 'undefined' && currentUser && (currentUser.role === 'admin' || currentUser.role === 'super_admin')) { %>
      <a href="/settings/team" class="sidebar-link" title="Team & Members">
        <i class="bi bi-people-fill"></i>
        <span>Team</span>
      </a>
    <% } %>
  </nav>
  <div class="sidebar-bottom">
    <a href="/ai-settings" class="sidebar-link" title="AI Settings">
      <i class="bi bi-gear-fill"></i>
      <span>Settings</span>
    </a>
    <a href="#" class="sidebar-link" title="Sign out" onclick="event.preventDefault(); autoDashLogout();">
      <i class="bi bi-box-arrow-right"></i>
      <span>Sign out</span>
    </a>
  </div>
</aside>
<script>
  // Highlight active sidebar link
  (function () {
    var path = window.location.pathname.replace(/\/+$/, '') || '/';

    function matches(href) {
      switch (href) {
        case '/dashboard':
          // Home is only active on the exact /dashboard route
          return path === '/dashboard';
        case '/dashboard/history':
          // Dashboards: list and detail (read-only)
          return path === '/dashboard/history'
              || /^\/dashboard\/\d+$/.test(path);
        case '/sources':
          return path === '/sources' || path.indexOf('/sources/') === 0;
        case '/templates':
          return path === '/templates' || path.indexOf('/templates/') === 0;
        case '/ai-builder':
          // AI Builder + wizard flows + edit-canvas (AI editing)
          return path === '/ai-builder'
              || path === '/wizard'
              || path.indexOf('/wizard/') === 0
              || path.indexOf('/wizard-guided/') === 0
              || /^\/dashboard\/\d+\/edit-canvas$/.test(path);
        case '/ai-settings':
          return path === '/ai-settings' || path === '/ai/settings';
        case '/admin':
        case '/admin/pages':
        case '/admin/content':
          return path === '/admin' || path.indexOf('/admin/') === 0;
        default:
          return path === href;
      }
    }

    document.querySelectorAll('.sidebar-link').forEach(function (link) {
      var href = link.getAttribute('href');
      if (!href || href === '#') return;
      var isActive = matches(href);
      if (isActive) {
        link.classList.add('active');
        // Prevent navigating away when the user is already on this section
        link.addEventListener('click', function (e) { e.preventDefault(); });
      }
    });
  })();
  // Logout — clears mock auth and redirects
  window.autoDashLogout = function () {
    try { localStorage.removeItem('autodash_auth'); } catch (_) {}
    document.cookie = 'autodash_auth=; Path=/; Max-Age=0; SameSite=Lax';
    document.cookie = 'autodash_user=; Path=/; Max-Age=0; SameSite=Lax';
    fetch('/auth/logout', { method: 'POST' })
      .catch(function () {})
      .finally(function () { window.location.href = '/auth'; });
  };
</script>
