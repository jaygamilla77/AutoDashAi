<% if (typeof dashboard !== 'undefined' && dashboard) { %>

<div class="page-header d-flex justify-content-between align-items-start">
  <div>
    <h1><%= dashboard.title %></h1>
    <% if (dashboard.promptText) { %>
      <p>"<%= dashboard.promptText %>"</p>
    <% } %>
  </div>
  <div class="d-flex gap-2">
    <% if (dashboard.DataSource) { %>
      <span class="badge bg-secondary"><%= dashboard.DataSource.name %></span>
    <% } %>
    <span class="badge bg-secondary"><%= new Date(dashboard.createdAt).toLocaleDateString() %></span>
  </div>
</div>

<% if (typeof config !== 'undefined' && config) { %>

  <!-- KPIs -->
  <% if (config.kpis && config.kpis.length > 0) { %>
    <% var kpis = config.kpis; %>
    <%- include('partials/kpiCards') %>
  <% } %>

  <!-- Chart -->
  <% if (config.chartConfig) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-body">
          <div class="chart-container" style="position: relative; height: 400px;">
            <canvas id="dashboardChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    window.__chartConfig = <%- JSON.stringify(config.chartConfig) %>;
  </script>
  <% } %>

  <!-- Table -->
  <% if (config.tableData && config.tableData.rows && config.tableData.rows.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-white">
          <h6 class="mb-0">Data</h6>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
              <thead class="table-dark">
                <tr>
                  <% config.tableData.columns.forEach(function(col) { %>
                    <th><%= col %></th>
                  <% }); %>
                </tr>
              </thead>
              <tbody>
                <% config.tableData.rows.forEach(function(row) { %>
                <tr>
                  <% config.tableData.columns.forEach(function(col) { %>
                    <td><%= row[col] != null ? row[col] : '-' %></td>
                  <% }); %>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

<% } %>

<% } else { %>
  <div class="text-center py-5">
    <p class="text-muted">Dashboard not found.</p>
    <a href="/dashboard/history" class="btn btn-primary">Back to History</a>
  </div>
<% } %>
