      // 4. Sectioned chart grid
      var chartPanels = panels.filter(function(p) { return p.chartType !== 'table'; });
      var tablePanels = panels.filter(function(p) { return p.chartType === 'table'; });
      var sectionOrder = ['Executive Summary','Performance Overview','Trend Analysis','Distribution & Breakdown','Operational Detail','Risk & Alerts'];
      var sectionStyles = {
        'Executive Summary':        { accent:'#312e81', icon:'bi-graph-up-arrow' },
        'Performance Overview':     { accent:'#3b82f6', icon:'bi-speedometer2' },
        'Trend Analysis':           { accent:'#6366f1', icon:'bi-activity' },
        'Distribution & Breakdown': { accent:'#8b5cf6', icon:'bi-pie-chart-fill' },
        'Operational Detail':       { accent:'#10b981', icon:'bi-kanban-fill' },
        'Risk & Alerts':            { accent:'#ef4444', icon:'bi-exclamation-diamond-fill' },
      };
      var sectionGroups = {};
      chartPanels.forEach(function(p) {
        var sec = p._section || 'Performance Overview';
        if (!sectionGroups[sec]) sectionGroups[sec] = [];
        sectionGroups[sec].push(p);
      });

      var chartContainer = document.createElement('div');
      chartContainer.id = 'aiFullDashSections';
      chartContainer.style.cssText = 'padding:0 '+gap+'px '+gap+'px;display:flex;flex-direction:column;gap:'+gap+'px';

      var colW = Math.max(280, Math.floor((canvasW - gap * 3) / 2));
      var panelH = 300;

      var orderedSections = sectionOrder.filter(function(s) { return sectionGroups[s] && sectionGroups[s].length; });
      Object.keys(sectionGroups).forEach(function(s) { if (orderedSections.indexOf(s) === -1) orderedSections.push(s); });

      orderedSections.forEach(function(secName, secIdx) {
        var secPanels = sectionGroups[secName];
        var style = sectionStyles[secName] || { accent:'#6b7280', icon:'bi-grid' };

        var secHeader = document.createElement('div');
        secHeader.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 4px 4px';
        secHeader.innerHTML =
          '<div style="width:3px;height:18px;border-radius:2px;background:'+style.accent+';flex-shrink:0"></div>' +
          '<i class="bi '+style.icon+'" style="font-size:0.85rem;color:'+style.accent+'"></i>' +
          '<span style="font-size:0.78rem;font-weight:700;color:#1f2937;letter-spacing:0.2px">'+secName+'</span>' +
          '<div style="flex:1;height:1px;background:linear-gradient(90deg,'+style.accent+'30,transparent);margin-left:4px"></div>';
        chartContainer.appendChild(secHeader);

        // KPI/cards panels lay out in a denser 4-up row; charts in a 2-up row.
        var allKpi = secPanels.length > 0 && secPanels.every(function(p) {
          return p.chartType === 'cards' || p.type === 'kpi';
        });
        var rowDiv = document.createElement('div');
        if (allKpi) {
          rowDiv.style.cssText =
            'display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:'+gap+'px';
        } else {
          rowDiv.style.cssText =
            'display:grid;grid-template-columns:repeat(auto-fit,minmax('+Math.max(280,colW-20)+'px,1fr));gap:'+gap+'px';
        }
        var rowPanelH = allKpi ? 150 : panelH;

        secPanels.forEach(function(panel, pi) {
          var wrapperDiv = document.createElement('div');
          wrapperDiv.style.cssText = 'height:'+rowPanelH+'px;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.06);border:1px solid #e5e7eb;background:#fff;animation:aiSlideIn 0.35s ease '+((secIdx*0.1)+(pi*0.06))+'s both;position:relative';

          __aiNextX = -9999; __aiNextY = -9999;
          aiRenderPanelOnCanvas(panel, false);
          __aiQueue.push(panel);

          var card = document.getElementById('aiCard-' + panel._uid);
          if (card) {
            card.style.position = 'relative'; card.style.left = '0'; card.style.top = '0';
            card.style.width = '100%'; card.style.height = '100%';
            card.style.borderRadius = '0'; card.style.boxShadow = 'none'; card.style.border = 'none';
            wrapperDiv.appendChild(card);
          }

          // Remove the inline insight bar from the card (we show a premium overlay instead)
          if (panel.aiInsight && card) {
            var bodyEl = card.querySelector('[data-ai-panel-body]');
            if (bodyEl) {
              var lastChild = bodyEl.lastElementChild;
              // The built-in insight bar has a lightbulb icon — remove it to avoid duplication
              if (lastChild && lastChild.querySelector('.bi-lightbulb')) lastChild.remove();
            }
            var insightOverlay = document.createElement('div');
            insightOverlay.style.cssText = 'position:absolute;bottom:0;left:0;right:0;padding:7px 10px;background:linear-gradient(0deg,rgba(15,23,42,0.82) 0%,rgba(15,23,42,0) 100%);font-size:0.62rem;color:rgba(255,255,255,0.92);line-height:1.45;pointer-events:none;border-radius:0 0 12px 12px';
            insightOverlay.innerHTML = '<i class="bi bi-stars" style="color:#a5b4fc;margin-right:3px"></i>' + _aiEsc(panel.aiInsight);
            wrapperDiv.appendChild(insightOverlay);
          }

          rowDiv.appendChild(wrapperDiv);
        });

        chartContainer.appendChild(rowDiv);
      });

      gridEl.appendChild(chartContainer);

      // 5. Data tables (collapsible)
      if (tablePanels.length > 0) {
        var tableWrap = document.createElement('div');
        tableWrap.style.cssText = 'padding:0 '+gap+'px '+gap+'px';
        var tableToggle = document.createElement('div');
        tableToggle.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 4px;cursor:pointer;user-select:none';
        tableToggle.innerHTML =
          '<div style="width:3px;height:18px;border-radius:2px;background:#6b7280;flex-shrink:0"></div>' +
          '<i class="bi bi-table" style="font-size:0.85rem;color:#6b7280"></i>' +
          '<span style="font-size:0.78rem;font-weight:700;color:#6b7280">Data Tables ('+tablePanels.length+')</span>' +
          '<i class="bi bi-chevron-down" style="color:#9ca3af;font-size:0.75rem;margin-left:auto"></i>';
        var tableBody = document.createElement('div');
        tableBody.style.display = 'none';
        var tableGrid = document.createElement('div');
        tableGrid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:'+gap+'px';
        tablePanels.forEach(function(panel) {
          var tWrap = document.createElement('div');
          tWrap.style.cssText = 'height:260px;border-radius:10px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,0.06);border:1px solid #e5e7eb;background:#fff';
          __aiNextX = -9999; __aiNextY = -9999;
          aiRenderPanelOnCanvas(panel, false); __aiQueue.push(panel);
          var card = document.getElementById('aiCard-' + panel._uid);
          if (card) {
            card.style.position='relative'; card.style.left='0'; card.style.top='0';
            card.style.width='100%'; card.style.height='100%';
            card.style.borderRadius='0'; card.style.boxShadow='none'; card.style.border='none';
            tWrap.appendChild(card);
          }
          tableGrid.appendChild(tWrap);
        });
        tableToggle.addEventListener('click', function() {
          tableBody.style.display = tableBody.style.display === 'none' ? 'block' : 'none';
        });
        tableBody.appendChild(tableGrid);
        tableWrap.appendChild(tableToggle); tableWrap.appendChild(tableBody);
        gridEl.appendChild(tableWrap);
      }

      // 5b. AI Insights & Recommendations strip — first-class dashboard content,
      // persisted on save and restored on reload.
      try {
        var insightsArr = data.insights || [];
        if (insightsArr.length && typeof window.injectInsightsStrip === 'function') {
          // injectInsightsStrip looks for #aiPanelGrid and inserts the strip
          // before it; remove any prior strip first to avoid duplicates.
          var oldStrip = document.getElementById('aiInsightsStrip');
          if (oldStrip) oldStrip.remove();
          window.injectInsightsStrip(insightsArr);
        }
      } catch(e) { console.warn('insights render failed', e); }

      // 6. Executive summary
      var summary = data.executiveSummary || '';
      if (summary && summary.length > 20) {
        var sumDiv = document.createElement('div');
        sumDiv.id = 'aiFullDashSummary';
        sumDiv.style.cssText = 'margin:0 '+gap+'px '+gap+'px;padding:14px 18px;background:linear-gradient(135deg,#faf5ff,#eff6ff);border-radius:12px;border-left:4px solid #6366f1;box-shadow:0 1px 6px rgba(99,102,241,0.1)';
        sumDiv.innerHTML =
          '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">' +
            '<i class="bi bi-robot" style="color:#6366f1;font-size:0.9rem"></i>' +
            '<span style="font-size:0.68rem;font-weight:700;color:#4338ca;text-transform:uppercase;letter-spacing:0.5px">AI Executive Summary</span>' +
          '</div>' +
          '<div style="font-size:0.78rem;color:#374151;line-height:1.65">' + _aiEsc(summary) + '</div>';
        gridEl.appendChild(sumDiv);
      }

      // 7. Finalise
      gridEl.style.minHeight = '600px';
      aiRenderQueueList();
      aiUpdateEmptyState();
      setTimeout(function() {
        Object.values(window.__aiECharts || {}).forEach(function(ec) { try { ec.resize(); } catch(e) {} });
        Object.values(window.__aiCharts || {}).forEach(function(ch) { try { ch.resize(); } catch(e) {} });
      }, 800);
  } // end _aiExecutiveDashboardRender

  function _aiRestoreExecutiveDashboard(preload) {
    var gridEl = document.getElementById('aiPanelGrid');
    if (!gridEl) return;

    aiClearQueue();
    ['aiFullDashSummary','aiFullDashKpiStrip','aiFullDashHeader','aiFullDashAlert','aiFullDashSections'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.remove();
    });

    var data = {
      panels: (preload.panels || []).map(function(p) {
        // Restore _section from the saved `section` field (backward compat)
        p._section = p._section || p.section || 'Performance Overview';
        p.section  = p._section;
        return p;
      }),
      kpiData: preload.kpiData || [],
      dashboardRole: preload.dashboardRole || null,
      dashboardSubtitle: preload.dashboardSubtitle || null,
      anomalyAlert: preload.anomalyAlert || null,
      executiveSummary: preload.executiveSummary || '',
      sections: preload.sections || [],
      layoutHint: preload.layoutHint || null,
      insights: preload.insights || [],
      recommendations: preload.recommendations || [],
    };

    window.__aiExecutiveMeta = {
      dashboardType: preload.dashboardType || 'executive',
      dashboardRole: data.dashboardRole,
      dashboardSubtitle: data.dashboardSubtitle,
      anomalyAlert: data.anomalyAlert,
      layoutHint: data.layoutHint,
      sections: data.sections,
      schemaVersion: preload.schemaVersion || 'executive-dashboard-v1',
      insights: data.insights,
      recommendations: data.recommendations,
      executiveSummary: data.executiveSummary,
    };
    __aiKpiData = data.kpiData;
    __aiExecSummary = data.executiveSummary;

    try {
      _aiExecutiveDashboardRender(data, gridEl);
    } catch(e) {
      console.error('Executive dashboard restore error:', e);
    }
  }

