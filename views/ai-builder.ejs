      h += '<div style="margin-bottom:9px"><label style="font-size:0.62rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:3px"><i class="bi bi-bullseye me-1"></i>Target Value</label>';
      h += '<input type="number" class="form-control form-control-sm" style="font-size:0.74rem" placeholder="e.g. 100000">';
      h += '<div style="font-size:0.6rem;color:#9ca3af;margin-top:2px">Set a goal to show progress toward a target</div></div>';
    }
