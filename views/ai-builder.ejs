      } else if (type === 'pie' || type === 'doughnut') {
        var sc = (chart.data.labels || []).map(function(_, i) { return pal[i % pal.length]; });
        chart.data.datasets.forEach(function(ds) { ds.backgroundColor = sc; ds.borderColor = '#fff'; ds.borderWidth = 2; });
      }
      chart.update();
      aiSyncPanelColors(uid);
