    var font    = opt.getAttribute('data-font')    || 'Inter';
    var desc    = opt.getAttribute('data-desc')    || '';
    var palette = [];
    try { palette = JSON.parse(opt.getAttribute('data-palette') || '[]'); } catch(e) {}
    if (!palette.length) palette = ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'];

    // Re-color all existing canvas charts with new palette
    Object.keys(__aiCharts).forEach(function(uid) {
      var chart = __aiCharts[uid];
      if (!chart || !chart.data || !chart.data.datasets) return;
      var type = (chart.config.type || 'bar').toLowerCase();
      var pal = palette.length ? palette : ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'];
      if (type === 'bar') {
        var barColors = (chart.data.labels || []).map(function(_, i) { return pal[i % pal.length]; });
        chart.data.datasets.forEach(function(ds) { ds.backgroundColor = barColors; ds.borderColor = 'transparent'; ds.borderWidth = 0; ds.borderRadius = 4; });
      } else if (type === 'line') {
