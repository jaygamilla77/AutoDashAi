        ? '<span style="font-size:0.58rem;background:#6366f1;color:#fff;padding:1px 5px;border-radius:3px;font-weight:700;flex-shrink:0">PREVIEW</span>'
        : '<span style="font-size:0.58rem;background:#22c55e;color:#fff;padding:1px 5px;border-radius:3px;font-weight:700;flex-shrink:0">AI</span>') +
      '<span style="font-size:0.82rem;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+_aiEsc(panel.title||'Panel')+'</span>' +
      '</div><div style="display:flex;gap:4px;align-items:center;flex-shrink:0">';
    if (isStaging) {
      hdr += '<button class="btn btn-sm py-0 px-2" onclick="aiAddPreviewToQueue()" style="font-size:0.7rem;background:#6366f1;color:#fff;border:none"><i class="bi bi-plus-circle me-1"></i>Add to Dashboard</button>' +
             '<button class="btn btn-sm btn-link text-secondary p-0 ms-1" onclick="aiClearPreview()" title="Dismiss"><i class="bi bi-x-lg" style="font-size:0.7rem"></i></button>';
    } else {
      // Build grouped type selector for inline panel header
      var _ecTypes = ['gauge','gauge_ring','funnel','treemap','heatmap','waterfall','histogram','bubble','multiline','stackedarea','bullet','timeline','forecast','scatter'];
      var _allTypeGroups = [
        { g: 'Smart', ts: [{ v:'auto', l:'Auto' }] },
        { g: 'Bar / Column', ts: [{ v:'bar', l:'Bar' },{ v:'hbar', l:'H-Bar' },{ v:'stackedbar', l:'Stacked Bar' },{ v:'waterfall', l:'Waterfall' },{ v:'histogram', l:'Histogram' },{ v:'bullet', l:'Bullet' }] },
        { g: 'Line / Area', ts: [{ v:'line', l:'Line' },{ v:'area', l:'Area' },{ v:'stackedarea', l:'Stacked Area' },{ v:'multiline', l:'Multi-Line' },{ v:'timeline', l:'Timeline' },{ v:'forecast', l:'Forecast' }] },
        { g: 'Circular', ts: [{ v:'pie', l:'Pie' },{ v:'doughnut', l:'Doughnut' },{ v:'polarArea', l:'Polar Area' },{ v:'radar', l:'Radar' }] },
        { g: 'Distribution', ts: [{ v:'scatter', l:'Scatter' },{ v:'bubble', l:'Bubble' }] },
        { g: 'Part-to-Whole', ts: [{ v:'funnel', l:'Funnel' },{ v:'treemap', l:'Treemap' }] },
        { g: 'Gauge / KPI', ts: [{ v:'gauge', l:'Gauge' },{ v:'gauge_ring', l:'Gauge Ring' },{ v:'heatmap', l:'Heatmap' },{ v:'cards', l:'KPI Cards' }] },
        { g: 'Tabular', ts: [{ v:'table', l:'Table' }] },
      ];
      hdr += '<select onchange="aiChangeChartType(\''+uid+'\',this.value)" style="font-size:0.6rem;padding:1px 4px;border:1px solid #e2e8f0;border-radius:4px;background:#f8fafc;color:#6b7280;cursor:pointer;max-width:100px">';
      _allTypeGroups.forEach(function(grp) {
        hdr += '<optgroup label="'+grp.g+'">';
        grp.ts.forEach(function(t){ hdr += '<option value="'+t.v+'"'+(t.v===(panel.chartType||'bar')?' selected':'')+'>'+t.l+'</option>'; });
        hdr += '</optgroup>';
      });
      hdr += '</select>' +
             '<button class="btn btn-sm btn-link text-danger p-0 ms-1" onclick="aiRemoveCanvasPanel(\''+uid+'\')" title="Remove"><i class="bi bi-x-lg" style="font-size:0.7rem"></i></button>';
    }
    hdr += '</div></div>';

    // Auto-detect ECharts config for panels saved before chartEngine field existed
    var _isEChart = panel.chartEngine === 'echarts' ||
      (!panel.chartEngine && panel.chartConfig &&
        (panel.chartConfig.series !== undefined || panel.chartConfig.xAxis !== undefined || panel.chartConfig.tooltip !== undefined));
    if (_isEChart) panel.chartEngine = 'echarts'; // normalise for renderer below
    var body = '<div data-ai-panel-body style="flex:1;min-height:0;padding:8px;overflow:hidden;display:flex;flex-direction:column">';
