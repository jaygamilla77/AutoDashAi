    var palettes = [
      { n:'Ocean', cs:['#3b82f6','#6366f1','#22c55e','#f59e0b','#ef4444'] },
      { n:'Sunset', cs:['#ef4444','#f97316','#f59e0b','#eab308','#22c55e'] },
      { n:'Forest', cs:['#22c55e','#10b981','#14b8a6','#0ea5e9','#6366f1'] },
      { n:'Corporate', cs:['#1e40af','#3b82f6','#60a5fa','#93c5fd','#bfdbfe'] },
      { n:'Mono', cs:['#111827','#374151','#6b7280','#9ca3af','#d1d5db'] },
    ];
    h += '<div style="margin-bottom:9px"><label style="font-size:0.62rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:5px"><i class="bi bi-palette me-1"></i>Color Theme</label>';
    h += '<div style="display:flex;flex-direction:column;gap:4px">';
    palettes.forEach(function(pal) {
      var isActive = JSON.stringify(state.customPalette) === JSON.stringify(pal.cs);
      h += '<div onclick="aiPropSetPalette(\'' + uid + '\',' + JSON.stringify(pal.cs) + ')" style="display:flex;align-items:center;gap:6px;padding:5px 8px;border-radius:5px;cursor:pointer;border:1.5px solid ' + (isActive ? '#6366f1' : '#e5e7eb') + ';background:' + (isActive ? '#eef2ff' : '#fff') + '">';
      h += '<div style="display:flex;gap:2px">' + pal.cs.map(function(c) { return '<div style="width:11px;height:11px;border-radius:2px;background:' + c + '"></div>'; }).join('') + '</div>';
      h += '<span style="font-size:0.68rem;color:#374151;font-weight:600;flex:1">' + pal.n + '</span>';
