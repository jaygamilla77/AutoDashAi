  function aiRenderCardsInPanel(uid, panel) {
    var el = document.getElementById('aiCardBody-' + uid); if (!el || !panel.labels) return;
    var formatVal = function(v) {
      var n = parseFloat(v); if (isNaN(n)) return String(v);
      var abs = Math.abs(n);
      if (abs >= 1e9)  return (n/1e9).toFixed(1).replace(/\.0$/,'')  + 'B';
      if (abs >= 1e6)  return (n/1e6).toFixed(1).replace(/\.0$/,'')  + 'M';
      if (abs >= 1e3)  return (n/1e3).toFixed(1).replace(/\.0$/,'')  + 'K';
      return n % 1 !== 0 ? n.toFixed(2) : String(n);
    };
    var pal = aiGetTemplatePalette();
    var defaultPal = ['#3b82f6','#6366f1','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#84cc16','#ec4899'];
