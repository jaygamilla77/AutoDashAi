<!-- Simple Template Picker Modal -->
<%- include('./partials/template-picker-modal.ejs') %>

<!-- Builder Experience enhancements (Fields panel, drag/drop, live preview, suggestions) -->
<script src="/js/builder-experience.js" defer></script>

<!-- Page Header -->
<div class="page-header" style="margin-bottom:4px">
  <h1>AI Builder</h1>
  <p>Ask a question. Generate a dashboard.</p>
</div>

<div id="aiModeCard" style="display:flex;flex-direction:column;flex:1;overflow:hidden;min-height:0">

  <!-- ── AI Mode Toolbar ──────────────────────────────────────────────────── -->
  <div style="display:flex;align-items:center;gap:8px;padding:6px 10px;background:#fff;border:1px solid #e5e7eb;border-top:none;border-radius:0;flex-shrink:0">
    <button class="btn btn-sm btn-outline-secondary" id="aiTogglePromptBtn" onclick="toggleAiPanel('prompt')" title="Toggle Prompt panel" style="font-size:0.78rem">
      <i class="bi bi-layout-sidebar"></i> <span id="aiTogglePromptTxt">Prompt</span>
    </button>
    <div style="width:1px;height:20px;background:#e5e7eb;flex-shrink:0"></div>
    <span style="font-size:0.78rem;color:#6b7280"><i class="bi bi-stars me-1"></i>AI Mode</span>
    <div style="flex:1"></div>
    <span id="aiPanelCountBadge" style="font-size:0.75rem;color:#6b7280;display:none">
      <i class="bi bi-grid-3x3-gap-fill me-1"></i><span id="aiQueueCount">0</span> panel(s) on canvas
    </span>
    <button class="btn btn-sm btn-outline-secondary" id="aiToggleSettingsBtn" onclick="toggleAiPanel('settings')" title="Toggle Settings panel" style="font-size:0.78rem">
      <i class="bi bi-sliders"></i> <span id="aiToggleSettingsTxt">Settings</span>
    </button>
    <button type="button" class="btn btn-sm px-3" id="aiFullDashBtn" onclick="openTemplatePickerModal()" style="font-size:0.82rem;font-weight:700;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;box-shadow:0 2px 8px rgba(99,102,241,0.35)" title="Create a dashboard from a template">
      <i class="bi bi-stars me-1"></i>Create Dashboard
    </button>
    <button type="button" class="btn btn-sm btn-primary px-3" id="aiGenerateBtn" onclick="submitAiDashboard()" disabled style="font-size:0.82rem">
      <i class="bi bi-lightning-fill me-1"></i>Generate &amp; Save
    </button>
    <button type="button" class="btn btn-sm btn-success px-3" id="aiSaveChangesBtn" onclick="submitAiChanges()" disabled style="font-size:0.82rem;display:none">
      <i class="bi bi-check-circle me-1"></i>Save Changes
    </button>
    <form id="aiGenerateForm" method="POST" action="/dashboard/manual-multi" style="display:none">
      <input type="hidden" name="panelsJson" id="aiPanelsJson">
      <input type="hidden" name="kpiDataJson" id="aiKpiDataJson">
      <input type="hidden" name="executiveSummary" id="aiExecSummary">
      <input type="hidden" name="paletteJson" id="aiPaletteJson">
      <input type="hidden" name="executiveMetaJson" id="aiExecutiveMetaJson">
    </form>
    <form id="aiUpdateForm" method="POST" style="display:none">
      <input type="hidden" name="panelsJson" id="aiUpdatePanelsJson">
      <input type="hidden" name="title" id="aiUpdateTitle">
      <input type="hidden" name="promptText" id="aiUpdatePromptText">
    </form>
  </div>

  <!-- ── 3-panel workspace ─────────────────────────────────────────────────── -->
  <div id="aiWorkspace" style="display:flex;flex:1;overflow:hidden;user-select:none;min-height:0">

    <!-- Left: Prompt Panel -->
    <div id="aiPromptPanel" style="width:300px;min-width:160px;flex-shrink:0;background:#f9fafb;overflow-y:auto">
      <div style="padding:7px 10px 6px;border-bottom:1px solid #e5e7eb;background:#f3f4f6">
        <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:#9ca3af">
          <i class="bi bi-chat-left-text me-1"></i>AI Prompt
        </span>
      </div>
      <div style="padding:10px">

        <!-- Source -->
        <div class="mb-2">
          <label style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#2563eb"><i class="bi bi-database-fill me-1"></i>Source</label>
          <select class="form-select form-select-sm mt-1" id="aiSourceSel" style="font-size:0.8rem">
            <option value="">Internal Database</option>
            <% if (typeof sources !== 'undefined' && sources.length > 0) { %>
              <% sources.forEach(function(s) { %>
                <option value="<%= s.id %>"><%= s.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <!-- Chart type -->
        <div class="mb-3">
          <label style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#059669"><i class="bi bi-bar-chart-fill me-1"></i>Chart Type</label>
          <select class="form-select form-select-sm mt-1" id="aiChartTypeSel" style="font-size:0.8rem">
            <% if (typeof chartTypeGroups !== 'undefined' && chartTypeGroups && chartTypeGroups.length) { %>
              <% chartTypeGroups.forEach(function(grp) { %>
                <optgroup label="<%= grp.group %>">
                  <% grp.types.forEach(function(ct) { %>
                    <option value="<%= ct.value %>" <%= ct.value === 'auto' ? 'selected' : '' %>><%= ct.label %></option>
                  <% }); %>
                </optgroup>
              <% }); %>
            <% } else if (typeof chartTypes !== 'undefined') { %>
              <% chartTypes.forEach(function(ct) { %>
                <option value="<%= ct %>" <%= ct === 'auto' ? 'selected' : '' %>><%= ct.charAt(0).toUpperCase() + ct.slice(1) %></option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <!-- Prompt -->
        <div class="mb-2">
          <label style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#7c3aed"><i class="bi bi-pencil-fill me-1"></i>Question</label>
          <textarea class="form-control form-control-sm mt-1" id="aiPromptTextarea" rows="4"
            style="font-size:0.82rem;resize:vertical;min-height:80px"
            placeholder="e.g. Top 10 employees by salary"></textarea>
        </div>

        <!-- Action buttons -->
        <div class="d-flex gap-2 mb-3">
          <button type="button" class="btn btn-sm btn-outline-primary flex-shrink-0" onclick="aiAddToQueue()" style="font-size:0.75rem">
            <i class="bi bi-plus-lg"></i> Add
          </button>
          <button type="button" class="btn btn-sm btn-dark flex-grow-1" onclick="aiPreviewPanel()" id="aiPreviewBtn" style="font-size:0.75rem">
            <i class="bi bi-eye me-1"></i>Preview on Canvas
          </button>
        </div>

        <!-- Queue -->
        <div id="aiQueueSection" style="display:none;margin-bottom:12px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
            <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#6b7280">
              <i class="bi bi-grid-3x3-gap-fill me-1"></i>Queue
              <span class="badge bg-primary rounded-pill ms-1" id="aiPanelCount" style="font-size:0.58rem">0</span>
            </span>
            <button type="button" class="btn btn-link btn-sm text-danger p-0" style="font-size:0.72rem" onclick="aiClearQueue()">
              <i class="bi bi-trash"></i>
            </button>
          </div>
          <div id="aiQueueList" class="d-flex flex-column gap-1"></div>
        </div>

        <!-- Examples -->
        <div class="pt-2 border-top">
          <div class="d-flex justify-content-between align-items-center" style="margin-bottom:6px">
            <div style="font-size:0.63rem;text-transform:uppercase;letter-spacing:0.4px;color:#9ca3af">
              <i class="bi bi-lightbulb me-1"></i>Examples
            </div>
            <button type="button" class="btn btn-sm p-0 border-0" id="btnAISuggest" onclick="fetchAISuggestions()"
              style="font-size:0.65rem;color:#7c3aed;background:none" title="Get AI-powered suggestions">
              <i class="bi bi-stars"></i> AI Suggest
            </button>
          </div>
          <div class="d-flex flex-column gap-1" id="aiExamplesContainer">
            <% if (typeof samplePrompts !== 'undefined') { %>
              <% samplePrompts.forEach(function(sp) { %>
                <button type="button" class="btn btn-sm btn-light text-start ai-example-btn"
                  style="font-size:0.72rem;white-space:normal;text-align:left;border:1px solid #e5e7eb"
                  data-prompt="<%= sp %>"><i class="bi bi-stars me-1" style="color:#8b5cf6;font-size:0.65rem"></i><%= sp %></button>
              <% }); %>
            <% } %>
          </div>
        </div>

      </div>
    </div>

    <!-- Resize handle: prompt ↔ canvas -->
    <div id="aiResizePrompt" style="width:5px;flex-shrink:0;background:#e5e7eb;cursor:col-resize;position:relative;z-index:10;transition:background 0.1s" title="Drag to resize">
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;gap:2px">
        <div style="width:2px;height:10px;background:#9ca3af;border-radius:1px"></div>
      </div>
    </div>

    <!-- Center: Canvas -->
    <div id="aiCanvas" style="flex:1;overflow-y:auto;background:#e8eef5;padding:14px;min-width:0;position:relative">
      <!-- Export toolbar -->
      <div id="aiExportBar" style="position:sticky;top:0;z-index:50;display:flex;gap:6px;margin-bottom:10px;background:transparent">
        <button onclick="aiExportPNG()" class="btn btn-sm btn-light" style="font-size:0.72rem;padding:3px 9px;border:1px solid #d1d5db;background:#fff" title="Export canvas as PNG">
          <i class="bi bi-image me-1"></i>PNG
        </button>
        <button onclick="aiExportPDF()" class="btn btn-sm btn-light" style="font-size:0.72rem;padding:3px 9px;border:1px solid #d1d5db;background:#fff" title="Export canvas as PDF">
          <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </button>
        <button onclick="aiExportExcel()" class="btn btn-sm btn-light" style="font-size:0.72rem;padding:3px 9px;border:1px solid #d1d5db;background:#fff" title="Export data as Excel">
          <i class="bi bi-file-earmark-spreadsheet me-1"></i>Excel
        </button>
        <button onclick="aiOpenShareModal()" class="btn btn-sm" id="aiShareBtn" style="font-size:0.72rem;padding:3px 9px;border:1px solid #2563eb;background:linear-gradient(135deg,#3b82f6,#2563eb);color:#fff;font-weight:600" title="Generate a shareable interactive link">
          <i class="bi bi-share-fill me-1"></i>Share
        </button>
      </div>
      <div id="aiEmptyState" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:90%;text-align:center;pointer-events:none;gap:0">
        <div style="position:relative;width:140px;height:120px;margin-bottom:16px">
          <!-- Sparkle decorations -->
          <span style="position:absolute;top:4px;left:18px;font-size:1rem;color:#c7d2fe;animation:aiPulse 2.5s ease-in-out infinite">✦</span>
          <span style="position:absolute;top:0;right:22px;font-size:0.6rem;color:#ddd6fe;animation:aiPulse 2.5s ease-in-out 0.6s infinite">✦</span>
          <span style="position:absolute;bottom:10px;left:8px;font-size:0.5rem;color:#e0e7ff;animation:aiPulse 2.5s ease-in-out 1.2s infinite">✦</span>
          <!-- Dashboard illustration SVG -->
          <svg width="120" height="100" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin:10px auto 0;display:block;opacity:0.55">
            <rect x="4" y="4" width="112" height="92" rx="8" fill="#f0f4ff" stroke="#c7d2fe" stroke-width="1.5"/>
            <rect x="12" y="12" width="44" height="28" rx="4" fill="#dbeafe"/>
            <rect x="64" y="12" width="44" height="28" rx="4" fill="#ede9fe"/>
            <rect x="12" y="48" width="28" height="38" rx="3" fill="#bfdbfe"/>
            <rect x="46" y="58" width="28" height="28" rx="3" fill="#c7d2fe"/>
            <rect x="80" y="54" width="28" height="32" rx="3" fill="#bbf7d0"/>
            <rect x="17" y="56" width="4" height="24" rx="2" fill="#3b82f6"/>
            <rect x="24" y="62" width="4" height="18" rx="2" fill="#3b82f6" opacity="0.7"/>
            <rect x="31" y="52" width="4" height="28" rx="2" fill="#3b82f6" opacity="0.5"/>
            <circle cx="34" cy="26" r="6" fill="none" stroke="#6366f1" stroke-width="2"/>
            <path d="M29 26 L34 20 L39 28" stroke="#6366f1" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div style="font-size:1rem;font-weight:700;color:#374151">Canvas is empty</div>
        <div style="font-size:0.78rem;margin-top:6px;color:#9ca3af;line-height:1.6">
          Type a question in the <strong style="color:#6366f1">Prompt</strong> panel ←<br>
          click <strong style="color:#6366f1">Preview on Canvas</strong> to get started.
        </div>
      </div>
      <div id="aiPanelGrid" style="position:relative;min-height:100%;width:100%"></div>
    </div>

    <!-- Resize handle: canvas ↔ settings -->
    <div id="aiResizeSettings" style="width:5px;flex-shrink:0;background:#e5e7eb;cursor:col-resize;position:relative;z-index:10;transition:background 0.1s" title="Drag to resize">
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;gap:2px">
        <div style="width:2px;height:10px;background:#9ca3af;border-radius:1px"></div>
      </div>
    </div>

    <!-- Right: Settings/Properties Panel -->
    <div id="aiSettingsPanel" style="display:flex;flex-direction:column;width:240px;min-width:140px;flex-shrink:0;background:#fff;overflow:hidden">
      <!-- Tab buttons -->
      <div style="display:flex;border-bottom:1px solid #e5e7eb;background:#f8fafc;flex-shrink:0">
        <button id="aiSettingsTabBtn" onclick="switchAiSettingsTab('settings')" style="flex:1;padding:8px 12px;border:none;background:none;font-size:0.7rem;font-weight:600;color:#6b7280;border-bottom:2px solid #6366f1;cursor:pointer;text-transform:uppercase;letter-spacing:0.4px">
          <i class="bi bi-sliders me-1"></i>Settings
        </button>
        <button id="aiPropertiesTabBtn" onclick="switchAiSettingsTab('properties')" style="flex:1;padding:8px 12px;border:none;background:none;font-size:0.7rem;font-weight:600;color:#9ca3af;border-bottom:2px solid transparent;cursor:pointer;text-transform:uppercase;letter-spacing:0.4px">
          <i class="bi bi-gear me-1"></i>Properties
        </button>
      </div>

      <!-- Settings Tab Content -->
      <div id="aiSettingsTabContent" style="flex:1;overflow-y:auto;padding:12px">

        <!-- Template -->
        <div class="mb-3">
          <label style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#6b7280"><i class="bi bi-palette me-1"></i>Template</label>
          <select class="form-select form-select-sm mt-1" id="aiTemplateSel" style="font-size:0.8rem" onchange="aiRenderTemplatePreview()">
            <option value="" data-palette="[]" data-accent="#3b82f6" data-font="Inter" data-desc="Default Chart.js colors and no custom font." data-charttypes="[]">Default (no theme)</option>
            <% if (typeof templates !== 'undefined' && templates.length > 0) { %>
              <% templates.forEach(function(t) { %>
                <% var tCharts = ''; try { if (t.preferredChartTypes) tCharts = t.preferredChartTypes; } catch(e) {} %>
                <option value="<%= t.id %>"
                  data-accent="<%= t.accentColor %>"
                  data-font="<%= t.fontFamily %>"
                  data-palette="<%= t.colorPalette || '[]' %>"
                  data-desc="<%= (t.description || '').replace(/"/g, '&quot;') %>"
                  data-charttypes="<%= tCharts %>">
                  <%= t.name %>
                </option>
              <% }); %>
            <% } %>
          </select>
          <div id="aiTemplateHint" style="font-size:0.72rem;color:#888;margin-top:3px"></div>

          <!-- Live template preview -->
          <div id="aiTemplatePreview" style="margin-top:8px;border-radius:6px;overflow:hidden;border:1px solid #e2e8f0;display:none">
            <!-- Will be populated by aiRenderTemplatePreview() -->
          </div>
        </div>

        <hr style="margin:12px 0;border-color:#f1f5f9">

        <div style="font-size:0.72rem;color:#9ca3af;margin-bottom:10px;line-height:1.4">
          <i class="bi bi-info-circle me-1"></i>Preview panels on the canvas, then save as a dashboard.
        </div>

        <button type="button" class="btn btn-dark w-100 mb-2" onclick="aiPreviewPanel()" style="font-size:0.8rem">
          <i class="bi bi-eye me-1"></i>Preview on Canvas
        </button>
        <button type="button" class="btn btn-success w-100" id="aiSaveBtn" onclick="submitAiDashboard()" disabled style="font-size:0.8rem">
          <i class="bi bi-lightning-fill me-1"></i>Generate &amp; Save Dashboard
        </button>

        <!-- AI Tips card -->
        <div style="margin-top:16px;padding:12px 14px;background:linear-gradient(135deg,#eff6ff,#f5f3ff);border-radius:10px;border:1px solid #e0e7ff">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
            <i class="bi bi-stars" style="color:#6366f1;font-size:0.9rem"></i>
            <span style="font-size:0.68rem;font-weight:700;color:#4338ca;text-transform:uppercase;letter-spacing:0.4px">AI Tips</span>
          </div>
          <div style="font-size:0.72rem;color:#4b5563;line-height:1.55">
            Use natural language to describe what you want to see. AI will pick the best charts and KPIs for you.
          </div>
          <div style="margin-top:8px;font-size:0.7rem;color:#6366f1;font-weight:600;cursor:pointer" onclick="document.getElementById('aiPromptPanel').scrollIntoView({behavior:'smooth'})">
            Examples on the left &rarr;
          </div>
        </div>

      </div>

      <!-- Properties Tab Content -->
      <div id="aiPropertiesTabContent" style="flex:1;overflow-y:auto;padding:12px;display:none">
        <div id="aiPropertiesContent" style="font-size:0.8rem;color:#6b7280">
          <div style="text-align:center;padding:20px 0;color:#9ca3af">
            <i class="bi bi-click" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.3"></i>
            Click a chart or card on the canvas to view its properties.
          </div>
        </div>
      </div>

    </div>

  </div><!-- /aiWorkspace -->
</div><!-- /aiModeCard -->

<script>
  // Inject preloadDashboard data for editing existing dashboards
  window.preloadDashboard = <%- JSON.stringify(typeof preloadDashboard !== 'undefined' ? preloadDashboard : null) %>;
</script>

<script>
// ── AI Mode Canvas ────────────────────────────────────────────────────────────
(function () {
  var __aiCharts = {}, __aiECharts = {}, __aiQueue = [], __aiPanelIdCtr = 0, __aiZTop = 10, __aiNextX = 10, __aiNextY = 10;
  var __aiPanelData = {};
  var __preloadDashboard = window.preloadDashboard || null;
  window.__aiCharts = __aiCharts; window.__aiECharts = __aiECharts; window.__aiQueue = __aiQueue; window.__aiPanelData = __aiPanelData;
  window.__preloadDashboard = __preloadDashboard;
  var __aiPreview = null;

  function _aiEsc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Toggle side panels ────────────────────────────────────────────────────
  window.toggleAiPanel = function(which) {
    var ids = which === 'prompt'
      ? { panel:'aiPromptPanel', handle:'aiResizePrompt', btn:'aiTogglePromptBtn' }
      : { panel:'aiSettingsPanel', handle:'aiResizeSettings', btn:'aiToggleSettingsBtn' };
    var p = document.getElementById(ids.panel), h = document.getElementById(ids.handle);
    var btn = document.getElementById(ids.btn);
    var hidden = p.style.display === 'none';
    p.style.display = hidden ? '' : 'none';
    if (h) h.style.display = hidden ? '' : 'none';
    if (btn) btn.classList.toggle('active', hidden);
  };

  // ── Drag-to-resize sidebar handles ────────────────────────────────────────
  (function initAiResizers() {
    function makeResizer(handleId, panelId, side) {
      var handle = document.getElementById(handleId);
      var panel  = document.getElementById(panelId);
      if (!handle || !panel) return;
      handle.addEventListener('mouseover', function() { handle.style.background = '#c7d2fe'; });
      handle.addEventListener('mouseout',  function() { handle.style.background = '#e5e7eb'; });
      handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        var startX = e.clientX, startW = panel.offsetWidth;
        handle.style.background = '#6366f1';
        function onMove(ev) {
          var ws = document.getElementById('aiWorkspace');
          var maxW = ws ? ws.offsetWidth * 0.45 : 600;
          var delta = side === 'left' ? ev.clientX - startX : startX - ev.clientX;
          panel.style.width = Math.max(160, Math.min(maxW, startW + delta)) + 'px';
        }
        function onUp() { handle.style.background = '#e5e7eb'; document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onUp); }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }
    makeResizer('aiResizePrompt',   'aiPromptPanel',   'left');
    makeResizer('aiResizeSettings', 'aiSettingsPanel', 'right');
  })();

  // ── Examples ─────────────────────────────────────────────────────────────
  var SOURCE_PROMPT_MAP = <%- JSON.stringify(typeof sourcePromptMap !== 'undefined' ? sourcePromptMap : {}) %>;
  var DEFAULT_PROMPTS = Array.from(document.querySelectorAll('#aiExamplesContainer .ai-example-btn')).map(function(b){ return b.dataset.prompt; });

  function renderAiExamples(prompts) {
    var c = document.getElementById('aiExamplesContainer'); if (!c) return;
    c.innerHTML = '';
    prompts.forEach(function(p) {
      var text = typeof p === 'string' ? p : p.text;
      var btn = document.createElement('button');
      btn.type = 'button'; btn.className = 'btn btn-sm btn-light text-start ai-example-btn';
      btn.style.cssText = 'font-size:0.72rem;white-space:normal;text-align:left';
      btn.textContent = text;
      btn.addEventListener('click', function(){ document.getElementById('aiPromptTextarea').value = text; });
      c.appendChild(btn);
    });
  }

  document.querySelectorAll('#aiExamplesContainer .ai-example-btn').forEach(function(btn) {
    btn.addEventListener('click', function(){ document.getElementById('aiPromptTextarea').value = this.dataset.prompt; });
  });

  var aiSrcSel = document.getElementById('aiSourceSel');
  if (aiSrcSel) {
    aiSrcSel.addEventListener('change', function() {
      var sid = aiSrcSel.value;
      if (sid && SOURCE_PROMPT_MAP[sid] && SOURCE_PROMPT_MAP[sid].length) renderAiExamples(SOURCE_PROMPT_MAP[sid]);
      else renderAiExamples(DEFAULT_PROMPTS);
    });
  }

  // URL pre-fill
  var urlParams = new URLSearchParams(window.location.search);
  var prePrompt = urlParams.get('prompt');
  if (prePrompt) { var ta = document.getElementById('aiPromptTextarea'); if (ta) ta.value = decodeURIComponent(prePrompt); }
  var preSource = urlParams.get('sourceId');
  if (preSource && aiSrcSel) {
    for (var i = 0; i < aiSrcSel.options.length; i++) {
      if (String(aiSrcSel.options[i].value) === String(preSource)) { aiSrcSel.selectedIndex = i; aiSrcSel.dispatchEvent(new Event('change')); break; }
    }
  }

  // Auto-generate dashboard when template is selected
  var templateId = urlParams.get('template');
  var templateName = urlParams.get('templateName');
  if (templateId && templateName) {
    // Show loading indicator - insert after export bar, don't replace entire canvas
    var canvas = document.getElementById('aiCanvas');
    var emptyState = document.getElementById('aiEmptyState');
    
    if (canvas && emptyState) {
      // Hide the empty state
      emptyState.style.display = 'none';
      
      // Create and show loading indicator
      var loadingMsg = document.createElement('div');
      loadingMsg.id = 'aiTemplateLoading';
      loadingMsg.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;height:400px;gap:20px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:90%;background:rgba(255,255,255,0.95);border-radius:12px;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:100';
      loadingMsg.innerHTML = '<div style="font-size:2rem;animation:spin 1s linear infinite"><i class="bi bi-hourglass-split"></i></div>' +
        '<div style="font-size:1.2rem;font-weight:600;color:#0F172A">Generating ' + decodeURIComponent(templateName) + ' Dashboard...</div>' +
        '<div style="font-size:0.95rem;color:#64748B">Analyzing data and creating your dashboard...</div>';
      
      canvas.appendChild(loadingMsg);
    }

    // Auto-generate with template
    setTimeout(function() {
      // Get template metadata from backend
      fetch('/api/dashboard-templates/' + encodeURIComponent(templateId))
        .then(function(res) { 
          if (!res.ok) throw new Error('Template not found');
          return res.json(); 
        })
        .then(function(tmpl) {
          console.log('Template loaded:', tmpl);
          
          // Use template's prompt starter as the default prompt
          var ta = document.getElementById('aiPromptTextarea');
          if (ta && tmpl.promptStarter) {
            ta.value = tmpl.promptStarter;
            console.log('Prompt set to:', tmpl.promptStarter);
            
            // Dispatch change event to trigger any watchers
            ta.dispatchEvent(new Event('change', { bubbles: true }));
            ta.dispatchEvent(new Event('input', { bubbles: true }));
          }

          // Remove loading indicator and show success message
          setTimeout(function() {
            var loadingEl = document.getElementById('aiTemplateLoading');
            if (loadingEl) {
              loadingEl.innerHTML = '<div style="text-align:center">' +
                '<p style="font-size:2rem;color:#10b981;margin:0"><i class="bi bi-check-circle-fill"></i></p>' +
                '<p style="margin:15px 0 10px;font-size:1.1rem;color:#0F172A"><strong>✓ ' + decodeURIComponent(templateName) + '</strong> template loaded</p>' +
                '<p style="margin:0;font-size:0.95rem;color:#64748B">Click <strong>Preview on Canvas</strong> to generate your dashboard</p>' +
                '</div>';
            }
          }, 500);
        })
        .catch(function(err) {
          console.error('Template load error:', err);
          var loadingEl = document.getElementById('aiTemplateLoading');
          if (loadingEl) {
            loadingEl.innerHTML = '<div style="text-align:center;color:#dc2626">' +
              '<p><i class="bi bi-exclamation-triangle"></i></p>' +
              '<p>Error loading template</p>' +
              '<p style="font-size:0.85rem;margin-top:10px">' + err.message + '</p>' +
              '</div>';
          }
        });
    }, 500);
  }

  // ── Queue management ──────────────────────────────────────────────────────
  function aiUpdateToolbar() {
    var n = __aiQueue.length;
    var badge = document.getElementById('aiPanelCountBadge'), qEl = document.getElementById('aiQueueCount');
    var countEl = document.getElementById('aiPanelCount');
    var section = document.getElementById('aiQueueSection');
    var genBtn = document.getElementById('aiGenerateBtn'), saveBtn = document.getElementById('aiSaveBtn');
    var saveChangesBtn = document.getElementById('aiSaveChangesBtn');
    if (badge)  badge.style.display  = n > 0 ? '' : 'none';
    if (qEl)    qEl.textContent = n;
    if (countEl) countEl.textContent = n;
    if (section) section.style.display = n > 0 ? '' : 'none';
    if (genBtn)  genBtn.disabled  = n === 0;
    if (saveBtn) saveBtn.disabled = n === 0;
    if (saveChangesBtn) saveChangesBtn.disabled = n === 0;
  }
  window.aiUpdateToolbar = aiUpdateToolbar;

  function aiRenderQueueList() {
    var listEl = document.getElementById('aiQueueList'); if (!listEl) return;
    listEl.innerHTML = '';
    __aiQueue.forEach(function(p, idx) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;gap:4px;padding:4px 6px;border:1px solid #e5e7eb;border-radius:6px;background:#fff';
