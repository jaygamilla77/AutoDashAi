    h += '<label style="display:flex;align-items:center;gap:7px;font-size:0.72rem;color:#374151;cursor:pointer;padding:3px 0;margin-bottom:2px"><input type="checkbox" checked style="accent-color:#6366f1"> Show data labels</label>';
    h += '<label style="display:flex;align-items:center;gap:7px;font-size:0.72rem;color:#374151;cursor:pointer;padding:3px 0"><input type="checkbox" checked style="accent-color:#6366f1"> Show legend</label>';
    h += '</div>';
