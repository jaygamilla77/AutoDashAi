  window.aiRenderQueueList = aiRenderQueueList;

  window.aiRemoveFromQueue = function(idx) {
    var p = __aiQueue[idx];
    if (p && p._uid) {
      if (__aiCharts[p._uid]) { __aiCharts[p._uid].destroy(); delete __aiCharts[p._uid]; }
      var card = document.getElementById('aiCard-' + p._uid); if (card) card.remove();
    }
    __aiQueue.splice(idx, 1);
    aiRenderQueueList(); aiUpdateEmptyState();
    if (typeof window.aiCleanupEmptySections === 'function') window.aiCleanupEmptySections();
  };

  window.aiClearQueue = function() {
    __aiQueue.forEach(function(p) {
      if (!p._uid) return;
      if (__aiCharts[p._uid]) { __aiCharts[p._uid].destroy(); delete __aiCharts[p._uid]; }
      delete __aiPanelData[p._uid];
      var card = document.getElementById('aiCard-' + p._uid); if (card) card.remove();
    });
    __aiQueue.splice(0, __aiQueue.length); __aiKpiData = []; __aiExecSummary = ''; aiRenderQueueList(); aiUpdateEmptyState();
    if (typeof window.aiCleanupEmptySections === 'function') window.aiCleanupEmptySections();
  };

