  window.aiCreateShareLink = function() {
    var dashId = window.__editingDashboardId;
    if (!dashId) return;
    var perm = document.getElementById('aiSharePerm').value;
    var expiry = document.getElementById('aiShareExpiry').value || null;
    var pwd = document.getElementById('aiSharePwd').value || null;
    var allowFilters = document.getElementById('aiShareAllowFilters').checked;
    var allowExport = document.getElementById('aiShareAllowExport').checked;

    fetch('/dashboard/' + dashId + '/share', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ permissionType: perm, expiresAt: expiry, password: pwd, allowFilters: allowFilters, allowExport: allowExport }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) { alert('Failed to create share link: ' + data.error); return; }
      var url = data.share.shareUrl;
      var resBox = document.getElementById('aiShareResult');
      resBox.style.display = 'block';
      document.getElementById('aiShareUrlInput').value = url;
      // QR code (Google Chart API)
      var qr = document.getElementById('aiShareQR');
      qr.innerHTML = '<img src="https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=' + encodeURIComponent(url) + '" alt="QR" style="display:block">';
      // Auto-copy
      aiCopyShareLink(true);
    })
    .catch(function(err) { alert('Error: ' + err.message); });
  };

  window.aiCopyShareLink = function(silent) {
    var input = document.getElementById('aiShareUrlInput');
    if (!input || !input.value) return;
    var doneVisual = function() {
      var btn = document.getElementById('aiShareCopyBtn');
      if (btn) {
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Copied!';
        btn.classList.add('btn-success');
        btn.classList.remove('btn-outline-primary');
        setTimeout(function() {
          btn.innerHTML = orig;
          btn.classList.remove('btn-success');
          btn.classList.add('btn-outline-primary');
        }, 1600);
      }
    };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(input.value).then(doneVisual).catch(function() {
        input.select(); document.execCommand('copy'); doneVisual();
      });
    } else {
      input.select(); document.execCommand('copy'); doneVisual();
    }
  };

  window.aiOpenShareLink = function() {
    var input = document.getElementById('aiShareUrlInput');
    if (input && input.value) window.open(input.value, '_blank', 'noopener');
  };

