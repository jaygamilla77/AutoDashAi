      '<svg width="10" height="10" viewBox="0 0 10 10" style="opacity:0.45"><line x1="10" y1="2" x2="2" y2="10" stroke="#6b7280" stroke-width="1.5"/><line x1="10" y1="6" x2="6" y2="10" stroke="#6b7280" stroke-width="1.5"/></svg></div>';

    var clipOpen  = '<div style="position:absolute;inset:0;display:flex;flex-direction:column;border-radius:8px;overflow:hidden;pointer-events:none"><div style="pointer-events:auto;display:flex;flex-direction:column;height:100%">';
    var clipClose = '</div></div>';
    card.innerHTML = clipOpen + hdr + body + clipClose + grip;
    document.getElementById('aiPanelGrid').appendChild(card);
    aiMakePanelInteractive(card, uid);
    
    // Add click handler to show properties
    card.addEventListener('click', function() { showPanelProperties(uid); });

    if (panel.hasData) {
      if (panel.chartType === 'cards') {
        aiRenderCardsInPanel(uid, panel);
      } else if (_isEChart && panel.chartConfig && panel.chartType !== 'table') {
        requestAnimationFrame(function() { aiRenderEChart(uid, panel); });
      } else if (panel.chartConfig && panel.chartType !== 'table') {
        requestAnimationFrame(function() {
          var cv = document.getElementById('aiChartCanvas-'+uid);
          if (!cv) { console.warn('[AI] canvas missing for', uid, panel.title); return; }
          try {
            var cfg = JSON.parse(JSON.stringify(panel.chartConfig));
            cfg.options = cfg.options || {};
            cfg.options.animation = false; cfg.options.responsive = true; cfg.options.maintainAspectRatio = false;
            aiApplyTemplatePalette(cfg, panel.chartType);
            __aiCharts[uid] = new Chart(cv.getContext('2d'), cfg);
            aiSyncPanelColors(uid);
            cv.addEventListener('click', function() { showPanelProperties(uid); });
            // Defensive: chart created in a not-yet-laid-out container will have 0×0 canvas.
            // Force a resize once the layout has settled so it actually paints.
            setTimeout(function(){ try { __aiCharts[uid] && __aiCharts[uid].resize(); } catch(e){} }, 60);
            setTimeout(function(){ try { __aiCharts[uid] && __aiCharts[uid].resize(); } catch(e){} }, 300);
          } catch (chartErr) {
            console.error('[AI] Chart.js render failed for', panel.title, chartErr);
          }
