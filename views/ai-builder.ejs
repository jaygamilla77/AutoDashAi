  // ── Export Functions ──────────────────────────────────────────────────────
  window.aiExportPNG = function() {
    // Try to find the focused/selected panel first; fall back to full canvas
    var uid = window.__selectedPanelUid;
    if (uid && __aiECharts[uid]) {
      var url = __aiECharts[uid].getDataURL({ type: 'png', backgroundColor: '#fff', pixelRatio: 2 });
      var a = document.createElement('a'); a.href = url;
      a.download = 'panel-' + uid + '.png'; a.click(); return;
    }
    if (uid && __aiCharts[uid]) {
      var canvas = document.getElementById('aiChartCanvas-' + uid);
      if (canvas) {
        var a2 = document.createElement('a'); a2.href = canvas.toDataURL('image/png');
        a2.download = 'panel-' + uid + '.png'; a2.click(); return;
      }
    }
    // Full canvas export
    var bar = document.getElementById('aiExportBar');
    if (bar) bar.style.display = 'none';
    html2canvas(document.getElementById('aiPanelGrid'), { backgroundColor: '#e8eef5', scale: 1.5 }).then(function(c) {
      if (bar) bar.style.display = '';
      var a3 = document.createElement('a'); a3.href = c.toDataURL('image/png');
      a3.download = 'dashboard.png'; a3.click();
    }).catch(function(e) { if (bar) bar.style.display = ''; alert('PNG export failed: ' + e.message); });
  };

  window.aiExportPDF = function() {
    var bar = document.getElementById('aiExportBar');
    if (bar) bar.style.display = 'none';
    html2canvas(document.getElementById('aiPanelGrid'), { backgroundColor: '#e8eef5', scale: 1.5 }).then(function(c) {
      if (bar) bar.style.display = '';
      var imgData = c.toDataURL('image/png');
      var pdf = new window.jspdf.jsPDF({ orientation: c.width > c.height ? 'landscape' : 'portrait', unit: 'px', format: [c.width, c.height] });
      pdf.addImage(imgData, 'PNG', 0, 0, c.width, c.height);
      pdf.save('dashboard.pdf');
    }).catch(function(e) { if (bar) bar.style.display = ''; alert('PDF export failed: ' + e.message); });
  };

  window.aiExportExcel = function() {
    if (!window.XLSX) { alert('Excel export library not loaded.'); return; }
    var wb = XLSX.utils.book_new();
    var exported = 0;
    Object.keys(__aiPanelData).forEach(function(uid) {
      var p = __aiPanelData[uid];
      if (!p || !p.hasData) return;
      var rows = [];
      if (p.tableData && p.tableData.columns && p.tableData.rows && p.tableData.rows.length) {
        rows.push(p.tableData.columns);
        p.tableData.rows.forEach(function(r) { rows.push(p.tableData.columns.map(function(c){ return r[c] != null ? r[c] : ''; })); });
      } else if (p.labels && p.labels.length) {
        rows.push(['Label', 'Value']);
        p.labels.forEach(function(l, i) { rows.push([l, p.values ? (p.values[i] || 0) : 0]); });
      }
      if (!rows.length) return;
      var sheetName = (p.title || uid).toString().slice(0,31).replace(/[\\\/\?\*\[\]]/g,'');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), sheetName || ('Sheet'+(++exported)));
      exported++;
    });
    if (!exported) { alert('No data panels to export.'); return; }
    XLSX.writeFile(wb, 'dashboard-data.xlsx');
  };

