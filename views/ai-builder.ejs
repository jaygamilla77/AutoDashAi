  function aiGetTemplatePalette() {
    var sel = document.getElementById('aiTemplateSel');
    if (!sel) return null;
    var opt = sel.options[sel.selectedIndex];
    var raw = opt ? opt.getAttribute('data-palette') : null;
    if (!raw) return null;
    try { var p = JSON.parse(raw); return (p && p.length >= 2) ? p : null; } catch(e) { return null; }
  }

  /* Write palette-applied colours back into the panel data so they survive save */
  function aiSyncPanelColors(uid) {
    var panel = __aiPanelData[uid]; if (!panel) return;
    var chart = __aiCharts[uid]; if (!chart || !chart.data || !chart.data.datasets || !chart.data.datasets[0]) return;
    var ds = chart.data.datasets[0];
    var bg = ds.backgroundColor;
    var bd = ds.borderColor;
    panel.bgColors = Array.isArray(bg) ? bg.slice() : [bg];
    panel.borderColors = Array.isArray(bd) ? bd.slice() : [bd];
    // Also update the chartConfig so dashboard-multi.ejs picks up the correct colors
    if (panel.chartConfig && panel.chartConfig.data && panel.chartConfig.data.datasets && panel.chartConfig.data.datasets[0]) {
      panel.chartConfig.data.datasets[0].backgroundColor = panel.bgColors;
      panel.chartConfig.data.datasets[0].borderColor = panel.borderColors;
    }
    // Also update the matching queue item
    for (var i = 0; i < __aiQueue.length; i++) {
      if (__aiQueue[i]._uid === uid) {
        __aiQueue[i].bgColors = panel.bgColors;
        __aiQueue[i].borderColors = panel.borderColors;
        if (__aiQueue[i].chartConfig && __aiQueue[i].chartConfig.data && __aiQueue[i].chartConfig.data.datasets && __aiQueue[i].chartConfig.data.datasets[0]) {
          __aiQueue[i].chartConfig.data.datasets[0].backgroundColor = panel.bgColors;
          __aiQueue[i].chartConfig.data.datasets[0].borderColor = panel.borderColors;
        }
        break;
      }
    }
  }

  function aiApplyTemplatePalette(cfg, chartType) {
    var pal = aiGetTemplatePalette();
    if (!pal || !cfg.data || !cfg.data.datasets) return cfg;
    var type = (chartType || cfg.type || 'bar').toLowerCase();
    if (type === 'bar') {
      var barColors = (cfg.data.labels || []).map(function(_, i) { return pal[i % pal.length]; });
      cfg.data.datasets.forEach(function(ds) {
        ds.backgroundColor = barColors.length ? barColors : pal;
        ds.borderColor = 'transparent';
        ds.borderWidth = 0;
        ds.borderRadius = 4;
      });
    } else if (type === 'line') {
      cfg.data.datasets.forEach(function(ds, i) {
        ds.borderColor = pal[i % pal.length];
