        '<span style="flex:1;font-size:0.72rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + _aiEsc(p.originalPrompt||p.title||'Panel') + '">' + _aiEsc(p.originalPrompt||p.title||'Panel') + '</span>' +
        '<button type="button" style="background:none;border:none;color:#ef4444;padding:0;cursor:pointer;font-size:0.72rem;flex-shrink:0" onclick="aiRemoveFromQueue(' + idx + ')"><i class="bi bi-x-lg"></i></button>';
      listEl.appendChild(row);
