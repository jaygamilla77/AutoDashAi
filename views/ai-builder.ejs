        '<div style="font-size:1.5rem;font-weight:700;color:'+color+';line-height:1.1;letter-spacing:-0.5px">'+_aiEsc(String(dv))+'</div>' +
        '<div style="font-size:0.68rem;color:#6b7280;margin-top:6px;text-transform:uppercase;letter-spacing:0.6px;word-break:break-word">'+_aiEsc(String(lbl))+'</div></div>';
    }).join('');
    // Sync card palette colors back to panel data
