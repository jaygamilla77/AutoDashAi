          : '';
        var pwdBadge = s.hasPassword ? '<span class="badge bg-info ms-1"><i class="bi bi-lock-fill"></i></span>' : '';
        html += '<div class="list-group-item">' +
          '<div class="d-flex align-items-center mb-1">' +
            statusBadge + expBadge + pwdBadge +
            '<small class="text-muted ms-auto">' + new Date(s.createdAt).toLocaleString() + '</small>' +
          '</div>' +
          '<div class="d-flex align-items-center gap-2">' +
            '<input class="form-control form-control-sm" readonly value="' + s.shareUrl + '" style="font-size:0.72rem">' +
            '<button class="btn btn-sm btn-outline-primary" title="Copy" onclick="navigator.clipboard.writeText(\'' + s.shareUrl + '\').then(function(){this.innerHTML=\'<i class=&quot;bi bi-check&quot;></i>\';}.bind(this))"><i class="bi bi-clipboard"></i></button>' +
            (s.isActive
              ? '<button class="btn btn-sm btn-outline-warning" title="Revoke" onclick="aiRevokeShare(' + s.id + ')"><i class="bi bi-slash-circle"></i></button>'
              : '<button class="btn btn-sm btn-outline-success" title="Regenerate" onclick="aiRegenerateShare(' + s.id + ')"><i class="bi bi-arrow-repeat"></i></button>') +
          '</div>' +
          '<div class="text-muted mt-1" style="font-size:0.7rem">' +
            '<i class="bi bi-eye me-1"></i>' + s.viewCount + ' views · ' +
            '<i class="bi bi-key me-1"></i>' + s.permissionType +
          '</div>' +
        '</div>';
      });
      html += '</div>';
      listEl.innerHTML = html;
    });
  };

