    box.innerHTML = '<div style="font-family:\''+font+'\',sans-serif">'
      // Window chrome
      + '<div style="background:#1e1e1e;padding:5px 8px;display:flex;align-items:center;gap:5px">'
      +   '<div style="width:6px;height:6px;border-radius:50%;background:#ff5f57"></div>'
      +   '<div style="width:6px;height:6px;border-radius:50%;background:#febc2e"></div>'
      +   '<div style="width:6px;height:6px;border-radius:50%;background:#28c840"></div>'
      +   '<span style="font-size:0.38rem;color:#aaa;margin-left:5px;letter-spacing:0.5px">'+_aiEsc(opt.text)+'</span>'
      + '</div>'
      // Toolbar
      + '<div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:4px 7px;display:flex;gap:5px;align-items:center">'
      +   '<div style="width:32px;height:4px;background:#e5e7eb;border-radius:2px"></div>'
      +   '<div style="width:32px;height:4px;background:#e5e7eb;border-radius:2px"></div>'
      +   '<div style="flex:1"></div>'
      +   '<div style="width:18px;height:9px;background:'+(palette[0]||accent)+';border-radius:2px;opacity:0.85"></div>'
      +   '<div style="width:18px;height:9px;background:'+(palette[1]||accent)+';border-radius:2px;opacity:0.85"></div>'
      + '</div>'
      // KPI cards
      + '<div style="background:#f0f2f5;padding:6px 7px 3px">'
      +   '<div style="display:flex;gap:4px">'+kpiHtml+'</div>'
      + '</div>'
      // Charts row
      + '<div style="background:#f0f2f5;display:flex;gap:4px;padding:3px 7px">'
      +   '<div style="flex:2;background:#fff;border-radius:3px;padding:4px 5px;border:1px solid #e5e7eb">'
      +     '<div style="font-size:0.28rem;color:#9ca3af;margin-bottom:2px;text-transform:uppercase;letter-spacing:0.3px">Trend</div>'
      +     '<div style="display:flex;align-items:flex-end;gap:1px;height:36px">'+barsHtml+'</div>'
      +   '</div>'
      +   '<div style="flex:1;background:#fff;border-radius:3px;padding:4px 5px;border:1px solid #e5e7eb;display:flex;flex-direction:column;align-items:center">'
      +     '<div style="font-size:0.28rem;color:#9ca3af;margin-bottom:3px;text-transform:uppercase;letter-spacing:0.3px;align-self:flex-start">Split</div>'
      +     '<div style="width:34px;height:34px;border-radius:50%;background:conic-gradient('+conic+');position:relative;flex-shrink:0">'
      +       '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:16px;height:16px;border-radius:50%;background:#fff"></div>'
