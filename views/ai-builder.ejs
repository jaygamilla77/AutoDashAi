      if (!data.shares || !data.shares.length) {
        listEl.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:1.6rem;opacity:0.4;display:block;margin-bottom:6px"></i>No share links yet.</div>';
