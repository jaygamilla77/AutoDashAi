  // ── Preview / Add / Remove ────────────────────────────────────────────────
  window.aiPreviewPanel = function() {
    var prompt = ((document.getElementById('aiPromptTextarea')||{}).value||'').trim();
    if (!prompt) {
      var ta = document.getElementById('aiPromptTextarea');
      if (ta) { ta.focus(); ta.classList.add('is-invalid'); setTimeout(function(){ ta.classList.remove('is-invalid'); }, 1200); }
      return;
    }
    var chartType = (document.getElementById('aiChartTypeSel')||{}).value || 'auto';
    var sourceId  = (document.getElementById('aiSourceSel')||{}).value || '';
    var btn = document.getElementById('aiPreviewBtn');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Loading...'; }
    fetch('/dashboard/generate-panel', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt: prompt, chartType: chartType, dataSourceId: sourceId || null }),
    })
    .then(function(r){ return r.json(); })
    .then(function(panel) {
      if (panel.error) { alert('Error: ' + panel.error); return; }
      __aiPreview = panel;
      aiRenderPanelOnCanvas(panel, true);
    })
    .catch(function(err){ alert('Request failed: ' + err.message); })
    .finally(function(){ if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview on Canvas'; } });
  };

  window.aiClearPreview = function() {
    var old = document.getElementById('aiCard-ai-staging');
    if (old) {
      if (__aiCharts['ai-staging']) { __aiCharts['ai-staging'].destroy(); delete __aiCharts['ai-staging']; }
      if (__aiECharts['ai-staging']) { __aiECharts['ai-staging'].dispose(); delete __aiECharts['ai-staging']; }
      old.remove();
    }
    __aiPreview = null; aiUpdateEmptyState();
  };

  window.aiAddToQueue = function() {
    if (__aiPreview) aiAddPreviewToQueue();
    else aiPreviewPanel();
  };

  window.aiAddPreviewToQueue = function() {
    if (!__aiPreview) return;
    var panel = JSON.parse(JSON.stringify(__aiPreview));
    var old = document.getElementById('aiCard-ai-staging');
    if (old) { if (__aiCharts['ai-staging']) { __aiCharts['ai-staging'].destroy(); delete __aiCharts['ai-staging']; } old.remove(); }
    __aiPreview = null;
    aiRenderPanelOnCanvas(panel, false);
    __aiQueue.push(panel);
    aiRenderQueueList(); aiUpdateEmptyState();
  };

  window.aiRemoveCanvasPanel = function(uid) {
    if (__aiCharts[uid]) { __aiCharts[uid].destroy(); delete __aiCharts[uid]; }
    if (__aiECharts[uid]) { __aiECharts[uid].dispose(); delete __aiECharts[uid]; }
    delete __aiPanelData[uid];
    var card = document.getElementById('aiCard-' + uid); if (card) card.remove();
    for (var i = __aiQueue.length - 1; i >= 0; i--) { if (__aiQueue[i]._uid === uid) __aiQueue.splice(i, 1); }
    if (typeof window.aiCleanupEmptySections === 'function') window.aiCleanupEmptySections();
    // Clear properties if this was the selected panel
    if (__selectedPanelUid === uid) {
      __selectedPanelUid = null;
      var content = document.getElementById('aiPropertiesContent');
      if (content) {
        content.innerHTML = '<div style="text-align:center;padding:20px 0;color:#9ca3af">' +
          '<i class="bi bi-click" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.3"></i>' +
          'Click a chart or card on the canvas to view its properties.' +
        '</div>';
      }
      switchAiSettingsTab('settings');
    }
    aiRenderQueueList(); aiUpdateEmptyState();
  };

  // ── Save ──────────────────────────────────────────────────────────────────
  var __aiKpiData = [];
  var __aiExecSummary = '';

  window.submitAiDashboard = function() {
    if (!__aiQueue.length) { alert('Add at least one panel to the dashboard first.'); return; }
    // Force-sync all chart colors to panel data before serializing
    Object.keys(__aiCharts).forEach(function(uid) { aiSyncPanelColors(uid); });
    
    // Capture panel positions from DOM before saving
    __aiQueue.forEach(function(panel) {
      var card = document.getElementById('aiCard-' + panel._uid);
      if (card) {
        panel.position = {
          left: parseInt(card.style.left) || 0,
          top: parseInt(card.style.top) || 0
        };
      }
    });

    // Normalize section field on panels before saving
    __aiQueue.forEach(function(p) { p.section = p._section || p.section || null; });

    var meta = window.__aiExecutiveMeta || {};
    var isExec = !!(meta && meta.dashboardType === 'executive');

    // Executive Dashboards skip the legacy dashboard-multi intermediate page
    // and save directly via AJAX, then jump straight to the canvas renderer.
    // This is what guarantees pixel-consistent save → reopen behaviour.
    if (isExec) {
      var btn = document.getElementById('aiGenerateBtn');
      var origHTML = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving…'; }

      var sourceId = (document.getElementById('aiSourceSel') || {}).value || '';
      var promptText = (document.getElementById('aiPromptTextarea') || {}).value || '';

      var fullConfig = {
        panels: __aiQueue,
        kpiData: __aiKpiData,
        executiveSummary: __aiExecSummary || meta.executiveSummary || window.__aiExecSummaryStash || '',
        palette: aiGetTemplatePalette() || [],
        templateId: (document.getElementById('aiTemplateSel') || {}).value || null,
        dashboardType:     meta.dashboardType     || 'executive',
        dashboardRole:     meta.dashboardRole     || null,
        dashboardSubtitle: meta.dashboardSubtitle || null,
        anomalyAlert:      meta.anomalyAlert      || null,
        layoutHint:        meta.layoutHint        || null,
        sections:          meta.sections          || [],
        // ── AI intelligence is first-class dashboard content. Persist it
        //    alongside panels so save → reopen renders pixel-identical.
        insights:          meta.insights          || window.__aiInsightsStash       || [],
        recommendations:   meta.recommendations   || window.__aiRecommendationsStash || [],
        renderMode:        'executive-layout',
        dashboardVersion:  'v2',
        schemaVersion:     meta.schemaVersion     || 'executive-dashboard-v1',
        generatedAt:       meta.generatedAt       || new Date().toISOString(),
      };

      fetch('/dashboard/save-direct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: meta.dashboardRole || 'Executive Dashboard',
          promptText: promptText,
          dashboardConfig: fullConfig,
          dataSourceId: sourceId || null,
        }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data && data.error) { alert('Save failed: ' + data.error); return; }
        if (data && data.redirectUrl) {
          window.location.href = data.redirectUrl;
        } else {
          alert('Save failed: unexpected server response');
        }
      })
      .catch(function(err) {
        alert('Save failed: ' + (err.message || err));
      })
      .finally(function() {
        if (btn) { btn.disabled = false; btn.innerHTML = origHTML; }
      });
      return;
    }

    // Non-executive (manual) panels keep the legacy form-submit flow
    document.getElementById('aiPanelsJson').value = JSON.stringify(__aiQueue);
    document.getElementById('aiKpiDataJson').value = JSON.stringify(__aiKpiData);
    document.getElementById('aiExecSummary').value = __aiExecSummary;
    document.getElementById('aiPaletteJson').value = JSON.stringify(aiGetTemplatePalette() || []);
    document.getElementById('aiExecutiveMetaJson').value = '';
    document.getElementById('aiGenerateForm').submit();
  };

  window.submitAiChanges = function() {
    if (!__aiQueue.length) { alert('Add at least one panel to the dashboard first.'); return; }
    if (!window.__editingDashboardId) { alert('Dashboard ID not found.'); return; }
    
    // Force-sync all chart colors to panel data before serializing
    Object.keys(__aiCharts).forEach(function(uid) { aiSyncPanelColors(uid); });
    
    // Capture panel positions from DOM before saving
    __aiQueue.forEach(function(panel) {
      var card = document.getElementById('aiCard-' + panel._uid);
      if (card) {
        panel.position = {
          left: parseInt(card.style.left) || 0,
          top: parseInt(card.style.top) || 0
        };
      }
    });

    // Normalize section field on panels before saving
    __aiQueue.forEach(function(p) { p.section = p._section || p.section || null; });

    // Prepare config object with all dashboard data (including executive metadata)
    var meta = window.__aiExecutiveMeta || {};
    var configObj = {
      panels: __aiQueue,
      kpiData: __aiKpiData,
      executiveSummary: __aiExecSummary || meta.executiveSummary || '',
      palette: aiGetTemplatePalette() || [],
      dashboardType: meta.dashboardType || null,
      dashboardRole: meta.dashboardRole || null,
      dashboardSubtitle: meta.dashboardSubtitle || null,
      anomalyAlert: meta.anomalyAlert || null,
      layoutHint: meta.layoutHint || null,
      sections: meta.sections || [],
      // ── AI intelligence — first-class, persisted with the dashboard.
      insights:        meta.insights        || window.__aiInsightsStash       || [],
      recommendations: meta.recommendations || window.__aiRecommendationsStash || [],
      schemaVersion: meta.schemaVersion || null,
    };
    
    document.getElementById('aiUpdatePanelsJson').value = JSON.stringify(configObj);
    document.getElementById('aiUpdateTitle').value = document.querySelector('[id="aiPromptPanel"] .border-bottom span')?.textContent || 'Dashboard';
    document.getElementById('aiUpdatePromptText').value = document.getElementById('aiPrompt')?.value || '';
    
    var form = document.getElementById('aiUpdateForm');
    form.action = '/dashboard/' + window.__editingDashboardId + '/update';
    form.submit();
  };

  window.submitAiFullDashboard = function() {
    var sourceId = (document.getElementById('aiSourceSel') || {}).value || '';

    var btn = document.getElementById('aiFullDashBtn');
    var origHTML = btn ? btn.innerHTML : '';
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" style="width:0.75rem;height:0.75rem"></span>Generating…';
    }

    var gridEl = document.getElementById('aiPanelGrid');
    aiClearQueue();
    ['aiFullDashSummary','aiFullDashKpiStrip','aiFullDashHeader','aiFullDashAlert','aiFullDashSections'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.remove();
    });

    if (!document.getElementById('aiPulseStyle')) {
      var sty = document.createElement('style');
      sty.id = 'aiPulseStyle';
      sty.textContent = '@keyframes aiPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.08);opacity:0.85}} @keyframes aiSlideIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}';
      document.head.appendChild(sty);
    }

    var loadingOverlay = document.createElement('div');
    loadingOverlay.id = 'aiFullDashLoading';
    loadingOverlay.style.cssText = 'position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(135deg,#f8f9ff 0%,#f0f4ff 100%);z-index:10;gap:16px';
    loadingOverlay.innerHTML =
      '<div style="width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(99,102,241,0.35);animation:aiPulse 1.6s ease-in-out infinite">' +
        '<i class="bi bi-stars" style="font-size:1.6rem;color:#fff"></i>' +
      '</div>' +
      '<div style="text-align:center">' +
        '<div style="font-size:1rem;font-weight:700;color:#312e81;margin-bottom:4px">Building Your Executive Dashboard</div>' +
        '<div id="aiLoadStatusMsg" style="font-size:0.78rem;color:#6b7280;max-width:300px;line-height:1.5">AI is analysing your data…</div>' +
      '</div>' +
      '<div style="width:260px;background:#e5e7eb;border-radius:999px;height:6px;overflow:hidden">' +
        '<div id="aiLoadBar" style="height:100%;width:0%;background:linear-gradient(90deg,#6366f1,#8b5cf6);border-radius:999px;transition:width 1.2s ease"></div>' +
      '</div>' +
      '<div style="display:flex;gap:8px;margin-top:4px;flex-wrap:wrap;justify-content:center">' +
        '<span id="aiLoadStep1" style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:#e0e7ff;color:#4338ca;font-weight:600"><i class="bi bi-database me-1"></i>Querying data</span>' +
        '<span id="aiLoadStep2" style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:#f3f4f6;color:#9ca3af;font-weight:600"><i class="bi bi-cpu me-1"></i>AI curation</span>' +
        '<span id="aiLoadStep3" style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:#f3f4f6;color:#9ca3af;font-weight:600"><i class="bi bi-graph-up me-1"></i>Insights</span>' +
        '<span id="aiLoadStep4" style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:#f3f4f6;color:#9ca3af;font-weight:600"><i class="bi bi-layout-wtf me-1"></i>Layout</span>' +
      '</div>';
    gridEl.style.position = 'relative';
    gridEl.appendChild(loadingOverlay);

    // Animate progress bar and step labels over ~30s
    var _loadSteps = [
      { ms: 300,   pct: 8,  step: null,  msg: 'Querying your data sources…' },
      { ms: 2000,  pct: 20, step: 2,     msg: 'AI is selecting the best visuals…' },
      { ms: 6000,  pct: 38, step: null,  msg: 'Ranking panels by business impact…' },
      { ms: 11000, pct: 55, step: 3,     msg: 'Generating KPI cards and insights…' },
      { ms: 17000, pct: 70, step: null,  msg: 'Writing executive analysis…' },
      { ms: 22000, pct: 82, step: 4,     msg: 'Composing dashboard layout…' },
      { ms: 27000, pct: 92, step: null,  msg: 'Almost there — finalising…' },
    ];
    function _activateStep(n) {
      var el = document.getElementById('aiLoadStep'+n);
      if (el) { el.style.background='#e0e7ff'; el.style.color='#4338ca'; }
    }
    _loadSteps.forEach(function(s) {
      setTimeout(function() {
        var bar = document.getElementById('aiLoadBar');
        var msg = document.getElementById('aiLoadStatusMsg');
        if (bar) bar.style.width = s.pct + '%';
        if (msg) msg.textContent = s.msg;
        if (s.step) _activateStep(s.step);
      }, s.ms);
    });

    fetch('/dashboard/full', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sourceId: sourceId }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var ov = document.getElementById('aiFullDashLoading'); if (ov) ov.remove();
      if (data.error) { alert(data.error); return; }
      var panels = data.panels || [];
      if (!panels.length) { _aiRenderEmptyDashState(gridEl, data); return; }

      // Store executive metadata globally for save/reload
      window.__aiExecutiveMeta = {
        dashboardType: 'executive',
        dashboardRole: data.dashboardRole || null,
        dashboardSubtitle: data.dashboardSubtitle || null,
        anomalyAlert: data.anomalyAlert || null,
        layoutHint: data.layoutHint || null,
        sections: data.sections || [],
        schemaVersion: 'executive-dashboard-v1',
        generatedAt: new Date().toISOString(),
      };
      // Normalize _section → section on each panel so it survives serialization
      panels.forEach(function(p) { p.section = p._section || p.section || 'Performance Overview'; });

      _aiExecutiveDashboardRender(data, gridEl);
    })
    .catch(function(err) {
      var ov = document.getElementById('aiFullDashLoading'); if (ov) ov.remove();
      var msg = err.message || String(err);
      if (msg.toLowerCase().includes('failed to fetch') || msg.toLowerCase().includes('networkerror') || msg.toLowerCase().includes('connection refused')) {
        alert('Could not reach the server. Please make sure the server is running (npm start) and try again.');
      } else {
        alert('Executive Dashboard error: ' + msg);
      }
    })
    .finally(function() {
      if (btn) { btn.disabled = false; btn.innerHTML = origHTML; }
    });
  };

  // ── Shared executive dashboard renderer ──────────────────────────────────────
  // Called both from the AJAX response handler and from _aiRestoreExecutiveDashboard
  function _aiExecutiveDashboardRender(data, gridEl) {
      var panels = data.panels || [];
      var canvasEl = document.getElementById('aiCanvas');
      var canvasW  = canvasEl ? canvasEl.clientWidth : 960;
      var gap = 14;

      // 1. Dashboard header bar
      var headerDiv = document.createElement('div');
      headerDiv.id = 'aiFullDashHeader';
      headerDiv.style.cssText = 'background:linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4338ca 100%);padding:18px 20px 14px;margin-bottom:4px;position:relative;overflow:hidden';
      var roleText = _aiEsc(data.dashboardRole || 'Executive Dashboard');
      var subtitleText = _aiEsc(data.dashboardSubtitle || 'AI-Generated Overview');
      headerDiv.innerHTML =
        '<div style="position:absolute;top:-20px;right:-20px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,0.05)"></div>' +
        '<div style="position:absolute;bottom:-30px;right:60px;width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,0.04)"></div>' +
        '<div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:10px;position:relative">' +
          '<div>' +
            '<div style="font-size:0.62rem;font-weight:700;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px"><i class="bi bi-stars me-1"></i>AI Executive Dashboard</div>' +
            '<div style="font-size:1.2rem;font-weight:800;color:#fff;margin-bottom:3px">' + roleText + '</div>' +
            '<div style="font-size:0.72rem;color:rgba(255,255,255,0.6)">' + subtitleText + ' · Generated ' + new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) + '</div>' +
          '</div>' +
          '<div style="display:flex;gap:6px;align-items:center">' +
            '<span style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-weight:600"><i class="bi bi-cpu me-1"></i>AI-Curated</span>' +
            '<span style="font-size:0.65rem;padding:3px 10px;border-radius:12px;background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-weight:600"><i class="bi bi-layout-wtf me-1"></i>' + panels.filter(function(p){return p.chartType!=='table';}).length + ' Charts</span>' +
          '</div>' +
        '</div>';
      gridEl.insertBefore(headerDiv, gridEl.firstChild);

      // 2. Anomaly alert banner
      if (data.anomalyAlert) {
        var alertDiv = document.createElement('div');
        alertDiv.id = 'aiFullDashAlert';
        alertDiv.style.cssText = 'display:flex;align-items:center;gap:10px;padding:9px 14px;background:linear-gradient(90deg,#fff7ed,#fef3c7);border-left:3px solid #f59e0b;font-size:0.74rem;color:#92400e;animation:aiSlideIn 0.4s ease';
        alertDiv.innerHTML =
          '<i class="bi bi-exclamation-triangle-fill" style="color:#f59e0b;font-size:1rem;flex-shrink:0"></i>' +
          '<div><strong style="color:#78350f">AI Alert:</strong> ' + _aiEsc(data.anomalyAlert) + '</div>' +
          '<button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;color:#92400e;cursor:pointer;font-size:1rem;line-height:1;padding:0" title="Dismiss">&times;</button>';
        gridEl.insertBefore(alertDiv, gridEl.childNodes[1] || null);
      }

      // 3. Premium KPI strip
      var kpiData = data.kpiData || [];
      __aiKpiData = kpiData;
      if (kpiData.length > 0) {
        var kpiDiv = document.createElement('div');
        kpiDiv.id = 'aiFullDashKpiStrip';
        kpiDiv.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;padding:12px 14px;background:#f8f9ff;border-bottom:1px solid #e5e7eb';
        kpiData.forEach(function(kpi, ki) {
          var color = kpi.color || ['#3b82f6','#6366f1','#22c55e','#f59e0b','#ef4444','#8b5cf6'][ki % 6];
          var trendColor = kpi.trendDirection === 'up' ? '#22c55e' : kpi.trendDirection === 'down' ? '#ef4444' : '#6b7280';
          if (kpi.status === 'danger') trendColor = '#ef4444';
          if (kpi.status === 'warning') trendColor = '#f59e0b';
          var trendIcon = kpi.trendDirection === 'up' ? 'bi-arrow-up-short' : kpi.trendDirection === 'down' ? 'bi-arrow-down-short' : 'bi-dash';
          var kpiUid = 'kpi-' + ki;
          __aiPanelData[kpiUid] = {
            _uid: kpiUid, chartType: 'kpi', title: kpi.label || 'KPI', hasData: true,
            labels: [kpi.label || 'KPI'], values: [kpi.value || '0'],
            kpiLabel: kpi.label, kpiValue: kpi.value, kpiTrend: kpi.trend,
            kpiIcon: kpi.icon, kpiSubtitle: kpi.subtitle, kpiSource: kpi.source,
            structuredRequest: kpi.structuredRequest || null,
            dataSourceId: kpi.dataSourceId || null,
            dataConfig: kpi.dataConfig || null,
          };
          var kpiCard = document.createElement('div');
          kpiCard.style.cssText = 'background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:14px 16px;border-top:3px solid '+color+';box-shadow:0 1px 4px rgba(0,0,0,0.04);cursor:pointer;transition:all 0.18s;animation:aiSlideIn 0.3s ease '+(ki*0.06)+'s both';
          kpiCard.innerHTML =
            '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">' +
              '<div style="width:32px;height:32px;border-radius:8px;background:'+color+'18;display:flex;align-items:center;justify-content:center">' +
                '<i class="bi '+(kpi.icon||'bi-bar-chart-fill')+'" style="font-size:1rem;color:'+color+'"></i>' +
              '</div>' +
              (kpi.trend ? '<div style="font-size:0.68rem;font-weight:700;color:'+trendColor+';display:flex;align-items:center;gap:1px;padding:2px 6px;border-radius:8px;background:'+trendColor+'18"><i class="bi '+trendIcon+'"></i>'+_aiEsc(kpi.trend)+'</div>' : '') +
            '</div>' +
            '<div style="font-size:1.6rem;font-weight:800;color:#111827;line-height:1;margin-bottom:4px">'+_aiEsc(kpi.value||'—')+'</div>' +
            '<div style="font-size:0.65rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;line-height:1.3">'+_aiEsc(kpi.label||'')+'</div>' +
            (kpi.subtitle ? '<div style="font-size:0.6rem;color:#9ca3af;margin-top:3px">'+_aiEsc(kpi.subtitle)+'</div>' : '');
          kpiCard.addEventListener('mouseover', function() { this.style.boxShadow='0 6px 20px rgba(0,0,0,0.1)'; this.style.transform='translateY(-3px)'; });
