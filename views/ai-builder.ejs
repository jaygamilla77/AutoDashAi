  // IMPORTANT: Advanced tab renderer is resolved from window.aiPropRenderAdvanced so
  // we can provide a guided query builder without changing the dashboard flow.
  // We keep a minimal default implementation as a fallback.
  window.aiPropRenderAdvanced = function(uid, panel, state) {
    var sr = state.editSR;
    var h = '';
    var hist = state.history || [];
    h += '<div style="margin-bottom:12px"><div style="font-size:0.62rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:5px"><i class="bi bi-clock-history me-1"></i>Edit History</div>';
    if (!hist.length) {
      h += '<div style="font-size:0.72rem;color:#9ca3af;background:#f9fafb;border:1px dashed #e5e7eb;border-radius:6px;padding:9px;text-align:center"><i class="bi bi-clock" style="display:block;font-size:1.2rem;opacity:0.3;margin-bottom:4px"></i>No edits yet. History will appear here so you can undo changes.</div>';
    } else {
      hist.slice().reverse().forEach(function(v, ri) {
        var realIdx = hist.length - 1 - ri;
        h += '<div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:5px;padding:6px 8px;margin-bottom:4px;display:flex;align-items:center;justify-content:space-between">';
        h += '<div><div style="font-size:0.7rem;font-weight:600;color:#374151">Version ' + (realIdx + 1) + '</div><div style="font-size:0.6rem;color:#9ca3af">' + _aiEsc(v.ts) + '</div></div>';
        h += '<button onclick="aiPropUndo(\'' + uid + '\',' + realIdx + ')" class="btn btn-sm" style="font-size:0.62rem;padding:2px 6px;background:#fff;border:1px solid #d1d5db;color:#6b7280">Restore</button>';
        h += '</div>';
      });
    }
    h += '</div>';
    h += '<details style="margin-bottom:12px"><summary style="font-size:0.7rem;font-weight:600;color:#6b7280;cursor:pointer;padding:6px 8px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;list-style:none"><i class="bi bi-code-square me-1"></i>Show Technical Details</summary>';
    h += '<div style="background:#f3f4f6;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 6px 6px;padding:8px">';
    h += '<div style="font-size:0.62rem;font-weight:700;color:#6b7280;margin-bottom:3px">Structured Query:</div>';
    h += '<pre style="font-size:0.6rem;color:#374151;margin:0;overflow:auto;max-height:130px;white-space:pre-wrap;line-height:1.5">' + _aiEsc(JSON.stringify(sr, null, 2)) + '</pre></div></details>';
    if (panel.labels && panel.labels.length) {
      h += '<details style="margin-bottom:12px"><summary style="font-size:0.7rem;font-weight:600;color:#6b7280;cursor:pointer;padding:6px 8px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;list-style:none"><i class="bi bi-table me-1"></i>Data Preview (' + panel.labels.length + ' rows)</summary>';
      h += '<div style="border:1px solid #e5e7eb;border-top:none;border-radius:0 0 6px 6px;overflow:auto;max-height:150px">';
      h += '<table style="width:100%;border-collapse:collapse;font-size:0.65rem"><thead><tr>';
      h += '<th style="padding:4px 7px;background:#f8fafc;border-bottom:1px solid #e5e7eb;text-align:left;color:#374151;position:sticky;top:0">Label</th>';
      h += '<th style="padding:4px 7px;background:#f8fafc;border-bottom:1px solid #e5e7eb;text-align:right;color:#374151;position:sticky;top:0">Value</th></tr></thead><tbody>';
      var maxR = Math.min(25, panel.labels.length);
      for (var ri2 = 0; ri2 < maxR; ri2++) {
        h += '<tr style="border-bottom:1px solid #f3f4f6"><td style="padding:3px 7px;color:#374151">' + _aiEsc(String(panel.labels[ri2] || '-')) + '</td>';
        h += '<td style="padding:3px 7px;color:#6b7280;text-align:right;font-weight:600">' + (panel.values && panel.values[ri2] != null ? Number(panel.values[ri2]).toLocaleString() : '-') + '</td></tr>';
      }
      if (panel.labels.length > maxR) h += '<tr><td colspan="2" style="padding:4px 7px;color:#9ca3af;text-align:center;font-style:italic">+' + (panel.labels.length - maxR) + ' more rows</td></tr>';
      h += '</tbody></table></div></details>';
    }
    h += '<div style="border:1px solid #fee2e2;border-radius:6px;padding:9px;background:#fff5f5">';
    h += '<div style="font-size:0.62rem;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:5px"><i class="bi bi-exclamation-triangle me-1"></i>Remove Panel</div>';
    h += '<button onclick="aiPropConfirmRemove(\'' + uid + '\')" class="btn btn-sm btn-danger w-100" style="font-size:0.72rem"><i class="bi bi-trash me-1"></i>Remove This Panel</button>';
    h += '</div>';
    return h;
  };

  window.showPanelProperties = function(uid) {
    var panel = window.__aiPanelData[uid];
    if (!panel) return;
    __selectedPanelUid = uid;
    // Keep a stable global for other scripts / debugging
    window.selectedPanelId = uid;
    window.selectedPanel = panel;

    // Hydrate structuredRequest from dataConfig for legacy/saved panels when possible.
    // (builder-experience.js also does this for the Data tab, but we do it here so
    // Overview/other tabs get accurate context too.)
    try {
      if (window.BX && typeof window.BX.ensurePanelSR === 'function') {
        window.BX.ensurePanelSR(panel);
      }
      // Ensure every panel carries a dataConfig snapshot when we have enough info.
      if (window.BX && typeof window.BX.rebuildDataConfig === 'function') {
        if (!panel.dataConfig && panel.structuredRequest) window.BX.rebuildDataConfig(panel);
      }
    } catch (e) {}
    var state = aiPropGetState(uid);
    if (!state.dirty) {
      state.editSR = JSON.parse(JSON.stringify(panel.structuredRequest || {}));
      if (!state.origSR || !Object.keys(state.origSR).length)
        state.origSR = JSON.parse(JSON.stringify(panel.structuredRequest || {}));
    }
    var content = document.getElementById('aiPropertiesContent');
    if (!content) return;
    var tabDefs = [
      { id:'overview', icon:'house', label:'Overview' },
      { id:'data', icon:'database', label:'Data' },
      { id:'filters', icon:'funnel', label:'Filters' },
      { id:'chart', icon:'bar-chart', label:'Chart' },
      { id:'advanced', icon:'gear', label:'Advanced' },
    ];
    var fCount = (state.editSR.filters && state.editSR.filters.length) || 0;
    var h = '<div style="font-size:0.75rem;color:#374151">';
    h += '<div style="background:linear-gradient(135deg,#1e1b4b,#312e81);padding:10px 12px;margin-bottom:0">';
    h += '<div style="font-size:0.6rem;color:rgba(255,255,255,0.55);margin-bottom:2px">' + (panel.chartType === 'kpi' ? '<i class="bi bi-123 me-1"></i>KPI CARD' : '<i class="bi bi-bar-chart me-1"></i>CHART PANEL') + '</div>';
    h += '<div style="font-size:0.86rem;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + _aiEsc(panel.title || '') + '">' + _aiEsc(panel.title || 'Untitled Panel') + '</div>';
    h += '<div style="font-size:0.62rem;color:rgba(255,255,255,0.45);margin-top:2px">' + ((panel.labels && panel.labels.length) || 0) + ' rows &middot; ' + _aiEsc(panel.chartType || 'bar') + (fCount ? ' &middot; ' + fCount + ' filter' + (fCount > 1 ? 's' : '') : '') + '</div>';
    h += '</div>';
    h += '<div style="display:flex;background:#f8fafc;border-bottom:1px solid #e5e7eb;margin-bottom:10px">';
    tabDefs.forEach(function(t) {
      var isActive = state.tab === t.id;
      h += '<button onclick="aiPropSwitchTab(\'' + uid + '\',\'' + t.id + '\')" style="flex:1;padding:6px 2px;border:none;border-bottom:2px solid ' + (isActive ? '#6366f1' : 'transparent') + ';background:none;font-size:0.56rem;font-weight:' + (isActive ? '700' : '500') + ';color:' + (isActive ? '#4f46e5' : '#9ca3af') + ';cursor:pointer;text-align:center;line-height:1.3" title="' + t.label + '">';
      h += '<i class="bi bi-' + t.icon + '" style="display:block;font-size:0.82rem;margin-bottom:1px"></i>' + t.label + '</button>';
    });
    h += '</div>';
    h += '<div id="aiPropTabBody-' + uid + '" style="padding:0 2px">';
    if (state.tab === 'overview') h += aiPropRenderOverview(uid, panel, state);
    else if (state.tab === 'data') {
      var dataRenderer = (window && window.aiPropRenderData) ? window.aiPropRenderData : null;
      h += (typeof dataRenderer === 'function') ? dataRenderer(uid, panel, state) : '';
    }
    else if (state.tab === 'filters') h += aiPropRenderFilters(uid, panel, state);
    else if (state.tab === 'chart') h += aiPropRenderChart(uid, panel, state);
    else {
      var advRenderer = (window && window.aiPropRenderAdvanced) ? window.aiPropRenderAdvanced : null;
      h += (typeof advRenderer === 'function') ? advRenderer(uid, panel, state) : '';
    }
    h += '</div></div>';
    content.innerHTML = h;
    switchAiSettingsTab('properties');
  };

  window.aiPropSwitchTab = function(uid, tab) {
    var state = aiPropGetState(uid);
    state.tab = tab;
    showPanelProperties(uid);
  };

  window.aiPropMarkDirty = function(uid) {
    var state = aiPropGetState(uid);
    state.dirty = true;
    var bar = document.getElementById('aiPropApplyBar-' + uid);
    if (bar) { bar.style.opacity = '1'; bar.style.pointerEvents = 'auto'; }
  };

  window.aiPropSaveTitle = function(uid) {
    var el = document.getElementById('aiPropTitle-' + uid);
    if (!el) return;
    var panel = window.__aiPanelData[uid];
    if (!panel) return;
    panel.title = el.value.trim() || panel.title || 'Untitled';
    if (panel.structuredRequest) panel.structuredRequest.title = panel.title;
    var card = document.getElementById('aiCard-' + uid);
    if (card) {
      var spans = card.querySelectorAll('span');
      spans.forEach(function(s) {
        if (parseFloat(window.getComputedStyle(s).fontSize) >= 11 && !/^(PREVIEW|AI)$/.test(s.textContent.trim())) s.textContent = panel.title;
      });
    }
    el.style.borderColor = '#22c55e';
    setTimeout(function() { if (el) el.style.borderColor = ''; }, 1500);
  };

  window.aiPropApply = function(uid) {
    var panel = window.__aiPanelData[uid];
    var state = aiPropGetState(uid);
    if (!panel) return;
    var newSR = JSON.parse(JSON.stringify(state.editSR));
    var focusEl = document.getElementById('aiPropFocus-' + uid);
    var dimEl = document.getElementById('aiPropDim-' + uid);
    var metricEl = document.getElementById('aiPropMetric-' + uid);
    var aggEl = document.getElementById('aiPropAgg-' + uid);
    var limEl = document.getElementById('aiPropLim-' + uid);
    var sortFEl = document.getElementById('aiPropSortField-' + uid);
    var sortDEl = document.getElementById('aiPropSortDir-' + uid);
    var srcEl = document.getElementById('aiPropSource-' + uid);
    if (focusEl) newSR.focusArea = focusEl.value.trim() || newSR.focusArea;
    if (dimEl && dimEl.value.trim()) newSR.dimensions = dimEl.value.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
    if (metricEl && metricEl.value.trim()) newSR.metrics = metricEl.value.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
    if (aggEl) newSR.aggregation = aggEl.value;
    if (limEl) newSR.limit = parseInt(limEl.value, 10) || newSR.limit;
    if (sortFEl) newSR.sort = { field: sortFEl.value.trim(), direction: sortDEl ? sortDEl.value : 'desc' };
    var newDsId = srcEl ? (srcEl.value || null) : panel.dataSourceId;
    state.history.push({ ts: new Date().toLocaleTimeString(), sr: JSON.parse(JSON.stringify(panel.structuredRequest || {})) });
    if (state.history.length > 5) state.history.shift();
    var applyBtn = document.querySelector('#aiPropApplyBar-' + uid + ' button');
    if (applyBtn) { applyBtn.disabled = true; applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Applying...'; }
    fetch('/dashboard/recalculate-panel', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ structuredRequest: newSR, dataSourceId: newDsId }),
    })
    .then(function(r) { return r.json(); })
    .then(function(updated) {
      if (updated.error) { alert('Could not apply changes: ' + updated.error); return; }
      if (window.__aiCharts[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
      if (window.__aiECharts[uid]) { window.__aiECharts[uid].dispose(); delete window.__aiECharts[uid]; }
      panel.structuredRequest = newSR;
      panel.dataSourceId = newDsId;
      if (updated.title) panel.title = updated.title;
      panel.chartType = updated.chartType || panel.chartType;
      panel.chartEngine = updated.chartEngine || 'chartjs';
      panel.chartConfig = updated.chartConfig;
      panel.labels = updated.labels || [];
      panel.values = updated.values || [];
      panel.tableData = updated.tableData || panel.tableData;
      panel.hasData = updated.hasData;
      panel.aiInsight = updated.aiInsight || panel.aiInsight;
      // Rebuild dataConfig snapshot so Properties → Data reflects saved values.
      try {
        if (window.BX && typeof window.BX.rebuildDataConfig === 'function') {
          window.BX.rebuildDataConfig(panel);
        }
      } catch (e) {}
      var card = document.getElementById('aiCard-' + uid);
      if (card && panel.hasData) {
        var bodyEl = card.querySelector('[data-ai-panel-body]');
        if (bodyEl) {
          if (panel.chartEngine === 'echarts' && panel.chartConfig && panel.chartType !== 'table') {
            bodyEl.innerHTML = '<div id="aiEChart-' + uid + '" style="width:100%;height:100%;min-height:220px"></div>';
            requestAnimationFrame(function() { aiRenderEChart(uid, panel); });
          } else if (panel.chartType === 'table') {
            bodyEl.innerHTML = aiBuildTableHTML(panel);
          } else if (panel.chartType === 'cards') {
            bodyEl.innerHTML = '<div id="aiCardBody-' + uid + '" style="display:flex;flex-wrap:wrap;gap:7px;padding:4px"></div>';
            aiRenderCardsInPanel(uid, panel);
          } else if (panel.chartConfig) {
            bodyEl.innerHTML = '<div style="position:relative;flex:1;min-height:0"><canvas id="aiChartCanvas-' + uid + '"></canvas></div>';
            requestAnimationFrame(function() {
              var cv = document.getElementById('aiChartCanvas-' + uid); if (!cv) return;
              var cfg = JSON.parse(JSON.stringify(panel.chartConfig));
              cfg.options = cfg.options || {}; cfg.options.animation = false; cfg.options.responsive = true; cfg.options.maintainAspectRatio = false;
              aiApplyTemplatePalette(cfg, panel.chartType);
              window.__aiCharts[uid] = new Chart(cv.getContext('2d'), cfg);
              aiSyncPanelColors(uid);
            });
          }
        }
      }
      state.editSR = JSON.parse(JSON.stringify(newSR));
      state.dirty = false;
      showPanelProperties(uid);
    })
    .catch(function(e) { alert('Error applying changes: ' + e.message); })
    .finally(function() { if (applyBtn) { applyBtn.disabled = false; applyBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Apply Changes'; } });
  };

  window.aiPropReset = function(uid) {
    var state = aiPropGetState(uid);
    state.editSR = JSON.parse(JSON.stringify(state.origSR));
    state.dirty = false;
    showPanelProperties(uid);
  };

  window.aiPropRefresh = function(uid) {
    var panel = window.__aiPanelData[uid];
    if (!panel || !panel.structuredRequest) return;
    fetch('/dashboard/recalculate-panel', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ structuredRequest: panel.structuredRequest, dataSourceId: panel.dataSourceId || null }),
    })
    .then(function(r) { return r.json(); })
    .then(function(updated) {
      if (updated.error || !updated.chartConfig) return;
      if (window.__aiCharts[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
      if (window.__aiECharts[uid]) { window.__aiECharts[uid].dispose(); delete window.__aiECharts[uid]; }
      panel.labels = updated.labels || panel.labels;
      panel.values = updated.values || panel.values;
      panel.hasData = updated.hasData;
      panel.chartConfig = updated.chartConfig;
      panel.chartEngine = updated.chartEngine || panel.chartEngine;
      // Keep dataConfig in sync after refresh recalculation.
      try {
        if (window.BX && typeof window.BX.rebuildDataConfig === 'function') {
          window.BX.rebuildDataConfig(panel);
        }
      } catch (e) {}
      var card = document.getElementById('aiCard-' + uid);
      if (card && panel.hasData) {
        var bodyEl = card.querySelector('[data-ai-panel-body]');
        if (bodyEl) {
          if (panel.chartEngine === 'echarts' && panel.chartConfig) {
            bodyEl.innerHTML = '<div id="aiEChart-' + uid + '" style="width:100%;height:100%;min-height:220px"></div>';
            requestAnimationFrame(function() { aiRenderEChart(uid, panel); });
          } else if (panel.chartConfig) {
            bodyEl.innerHTML = '<div style="position:relative;flex:1;min-height:0"><canvas id="aiChartCanvas-' + uid + '"></canvas></div>';
            requestAnimationFrame(function() {
              var cv = document.getElementById('aiChartCanvas-' + uid); if (!cv) return;
              var cfg = JSON.parse(JSON.stringify(panel.chartConfig));
              cfg.options = cfg.options || {}; cfg.options.animation = false; cfg.options.responsive = true; cfg.options.maintainAspectRatio = false;
              aiApplyTemplatePalette(cfg, panel.chartType);
              window.__aiCharts[uid] = new Chart(cv.getContext('2d'), cfg);
              aiSyncPanelColors(uid);
            });
          }
        }
      }
      showPanelProperties(uid);
    });
  };

  window.aiPropAddFilter = function(uid) {
    var state = aiPropGetState(uid);
    state.editSR.filters = (state.editSR.filters || []).concat([{ column: '', operator: '=', value: '' }]);
    state.tab = 'filters';
    showPanelProperties(uid);
  };

  window.aiPropRemoveFilter = function(uid, idx) {
    var state = aiPropGetState(uid);
    if (state.editSR.filters) state.editSR.filters.splice(idx, 1);
    showPanelProperties(uid);
  };

  window.aiPropUpdateFilter = function(uid, idx, field, val) {
    var state = aiPropGetState(uid);
    if (state.editSR.filters && state.editSR.filters[idx]) state.editSR.filters[idx][field] = val;
  };

  window.aiPropQuickFilter = function(uid, name) {
    var state = aiPropGetState(uid);
    var sr = state.editSR;
    sr.filters = sr.filters || [];
    var now = new Date();
    if (name === 'This Month') sr.filters.push({ column: 'month', operator: '=', value: now.toLocaleString('default', { month: 'long' }) });
    else if (name === 'This Year') sr.filters.push({ column: 'year', operator: '=', value: String(now.getFullYear()) });
    else if (name === 'Active Only') sr.filters.push({ column: 'status', operator: '=', value: 'active' });
    else if (name === 'Top 10') { sr.limit = 10; sr.sort = sr.sort || {}; sr.sort.direction = 'desc'; }
    else if (name === 'Clear All') { sr.filters = []; }
    state.tab = 'filters';
    showPanelProperties(uid);
  };

  window.aiPropSetPalette = function(uid, colors) {
    var state = aiPropGetState(uid);
    state.customPalette = colors;
    var panel = window.__aiPanelData[uid];
    if (panel) panel.customPalette = colors;
    var ch = window.__aiCharts[uid];
    if (ch && ch.data && ch.data.datasets && ch.data.datasets[0]) {
      var ds = ch.data.datasets[0];
      var lbls = panel ? (panel.labels || []) : [];
      if (Array.isArray(ds.backgroundColor)) ds.backgroundColor = lbls.map(function(_, i) { return colors[i % colors.length] + 'CC'; });
      else ds.backgroundColor = colors[0] + 'CC';
      ds.borderColor = Array.isArray(ds.borderColor) ? lbls.map(function(_, i) { return colors[i % colors.length]; }) : colors[0];
      ch.update('none');
    }
    var ec = window.__aiECharts[uid];
    if (ec) ec.setOption({ color: colors });
    var body = document.getElementById('aiPropTabBody-' + uid);
    if (body) body.innerHTML = aiPropRenderChart(uid, panel || {}, state);
  };

  window.aiPropUndo = function(uid, histIdx) {
    var state = aiPropGetState(uid);
    var snap = state.history[histIdx];
    if (!snap) return;
    if (!confirm('Restore to Version ' + (histIdx + 1) + '? Current unsaved changes will be replaced.')) return;
    state.editSR = JSON.parse(JSON.stringify(snap.sr));
    state.history = state.history.slice(0, histIdx);
    state.dirty = true;
    aiPropApply(uid);
  };

  window.aiPropConfirmRemove = function(uid) {
    if (confirm('Remove this panel? This cannot be undone.')) {
      aiRemoveCanvasPanel(uid);
      delete __propState[uid];
      var content = document.getElementById('aiPropertiesContent');
      if (content) content.innerHTML = '<div style="text-align:center;padding:24px 0;color:#9ca3af"><i class="bi bi-trash" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.3"></i><div style="font-size:0.78rem">Panel removed.</div></div>';
    }
  };

  // -- Change chart type on canvas panel --
  window.aiChangeChartType = function(uid, newType) {
    var panel = window.__aiPanelData[uid];
    if (!panel || !panel.hasData) return;
    // Destroy old chart from whichever map it's in
    if (__aiCharts[uid]) { __aiCharts[uid].destroy(); delete __aiCharts[uid]; }
    if (window.__aiCharts[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
    if (__aiECharts[uid]) { __aiECharts[uid].dispose(); delete __aiECharts[uid]; }
    panel.chartType = newType;

    var card = document.getElementById('aiCard-' + uid) || document.getElementById('mbCard-' + uid);
    if (!card) return;
    var bodyEl = card.querySelector('[data-ai-panel-body]') || card.querySelector('[data-mb-panel-body]');
    if (!bodyEl) return;

    var ecTypes = ['gauge','gauge_ring','funnel','treemap','heatmap','waterfall','histogram','bubble','multiline','stackedarea','bullet','timeline','forecast','scatter'];
    if (newType === 'cards') {
      bodyEl.innerHTML = '<div id="aiCardBody-'+uid+'" style="display:flex;flex-wrap:wrap;gap:7px;padding:4px"></div>';
      aiRenderCardsInPanel(uid, panel);
    } else if (newType === 'table') {
      bodyEl.innerHTML = aiBuildTableHTML(panel);
    } else if (ecTypes.indexOf(newType) >= 0) {
      // Fetch ECharts config from server then render
      bodyEl.innerHTML = '<div id="aiEChart-'+uid+'" style="width:100%;height:100%;min-height:220px"></div>';
      fetch('/dashboard/recalculate-panel', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ structuredRequest: Object.assign({}, panel.structuredRequest || {}, { chartPreference: newType }), dataSourceId: panel.dataSourceId || null }),
      })
      .then(function(r){ return r.json(); })
      .then(function(updated) {
        if (updated.error || !updated.chartConfig) return;
        panel.chartConfig = updated.chartConfig;
        panel.chartEngine = updated.chartEngine || 'echarts';
        aiRenderEChart(uid, panel);
      })
      .catch(function(){});
    } else {
      var cfg = { type: newType, data: { labels: panel.labels || [], datasets: [{ label: panel.title || 'Data', data: panel.values || [], backgroundColor: panel.bgColors || [], borderColor: panel.borderColors || [] }] }, options: {} };
      bodyEl.innerHTML = '<div style="position:relative;flex:1;min-height:0"><canvas id="aiChartCanvas-'+uid+'"></canvas></div>';
      requestAnimationFrame(function() {
        var cv = document.getElementById('aiChartCanvas-'+uid); if (!cv) return;
        var cfgClone = JSON.parse(JSON.stringify(cfg));
        cfgClone.options = { animation: false, responsive: true, maintainAspectRatio: false };
        aiApplyTemplatePalette(cfgClone, newType);
        __aiCharts[uid] = new Chart(cv.getContext('2d'), cfgClone);
        aiSyncPanelColors(uid);
      });
    }
  };

  function aiRenderEChart(uid, panel) {
    var elId = 'aiEChart-' + uid;
    var el = document.getElementById(elId);
    if (!el || !panel.chartConfig) return;
    if (__aiECharts[uid]) { __aiECharts[uid].dispose(); }
    var instance = echarts.init(el);
    instance.setOption(panel.chartConfig);
    __aiECharts[uid] = instance;
  }

  function aiBuildTableHTML(panel) {
    if (!panel.tableData || !panel.tableData.rows || !panel.tableData.rows.length)
      return '<div style="text-align:center;padding:2rem;color:#9ca3af;font-size:0.8rem"><i class="bi bi-inbox" style="font-size:1.5rem;display:block;opacity:0.3;margin-bottom:6px"></i>No data</div>';
    return '<div style="max-height:240px;overflow-y:auto"><table class="table table-sm table-striped mb-0">' +
      '<thead class="table-dark" style="position:sticky;top:0"><tr>' +
      panel.tableData.columns.map(function(c){ return '<th style="font-size:0.68rem;white-space:nowrap">'+_aiEsc(String(c))+'</th>'; }).join('') +
      '</tr></thead><tbody>' +
      panel.tableData.rows.slice(0,50).map(function(r){
        return '<tr>'+panel.tableData.columns.map(function(c){
          return '<td style="font-size:0.68rem">'+_aiEsc(String(r[c]!=null?r[c]:'-'))+'</td>';
        }).join('')+'</tr>';
      }).join('') + '</tbody></table></div>';
  }

  function aiMakePanelInteractive(card, uid) {
    var header = card.querySelector('[data-ai-panel-header]');
    if (header) {
      header.style.cursor = 'move';
      header.addEventListener('mousedown', function(e) {
        if (e.target.closest('button')) return;
        e.preventDefault();
        var sx = e.clientX - card.offsetLeft, sy = e.clientY - card.offsetTop;
        card.style.zIndex = ++__aiZTop;
        function onMove(ev) { card.style.left = Math.max(0, ev.clientX-sx)+'px'; card.style.top = Math.max(0, ev.clientY-sy)+'px'; }
        function onUp() { document.removeEventListener('mousemove',onMove); document.removeEventListener('mouseup',onUp); }
        document.addEventListener('mousemove', onMove); document.addEventListener('mouseup', onUp);
      });
    }
    var grip = card.querySelector('[data-ai-resize-grip]');
    if (grip) {
      grip.addEventListener('mousedown', function(e) {
        e.preventDefault(); e.stopPropagation();
        var sx=e.clientX, sy=e.clientY, sw=card.offsetWidth, sh=card.offsetHeight;
        card.style.zIndex = ++__aiZTop;
        function onMove(ev) {
          card.style.width  = Math.max(260, sw + ev.clientX - sx)+'px';
          card.style.height = Math.max(180, sh + ev.clientY - sy)+'px';
          var ch = __aiCharts[uid]; if (ch) ch.resize();
          var ec = __aiECharts[uid]; if (ec) ec.resize();
        }
        function onUp() { document.removeEventListener('mousemove',onMove); document.removeEventListener('mouseup',onUp); }
        document.addEventListener('mousemove', onMove); document.addEventListener('mouseup', onUp);
      });
    }
  }

