        <div class="text-center py-5 text-muted" style="font-size:0.8rem">
          <i class="bi bi-database" style="font-size:2rem;opacity:0.25;display:block;margin-bottom:8px"></i>
          Select a data source
        </div>
      </div>
    </div>

    <!-- Resize handle: schema ↔ canvas -->
    <div id="mbResizeSchema" style="width:5px;flex-shrink:0;background:#e5e7eb;cursor:col-resize;position:relative;z-index:10;transition:background 0.1s" title="Drag to resize">
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;gap:2px">
        <div style="width:2px;height:10px;background:#9ca3af;border-radius:1px"></div>
