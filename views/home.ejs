    </span>
    <button class="btn btn-sm btn-outline-secondary" id="mbToggleConfigBtn" onclick="toggleMbPanel('config')" title="Toggle Config panel" style="font-size:0.78rem">
      <i class="bi bi-sliders"></i> <span id="mbToggleConfigTxt">Config</span>
    </button>
    <button type="button" class="btn btn-sm btn-warning px-3" onclick="submitMbFullDashboard()" style="font-size:0.82rem;font-weight:600" title="Auto-generate a complete corporate dashboard as a data analyst">
      <i class="bi bi-magic me-1"></i>Full Dashboard
    </button>
    <button type="button" class="btn btn-sm btn-primary px-3" id="mbGenerateBtn" onclick="submitManualDashboard()" disabled style="font-size:0.82rem">
      <i class="bi bi-lightning-fill me-1"></i>Generate &amp; Save
