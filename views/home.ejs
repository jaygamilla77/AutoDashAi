        </div>

        <div style="border-top:1px solid #f1f5f9;margin:10px 0"></div>

        <!-- Dimension -->
        <div class="mb-2" id="mbDimensionGroup">
          <label class="form-label mb-1" style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#374151">
            <span class="badge bg-info text-dark me-1" style="font-size:0.58rem">D</span>Dimension (Group By)
          </label>
          <select class="form-select form-select-sm" id="mbDimension" onchange="updateTitle()" style="font-size:0.82rem">
            <option value="">-- select --</option>
          </select>
        </div>

        <!-- Measure -->
        <div class="mb-2" id="mbMeasureGroup">
          <label class="form-label mb-1" style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#374151">
            <span class="badge bg-warning text-dark me-1" style="font-size:0.58rem">M</span>Measure (Value)
          </label>
          <select class="form-select form-select-sm" id="mbMeasure" onchange="updateTitle()" style="font-size:0.82rem">
            <option value="">-- select --</option>
          </select>
        </div>

        <!-- Aggregation -->
        <div class="mb-3">
          <label class="form-label mb-1" style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#374151">
            <i class="bi bi-calculator me-1"></i>Aggregation
          </label>
          <div class="btn-group w-100" role="group" id="mbAggGroup">
            <% ['COUNT','SUM','AVG','MIN','MAX'].forEach(function(a, i){ %>
            <input type="radio" class="btn-check" name="mbAgg" id="mbAgg<%= a %>" value="<%= a %>" <%= i===0?'checked':'' %> onchange="updateTitle()">
            <label class="btn btn-outline-secondary btn-sm" for="mbAgg<%= a %>" style="font-size:0.68rem"><%= a %></label>
            <% }); %>
          </div>
        </div>

        <div style="border-top:1px solid #f1f5f9;margin:10px 0"></div>

        <!-- Chart Type -->
        <div class="mb-2">
          <label class="form-label mb-1" style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#374151">
            <i class="bi bi-bar-chart me-1"></i>Chart Type
          </label>
          <div class="btn-group w-100" role="group" id="mbChartGroup">
            <% [['bar','bi-bar-chart','Bar'],['line','bi-graph-up','Line'],['pie','bi-pie-chart','Pie'],['doughnut','bi-pie-chart-fill','Donut'],['scatter','bi-diagram-3','Scatter'],['table','bi-table','Table'],['cards','bi-grid-1x2-fill','Cards']].forEach(function(ct,i){ %>
            <input type="radio" class="btn-check" name="mbChart" id="mbChart<%= ct[0] %>" value="<%= ct[0] %>" <%= i===0?'checked':'' %>>
            <label class="btn btn-outline-secondary btn-sm" for="mbChart<%= ct[0] %>" style="font-size:0.68rem" title="<%= ct[2] %>">
              <i class="bi <%= ct[1] %>"></i>
            </label>
            <% }); %>
          </div>
        </div>

        <script>
        // Hide dimension when chart type is "cards" (measure stays visible for column selection)
        // Also trigger chart update when chart type changes
        document.querySelectorAll('input[name="mbChart"]').forEach(function(r) {
          r.addEventListener('change', function() {
            var isCard = this.value === 'cards';
            document.getElementById('mbDimensionGroup').style.display = isCard ? 'none' : '';
            if (isCard) document.getElementById('mbDimension').value = '';
            updateTitle();
            updateSelectedChartConfig(); // Update chart when type changes
          });
        });

        // Add change listeners to other Panel Configuration fields to trigger immediate chart updates
        document.getElementById('mbTable').addEventListener('change', function() {
          updateSelectedChartConfig();
        });
        document.getElementById('mbJoinTable').addEventListener('change', function() {
          updateSelectedChartConfig();
        });
        document.getElementById('mbDimension').addEventListener('change', function() {
          updateSelectedChartConfig();
        });
        document.getElementById('mbMeasure').addEventListener('change', function() {
          updateSelectedChartConfig();
        });
        document.getElementById('mbLimit').addEventListener('change', function() {
          updateSelectedChartConfig();
        });
        document.querySelectorAll('input[name="mbAgg"]').forEach(function(radio) {
          radio.addEventListener('change', function() {
            updateSelectedChartConfig();
          });
        });
        </script>

        <!-- Title -->
        <div class="mb-3">
          <label class="form-label mb-1" style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#374151">
            <i class="bi bi-type me-1"></i>Panel Title
          </label>
          <input type="text" class="form-control form-control-sm" id="mbTitle" placeholder="Auto-generated" style="font-size:0.82rem">
