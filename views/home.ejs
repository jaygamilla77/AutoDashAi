      </div>
      <div id="mbPanelGrid" style="position:relative;min-height:100%;width:100%"></div>
    </div>

    <!-- Resize handle: canvas ↔ config -->
    <div id="mbResizeConfig" style="width:5px;flex-shrink:0;background:#e5e7eb;cursor:col-resize;position:relative;z-index:10;transition:background 0.1s" title="Drag to resize">
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;gap:2px">
