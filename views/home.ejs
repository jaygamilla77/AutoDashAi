  <!-- ── 3-panel workspace ─────────────────────────────────────────────────── -->
  <div id="mbWorkspace" style="display:flex;height:calc(100vh - 160px);overflow:hidden;user-select:none">

    <!-- Left: Schema Explorer -->
    <div id="mbSchemaPanel" style="width:240px;min-width:120px;flex-shrink:0;border-right:none;background:#f9fafb;overflow-y:auto;position:relative">
      <div style="padding:7px 10px 6px;border-bottom:1px solid #e5e7eb;background:#f3f4f6">
        <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:#9ca3af">
          <i class="bi bi-diagram-3 me-1"></i>Schema / Fields
