  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
      background: #F8FAFC;
      min-height: 100vh;
      color: #0F172A;
      padding: 0;
      margin: 0;
    }

    .navbar {
      background: #FFFFFF !important;
      border-bottom: 1px solid #E2E8F0 !important;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04) !important;
      padding: 0.75rem 40px !important;
      margin-left: 72px;
      width: calc(100% - 72px);
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      padding: 0;
    }
    .navbar-brand-icon {
      width: 38px; height: 38px;
      background: #2563EB;
      color: #fff;
      border-radius: 10px;
      display: grid; place-items: center;
      font-size: 20px;
      box-shadow: 0 8px 24px rgba(37,99,235,.25);
      flex-shrink: 0;
    }
    .navbar-brand-text { display: flex; flex-direction: column; line-height: 1.05; }
    .navbar-brand-name { font-weight: 800; font-size: 17px; color: #0F172A; letter-spacing: -.01em; }
    .navbar-brand-name .ai { color: #2563EB; }
    .navbar-brand-tag { font-size: 11px; color: #64748B; font-weight: 500; margin-top: 2px; }

    .nav-link {
      color: #64748B !important;
      font-weight: 500;
      font-size: 0.95rem !important;
      transition: color 0.2s;
    }

    .nav-link:hover {
      color: #0EA5E9 !important;
    }

    .page-content {
      padding: 40px 40px;
      width: calc(100% - 72px);
      margin: 0 0 0 72px;
    }

    .site-footer { margin-left: 72px; }
    @media (max-width: 768px) {
      .site-footer { margin-left: 0; }
    }

    /* ─── Simplified welcome hero ──────────────────────────────────────── */
    .welcome-hero {
      max-width: 640px;
      margin: 60px auto 80px;
      text-align: center;
    }

    .welcome-title {
      font-size: 2.5rem;
      font-weight: 800;
      color: #0F172A;
      letter-spacing: -0.6px;
      margin: 0 0 12px;
    }

    .welcome-sub {
      font-size: 1rem;
      color: #64748B;
      margin: 0 0 40px;
    }

    .create-card {
      display: block;
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 16px;
      padding: 36px 32px 32px;
      text-decoration: none;
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .create-card:hover {
      border-color: #C7D2FE;
      box-shadow: 0 8px 24px rgba(79, 70, 229, 0.12);
      transform: translateY(-2px);
    }

    .create-card-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 18px;
      border-radius: 50%;
      background: #EEF2FF;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #2563EB;
      font-size: 1.6rem;
    }

    .create-card-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 8px;
    }

    .create-card-desc {
      font-size: 0.92rem;
      color: #64748B;
      line-height: 1.5;
      margin: 0 auto 22px;
      max-width: 340px;
    }

    .create-card-btn {
      display: inline-block;
      background: #2563EB;
      color: #FFFFFF;
      font-weight: 600;
      font-size: 0.95rem;
      padding: 12px 28px;
      border-radius: 10px;
      width: 100%;
      max-width: 320px;
      text-align: center;
    }

    .recent-heading {
      font-size: 1.05rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 10px;
    }

    .recent-divider {
      height: 1px;
      background: #E2E8F0;
      margin-bottom: 24px;
    }

    .empty-state-sub {
      font-size: 0.86rem;
      color: #94A3B8;
      margin-top: 4px;
    }

    .header-section {
      margin-bottom: 48px;
    }

    .header-greeting {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 40px;
      margin-bottom: 40px;
    }

    .greeting-text h1 {
      font-size: 2.25rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }

    .greeting-text p {
      font-size: 1rem;
      color: #64748B;
      margin: 0;
    }

    .ai-summary {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 24px;
      max-width: 380px;
      color: #0F172A;
      font-size: 0.95rem;
      line-height: 1.6;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .ai-summary-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #0F172A;
    }

    .ai-summary-title i {
      color: #0EA5E9;
    }

    /* â”€â”€â”€ KPI Cards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .kpi-section {
      margin-bottom: 48px;
    }

    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-title i {
      color: #0EA5E9;
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .kpi-card {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 24px;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .kpi-card:hover {
      border-color: #0EA5E9;
      box-shadow: 0 4px 12px rgba(14, 165, 233, 0.08);
      transform: translateY(-2px);
    }

    .kpi-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
    }

    .kpi-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: #64748B;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .kpi-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 6px;
      background: #F0FDF4;
      color: #16A34A;
    }

    .kpi-status.warning {
      background: #FFFBEB;
      color: #D97706;
    }

    .kpi-status.alert {
      background: #FEF2F2;
      color: #DC2626;
    }

    .kpi-value {
      font-size: 2rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 12px;
      line-height: 1;
    }

    .kpi-change {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.9rem;
      margin-bottom: 12px;
      color: #16A34A;
    }

    .kpi-change.negative {
      color: #DC2626;
    }

    .sparkline-container {
      height: 50px;
      position: relative;
    }

    /* â”€â”€â”€ Quick Actions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .actions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 16px;
      margin-bottom: 48px;
    }

    .action-card {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .action-card:hover {
      border-color: #0EA5E9;
      box-shadow: 0 4px 12px rgba(14, 165, 233, 0.08);
      transform: translateY(-2px);
    }

    .action-icon {
      font-size: 1.75rem;
      color: #0EA5E9;
    }

    .action-label {
      font-weight: 600;
      color: #0F172A;
      font-size: 0.9rem;
    }

    /* â”€â”€â”€ Recent Dashboards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .dashboards-section {
      margin-bottom: 48px;
    }

    .dashboards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
    }

    .dashboard-card {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      overflow: hidden;
      transition: all 0.2s;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .dashboard-card:hover {
      border-color: #0EA5E9;
      box-shadow: 0 4px 12px rgba(14, 165, 233, 0.08);
      transform: translateY(-2px);
    }

    .dashboard-preview {
      width: 100%;
      height: 120px;
      background: linear-gradient(135deg, #F0F9FF 0%, #F5FAFF 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0EA5E9;
      font-size: 2.5rem;
      overflow: hidden;
      border-bottom: 1px solid #E2E8F0;
    }

    .dashboard-content {
      padding: 16px;
    }

    .dashboard-title {
      font-weight: 600;
      color: #0F172A;
      font-size: 0.95rem;
      margin-bottom: 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .dashboard-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;
      color: #94A3B8;
      margin-bottom: 12px;
    }

    .dashboard-actions {
      display: flex;
      gap: 8px;
    }

    .dashboard-btn {
      flex: 1;
      padding: 8px;
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 8px;
      color: #0EA5E9;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-weight: 600;
    }

    .dashboard-btn:hover {
      background: #F0F9FF;
      border-color: #0EA5E9;
      color: #0284C7;
    }

    /* â”€â”€â”€ AI Recommendations â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .recommendations-section {
      margin-bottom: 48px;
    }

    .recommendations-grid {
      display: grid;
      gap: 16px;
    }

    .recommendation-card {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 20px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
      transition: all 0.2s;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .recommendation-card.critical {
      border-color: #FECACA;
      background: #FEF2F2;
    }

    .recommendation-card.warning {
      border-color: #FED7AA;
      background: #FFFBEB;
    }

    .recommendation-card.info {
      border-color: #BAE6FD;
      background: #F0F9FF;
    }

    .recommendation-card:hover {
      border-color: #0EA5E9;
      box-shadow: 0 4px 12px rgba(14, 165, 233, 0.08);
    }

    .recommendation-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .recommendation-icon.critical {
      color: #DC2626;
    }

    .recommendation-icon.warning {
      color: #D97706;
    }

    .recommendation-icon.info {
      color: #0EA5E9;
    }

    .recommendation-body {
      flex: 1;
    }

    .recommendation-title {
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 4px;
    }

    .recommendation-desc {
      font-size: 0.9rem;
      color: #64748B;
      margin-bottom: 12px;
    }

    .recommendation-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .rec-btn {
      padding: 8px 14px;
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 8px;
      color: #0EA5E9;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s;
      font-weight: 600;
    }

    .rec-btn:hover {
      background: #F0F9FF;
      border-color: #0EA5E9;
    }

    /* â”€â”€â”€ Empty State â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #94A3B8;
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 16px;
      opacity: 0.5;
      color: #CBD5E1;
    }

    .empty-state-text {
      font-size: 1.1rem;
      margin-bottom: 20px;
    }

    .empty-state a {
      color: #0EA5E9;
    }

    /* â”€â”€â”€ Responsive â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    @media (max-width: 1200px) {
      .navbar {
        padding: 0.75rem 32px !important;
      }

      .page-content {
        padding: 32px 32px;
      }

      .kpi-grid {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .dashboards-grid {
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      }
    }

    @media (max-width: 768px) {
      .navbar {
        padding: 0.75rem 24px !important;
      }

      .page-content {
        padding: 24px 24px;
      }

      .header-greeting {
        flex-direction: column;
        gap: 20px;
      }

      .greeting-text h1 {
        font-size: 1.75rem;
      }

      .ai-summary {
        max-width: 100%;
      }

      .kpi-grid {
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      }

      .actions-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .dashboards-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      }
    }

    @media (max-width: 480px) {
      .navbar {
        padding: 0.75rem 16px !important;
      }

      .page-content {
        padding: 16px 16px;
      }

      .greeting-text h1 {
        font-size: 1.5rem;
      }

      .kpi-value {
        font-size: 1.5rem;
      }

      .actions-grid {
        grid-template-columns: 1fr;
      }

      .dashboards-grid {
        grid-template-columns: 1fr;
      }

      .recommendation-card {
        flex-direction: column;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light">
    <div class="container-fluid" style="padding: 0;">
      <a class="navbar-brand" href="/" aria-label="AutoDash AI by Liknaya home">
        <span class="navbar-brand-icon"><i class="bi bi-bar-chart-line-fill"></i></span>
        <span class="navbar-brand-text">
          <span class="navbar-brand-name">AutoDash <span class="ai">AI</span></span>
          <span class="navbar-brand-tag">by Liknaya</span>
        </span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard/history">Dashboards</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/sources">Data Sources</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/ai-builder">AI Builder</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/settings">Settings</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="page-content">
    <!-- Hero / Welcome -->
    <div class="welcome-hero">
      <h1 class="welcome-title">Welcome back, <%= userDisplayName || 'there' %></h1>
      <p class="welcome-sub">Create intelligent dashboards in minutes with the power of AI.</p>

      <a href="/wizard" class="create-card" aria-label="Create Dashboard via Wizard">
        <div class="create-card-icon"><i class="bi bi-magic"></i></div>
        <div class="create-card-title">Create Dashboard via Wizard</div>
        <div class="create-card-desc">Answer a few questions and let AI build the perfect dashboard for your data.</div>
        <span class="create-card-btn">Create Dashboard</span>
      </a>
    </div>

    <!-- Recent Dashboards -->
    <div class="dashboards-section">
      <div class="recent-heading">Recent Dashboards</div>
      <div class="recent-divider"></div>

      <% if (recentDashboards && recentDashboards.length > 0) { %>
        <div class="dashboards-grid">
          <% recentDashboards.slice(0, 6).forEach(function(dashboard) { %>
            <div class="dashboard-card">
              <div class="dashboard-preview">
                <i class="bi bi-graph-up"></i>
              </div>
              <div class="dashboard-content">
                <div class="dashboard-title" title="<%= dashboard.title %>"><%= dashboard.title %></div>
                <div class="dashboard-meta">
                  <span><i class="bi bi-calendar"></i> <%= new Date(dashboard.updatedAt).toLocaleDateString() %></span>
                </div>
                <div class="dashboard-actions">
                  <a href="/dashboard/<%= dashboard.id %>" class="dashboard-btn">
                    <i class="bi bi-eye"></i> View
                  </a>
                  <a href="/dashboard/<%= dashboard.id %>/edit-canvas" class="dashboard-btn">
                    <i class="bi bi-pencil"></i> Edit
                  </a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="bi bi-graph-up"></i></div>
          <div class="empty-state-text">No dashboards yet</div>
          <div class="empty-state-sub">Create your first dashboard to get started.</div>
        </div>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
