</div><!-- /manualModeCard -->

<script>
(function () {
  // ── State ────────────────────────────────────────────────────────────────────
  window.__schemaLoaded = false;
  var __schema       = null;
  var __preview      = null;
  // SHARED STATE: Both modes use window.__aiQueue, __aiCharts, __aiPanelData

  // ── Utilities ────────────────────────────────────────────────────────────────
  function _esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Sidebar toggles ──────────────────────────────────────────────────────────
  window.toggleMbPanel = function(which) {
    var el  = document.getElementById(which === 'schema' ? 'mbSchemaPanel' : 'mbConfigPanel');
    var txt = document.getElementById(which === 'schema' ? 'mbToggleSchemaTxt' : 'mbToggleConfigTxt');
    if (!el) return;
    var collapsed = el.getAttribute('data-collapsed') === '1';
    if (collapsed) {
      el.style.width    = '240px';
      el.style.minWidth = '240px';
      el.style.overflow = 'auto';
      if (which === 'schema') el.style.borderRight = '1px solid #e5e7eb';
      else                    el.style.borderLeft  = '1px solid #e5e7eb';
      el.removeAttribute('data-collapsed');
      if (txt) txt.textContent = which === 'schema' ? 'Fields' : 'Config';
    } else {
      el.style.width    = '0px';
      el.style.minWidth = '0px';
      el.style.overflow = 'hidden';
      el.style.border   = 'none';
      el.setAttribute('data-collapsed', '1');
      if (txt) txt.textContent = which === 'schema' ? 'Fields >' : 'Config >';
    }
  };

  // ── Load schema ──────────────────────────────────────────────────────────────
  window.loadSchema = function () {
    window.__schemaLoaded = true;
    var sourceId = document.getElementById('mbSourceSel').value;
    var url = '/dashboard/schema' + (sourceId ? '?sourceId=' + encodeURIComponent(sourceId) : '');
    document.getElementById('schemaExplorer').innerHTML =
      '<div class="text-center py-4 text-muted" style="font-size:0.8rem"><div class="spinner-border spinner-border-sm mb-2" style="opacity:0.4"></div><br>Loading...</div>';
    fetch(url)
      .then(function(r){ return r.json(); })
      .then(function(schema){
        __schema = schema;
        __schemaExpanded = {};
        renderSchemaExplorer(schema);
        populateTableDropdown(schema);
      })
      .catch(function(){
        document.getElementById('schemaExplorer').innerHTML =
          '<div class="text-center py-4 text-danger" style="font-size:0.8rem">Failed to load schema.</div>';
      });
  };

  // ── Schema Explorer ──────────────────────────────────────────────────────────
  var __schemaExpanded = {};

  window.toggleTableExpand = function(tkey) {
    __schemaExpanded[tkey] = !__schemaExpanded[tkey];
    var safeKey = tkey.replace(/[^a-zA-Z0-9]/g, '_');
    var body = document.getElementById('tbl-body-' + safeKey);
    var icon = document.getElementById('tbl-chev-' + safeKey);
    if (body) body.style.display = __schemaExpanded[tkey] ? 'block' : 'none';
    if (icon) icon.className = __schemaExpanded[tkey] ? 'bi bi-chevron-down' : 'bi bi-chevron-right';
  };

  window.toggleAllTables = function(btn) {
    var anyOpen = Object.values(__schemaExpanded).some(Boolean);
    (__schema && __schema.tables || []).forEach(function(t) {
      __schemaExpanded[t.key] = !anyOpen;
      var s = t.key.replace(/[^a-zA-Z0-9]/g, '_');
      var b  = document.getElementById('tbl-body-' + s);
      var ic = document.getElementById('tbl-chev-' + s);
      if (b)  b.style.display  = !anyOpen ? 'block' : 'none';
      if (ic) ic.className     = !anyOpen ? 'bi bi-chevron-down' : 'bi bi-chevron-right';
    });
    if (btn) btn.textContent = !anyOpen ? 'Collapse all' : 'Expand all';
  };

  document.getElementById('schemaExplorer').addEventListener('click', function(e) {
    var chevBtn = e.target.closest('.tbl-chev-btn');
    if (chevBtn) { toggleTableExpand(chevBtn.dataset.tkey); return; }
    var tblBtn  = e.target.closest('.tbl-name-btn');
    if (tblBtn)  { selectTable(tblBtn.dataset.tkey); return; }
    var colBtn  = e.target.closest('.col-item');
    if (colBtn)  { selectColumn(colBtn.dataset.tkey, colBtn.dataset.ckey, colBtn.dataset.role); return; }
    var allBtn  = e.target.closest('.tbl-toggle-all');
    if (allBtn)  { toggleAllTables(allBtn); return; }
  });

  function renderSchemaExplorer(schema) {
    var el = document.getElementById('schemaExplorer');
    var html = '';
    if (schema.relationships && schema.relationships.length) {
      html += '<div style="padding:4px 6px"><span style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#9ca3af">Relationships</span></div>';
      schema.relationships.forEach(function(r) {
        html += '<div style="font-size:0.69rem;padding:2px 8px;color:#6b7280"><i class="bi bi-arrow-right text-primary" style="font-size:0.58rem"></i> ' + _esc(r.label) + '</div>';
      });
      html += '<hr style="margin:6px 4px">';
    }
    html += '<div style="padding:4px 8px;display:flex;align-items:center;justify-content:space-between">' +
      '<span style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#9ca3af">Tables</span>' +
      '<button class="btn btn-link btn-sm p-0 text-muted text-decoration-none tbl-toggle-all" style="font-size:0.6rem">Expand all</button>' +
      '</div>';
    schema.tables.forEach(function(t) {
      var dims     = t.columns.filter(function(c){ return c.role === 'dimension'; });
      var measures = t.columns.filter(function(c){ return c.role === 'measure'; });
      var safeKey  = t.key.replace(/[^a-zA-Z0-9]/g, '_');
      var isOpen   = !!__schemaExpanded[t.key];
      var ek       = _esc(t.key);
      html += '<div class="mb-1">' +
        '<div style="display:flex;align-items:center;background:#f3f4f6;border-radius:4px;border:1px solid #e5e7eb;margin:0 2px">' +
          '<button class="btn btn-link btn-sm p-0 flex-shrink-0 tbl-chev-btn" data-tkey="' + ek + '" style="width:22px;height:26px;color:#6b7280">' +
            '<i class="bi ' + (isOpen ? 'bi-chevron-down' : 'bi-chevron-right') + '" id="tbl-chev-' + safeKey + '" style="font-size:0.6rem"></i>' +
          '</button>' +
          '<button class="btn btn-link btn-sm flex-grow-1 text-start py-1 px-0 text-decoration-none tbl-name-btn" data-tkey="' + ek + '" style="font-size:0.78rem;font-weight:600;color:#111827;min-width:0" title="Use this table">' +
            '<i class="bi ' + _esc(t.icon || 'bi-table') + ' text-primary me-1" style="font-size:0.72rem"></i>' +
            _esc(t.displayName) +
          '</button>' +
          '<span class="badge bg-light text-muted border me-1 flex-shrink-0" style="font-size:0.56rem">' + t.columns.length + '</span>' +
        '</div>' +
        '<div id="tbl-body-' + safeKey + '" style="border-left:2px solid #dde3ec;margin-left:12px;display:' + (isOpen ? 'block' : 'none') + '">';
      if (dims.length) {
        html += '<div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#6b7280;padding:2px 4px">Dimensions</div>';
        dims.forEach(function(c) {
          html += '<div class="col-item" data-tkey="' + ek + '" data-ckey="' + _esc(c.key) + '" data-role="dimension" ' +
            'style="font-size:0.7rem;padding:2px 6px;cursor:pointer;color:#374151;border-radius:3px" title="Set as Dimension">' +
            '<span class="badge bg-info text-dark me-1" style="font-size:0.56rem">D</span>' + _esc(c.displayName) +
            ' <span style="color:#9ca3af;font-size:0.62rem">' + c.type + '</span></div>';
        });
      }
      if (measures.length) {
        html += '<div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#6b7280;padding:2px 4px;margin-top:2px">Measures</div>';
        measures.forEach(function(c) {
          html += '<div class="col-item" data-tkey="' + ek + '" data-ckey="' + _esc(c.key) + '" data-role="measure" ' +
            'style="font-size:0.7rem;padding:2px 6px;cursor:pointer;color:#374151;border-radius:3px" title="Set as Measure">' +
            '<span class="badge bg-warning text-dark me-1" style="font-size:0.56rem">M</span>' + _esc(c.displayName) +
            ' <span style="color:#9ca3af;font-size:0.62rem">' + c.type + '</span></div>';
        });
      }
      html += '</div></div>';
    });
    el.innerHTML = html;
  }

  // ── Populate table dropdown ───────────────────────────────────────────────────
  function populateTableDropdown(schema) {
    var sel = document.getElementById('mbTable');
    sel.innerHTML = '<option value="">-- select table --</option>';
    schema.tables.forEach(function(t) {
      var o = document.createElement('option'); o.value = t.key; o.textContent = t.displayName; sel.appendChild(o);
    });
    if (schema.tables.length > 0) { sel.value = schema.tables[0].key; onTableChange(); }
  }

  window.selectTable = function(tableKey) {
    document.getElementById('mbTable').value = tableKey; onTableChange();
  };

  window.selectColumn = function(tableKey, colKey, role) {
    var ref = tableKey + '.' + colKey;
    var mainVal = document.getElementById('mbTable').value;
    if (role === 'dimension') {
      if (!mainVal) { document.getElementById('mbTable').value = tableKey; onTableChange(); }
      else if (mainVal !== tableKey) {
        var joinSel = document.getElementById('mbJoinTable'), found = false;
        for (var i = 0; i < joinSel.options.length; i++) { if (joinSel.options[i].value === tableKey) { joinSel.value = tableKey; found = true; break; } }
        if (!found) { document.getElementById('mbTable').value = tableKey; onTableChange(); } else { onJoinChange(); }
      }
      document.getElementById('mbDimension').value = ref;
    } else {
      if (mainVal !== tableKey) { document.getElementById('mbTable').value = tableKey; onTableChange(); }
      document.getElementById('mbMeasure').value = ref;
    }
    updateTitle();
  };

  window.onTableChange = function() {
    if (!__schema) return;
    var tableKey = document.getElementById('mbTable').value;
    var joinSel  = document.getElementById('mbJoinTable');
    var prevJoin = joinSel.value;
    joinSel.innerHTML = '<option value="">-- none --</option>';
    var relatedKeys = new Set();
    (__schema.relationships || []).forEach(function(r) {
      if (r.from === tableKey) relatedKeys.add(r.to);
      if (r.to   === tableKey) relatedKeys.add(r.from);
    });
    relatedKeys.forEach(function(rk) {
      var rt = __schema.tables.find(function(t){ return t.key === rk; });
      if (rt) { var o = document.createElement('option'); o.value = rk; o.textContent = rt.displayName; joinSel.appendChild(o); }
    });
    if (prevJoin && joinSel.querySelector('option[value="' + prevJoin + '"]')) joinSel.value = prevJoin;
    refreshDimMesDropdowns(); updateTitle();
  };

  window.onJoinChange = function() { refreshDimMesDropdowns(); updateTitle(); };

  function refreshDimMesDropdowns() {
    if (!__schema) return;
    var tableKey = document.getElementById('mbTable').value;
    var joinKey  = document.getElementById('mbJoinTable').value;
    var allCols  = [];
    var addCols  = function(tKey) {
      var t = __schema.tables.find(function(x){ return x.key === tKey; }); if (!t) return;
      t.columns.forEach(function(c) { allCols.push({ ref: tKey + '.' + c.key, label: t.displayName + ' > ' + c.displayName, role: c.role, type: c.type }); });
    };
    if (tableKey) addCols(tableKey);
    if (joinKey && joinKey !== tableKey) addCols(joinKey);
    var dimSel = document.getElementById('mbDimension'), mesSel = document.getElementById('mbMeasure');
    var prevDim = dimSel.value, prevMes = mesSel.value;
    dimSel.innerHTML = '<option value="">-- select dimension --</option>';
    mesSel.innerHTML = '<option value="">-- select measure --</option>';
    allCols.forEach(function(c) {
      var o = document.createElement('option'); o.value = c.ref; o.textContent = c.label + ' (' + c.type + ')';
      if (c.role === 'dimension') dimSel.appendChild(o); else mesSel.appendChild(o);
    });
    if (prevDim && dimSel.querySelector('option[value="' + prevDim + '"]')) dimSel.value = prevDim;
    else if (dimSel.options.length > 1) dimSel.selectedIndex = 1;
    if (prevMes && mesSel.querySelector('option[value="' + prevMes + '"]')) mesSel.value = prevMes;
    else if (mesSel.options.length > 1) mesSel.selectedIndex = 1;
    __filterAllCols = allCols;
  }

  window.updateTitle = function() {
    var agg = document.querySelector('input[name="mbAgg"]:checked');
    var dim = document.getElementById('mbDimension'), mes = document.getElementById('mbMeasure');
    var dimLabel = dim.selectedIndex > 0 ? (dim.options[dim.selectedIndex].text.split('>')[1]||dim.options[dim.selectedIndex].text).replace(/\(.*\)/,'').trim() : '';
    var mesLabel = mes.selectedIndex > 0 ? (mes.options[mes.selectedIndex].text.split('>')[1]||mes.options[mes.selectedIndex].text).replace(/\(.*\)/,'').trim() : '';
    var inp = document.getElementById('mbTitle');
    if (!inp.dataset.userEdited) {
      inp.value = (agg ? agg.value : 'COUNT') + (mesLabel ? ' of ' + mesLabel : '') + (dimLabel ? ' by ' + dimLabel : '');
    }
  };
  document.getElementById('mbTitle').addEventListener('input', function(){ this.dataset.userEdited = this.value ? '1' : ''; });

  // ── Filters ───────────────────────────────────────────────────────────────────
  var __filterAllCols = [], __filterIdCtr = 0;

  window.addFilter = function() {
    var container = document.getElementById('mbFilters');
    var id = ++__filterIdCtr;
    var row = document.createElement('div');
    row.className = 'd-flex gap-1 align-items-center mb-1'; row.id = 'mbFilter-' + id;
    var colSel = document.createElement('select'); colSel.className = 'form-select form-select-sm'; colSel.style.fontSize = '0.74rem';
    colSel.innerHTML = '<option value="">Col...</option>';
    __filterAllCols.forEach(function(c){ var o=document.createElement('option'); o.value=c.ref; o.textContent=(c.label.split('>')[1]||c.label).trim(); colSel.appendChild(o); });
    var opSel = document.createElement('select'); opSel.className = 'form-select form-select-sm'; opSel.style.cssText='font-size:0.74rem;max-width:78px';
    ['=','!=','>','<','>=','<=','LIKE','NOT LIKE'].forEach(function(op){ var o=document.createElement('option'); o.value=op; o.textContent=op; opSel.appendChild(o); });
    var valInp = document.createElement('input'); valInp.type='text'; valInp.className='form-control form-control-sm'; valInp.placeholder='Value...'; valInp.style.fontSize='0.74rem';
    var rb = document.createElement('button'); rb.type='button'; rb.className='btn btn-sm btn-outline-danger flex-shrink-0';
    rb.innerHTML='<i class="bi bi-x"></i>'; rb.style.cssText='padding:2px 5px'; rb.onclick=function(){ row.remove(); };
    row.appendChild(colSel); row.appendChild(opSel); row.appendChild(valInp); row.appendChild(rb);
    container.appendChild(row);
  };

  function getFilters() {
    var result = [];
    document.querySelectorAll('#mbFilters > div').forEach(function(row) {
      var sels = row.querySelectorAll('select'), inp = row.querySelector('input');
      if (sels.length >= 2 && inp && sels[0].value && sels[1].value && inp.value !== '')
        result.push({ column: sels[0].value, operator: sels[1].value, value: inp.value });
    });
    return result;
  }

  // ── Canvas panel rendering ────────────────────────────────────────────────────
  var __mbNextX = 10, __mbNextY = 10;   // cascading placement offset

  function updateEmptyState() {
    var grid = document.getElementById('mbPanelGrid'), empty = document.getElementById('mbEmptyState');
    var panelCards = grid ? grid.querySelectorAll('[id^="mbCard-"]').length : 0;
    if (empty) empty.style.display = panelCards > 0 ? 'none' : 'flex';
  }

  // Make a card draggable via its header and resizable via its SE corner
  function makePanelInteractive(card, uid) {
    var header = card.querySelector('[data-panel-header]');
    if (header) {
      header.style.cursor = 'move';
      header.addEventListener('mousedown', function(e) {
        if (e.target.closest('button')) return;  // let buttons work normally
        e.preventDefault();
        var startX = e.clientX - card.offsetLeft;
        var startY = e.clientY - card.offsetTop;
        card.style.zIndex = ++__mbZTop;
        function onMove(ev) {
          var x = ev.clientX - startX;
          var y = ev.clientY - startY;
          card.style.left = Math.max(0, x) + 'px';
          card.style.top  = Math.max(0, y) + 'px';
        }
        function onUp() {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }

    // SE resize grip
    var grip = card.querySelector('[data-resize-grip]');
    if (grip) {
      grip.addEventListener('mousedown', function(e) {
        e.preventDefault(); e.stopPropagation();
        var startX = e.clientX, startY = e.clientY;
        var startW = card.offsetWidth, startH = card.offsetHeight;
        card.style.zIndex = ++__mbZTop;
        function onMove(ev) {
          var newW = Math.max(260, startW + ev.clientX - startX);
          var newH = Math.max(180, startH + ev.clientY - startY);
          card.style.width  = newW + 'px';
          card.style.height = newH + 'px';
          // Let Chart.js reflow
          var ch = window.__aiCharts[uid];
          if (ch) ch.resize();
        }
        function onUp() {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }
  }

  function updateQueueCount() {
    var n = window.__aiQueue.length;
    var genBtn = document.getElementById('mbGenerateBtn');
    var badge  = document.getElementById('mbPanelCountBadge');
    var qEl    = document.getElementById('mbQueueCount');
    if (genBtn) { genBtn.disabled = n === 0; genBtn.innerHTML = n > 0 ? '<i class="bi bi-lightning-fill me-1"></i>Generate &amp; Save (' + n + ')' : '<i class="bi bi-lightning-fill me-1"></i>Generate &amp; Save Dashboard'; }
    if (badge)  badge.style.display  = n > 0 ? '' : 'none';
    if (qEl)    qEl.textContent = n;
  }

  window.removeMbCanvasPanel = function(uid) {
    if (window.__aiCharts[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
    delete window.__aiPanelData[uid];
    var card = document.getElementById('mbCard-' + uid); if (card) card.remove();
    for (var i = window.__aiQueue.length - 1; i >= 0; i--) { if (window.__aiQueue[i]._uid === uid) window.__aiQueue.splice(i, 1); }
    updateQueueCount(); updateEmptyState();
  };

  function renderCardsInPanel(uid, panel) {
    var el = document.getElementById('mbCardBody-' + uid); if (!el || !panel.labels) return;
    var formatVal = function(v) {
      var n = parseFloat(v); if (isNaN(n)) return String(v);
      var abs = Math.abs(n);
      if (abs >= 1e9)  return (n/1e9).toFixed(1).replace(/\.0$/,'')  + 'B';
      if (abs >= 1e6)  return (n/1e6).toFixed(1).replace(/\.0$/,'')  + 'M';
      if (abs >= 1e3)  return (n/1e3).toFixed(1).replace(/\.0$/,'')  + 'K';
      return n % 1 !== 0 ? n.toFixed(2) : String(n);
    };
    el.style.cssText = 'display:flex;flex-wrap:wrap;gap:10px;padding:8px;justify-content:center';
    el.innerHTML = (panel.labels || []).slice(0,20).map(function(lbl, i){
      var val = panel.values[i] != null ? panel.values[i] : '-';
      var dv = formatVal(val);
      return '<div style="background:#1e1e2e;border-radius:10px;padding:18px 16px 14px;min-width:110px;flex:1;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.25)">' +
        '<div style="font-size:1.5rem;font-weight:700;color:#facc15;line-height:1.1;letter-spacing:-0.5px">' + _esc(String(dv)) + '</div>' +
        '<div style="font-size:0.68rem;color:#94a3b8;margin-top:6px;text-transform:uppercase;letter-spacing:0.6px;word-break:break-word">' + _esc(String(lbl)) + '</div></div>';
    }).join('');
  }

  function buildTableBodyHTML(panel) {
    if (!panel.tableData || !panel.tableData.rows || !panel.tableData.rows.length)
      return '<div style="text-align:center;padding:2rem;color:#9ca3af;font-size:0.8rem"><i class="bi bi-inbox" style="font-size:1.5rem;display:block;opacity:0.3;margin-bottom:6px"></i>No data</div>';
    return '<div style="max-height:240px;overflow-y:auto"><table class="table table-sm table-striped mb-0">' +
      '<thead class="table-dark" style="position:sticky;top:0"><tr>' +
      panel.tableData.columns.map(function(c){ return '<th style="font-size:0.68rem;white-space:nowrap">' + _esc(String(c)) + '</th>'; }).join('') +
      '</tr></thead><tbody>' +
      panel.tableData.rows.slice(0,50).map(function(r){
        return '<tr>' + panel.tableData.columns.map(function(c){
          return '<td style="font-size:0.68rem">' + _esc(String(r[c] != null ? r[c] : '-')) + '</td>';
        }).join('') + '</tr>';
      }).join('') + '</tbody></table></div>';
  }

  // -- Change chart type on canvas panel (Manual Builder) --
  window.mbChangeChartType = function(uid, newType) {
    var panel = window.__aiPanelData[uid] || (window.__aiPanelData || {})[uid];
    if (!panel || !panel.hasData) return;
    if (window.__aiCharts[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
    if ((window.__aiCharts || {})[uid]) { window.__aiCharts[uid].destroy(); delete window.__aiCharts[uid]; }
    panel.chartType = newType;

    var card = document.getElementById('mbCard-' + uid) || document.getElementById('aiCard-' + uid);
    if (!card) return;
    var bodyEl = card.querySelector('[data-mb-panel-body]') || card.querySelector('[data-ai-panel-body]');
    if (!bodyEl) return;

    var canvasId = 'mbCanvas-'+uid;
    var cardBodyId = 'mbCardBody-'+uid;
    if (newType === 'cards') {
      bodyEl.innerHTML = '<div id="'+cardBodyId+'" style="display:flex;flex-wrap:wrap;gap:7px;padding:4px"></div>';
      renderCardsInPanel(uid, panel);
    } else if (newType === 'table') {
      bodyEl.innerHTML = buildTableBodyHTML(panel);
    } else {
      var cfg = { type: newType, data: { labels: panel.labels || [], datasets: [{ label: panel.title || 'Data', data: panel.values || [], backgroundColor: panel.bgColors || [], borderColor: panel.borderColors || [] }] }, options: {} };
      bodyEl.innerHTML = '<div style="position:relative;flex:1;min-height:0"><canvas id="'+canvasId+'"></canvas></div>';
      requestAnimationFrame(function() {
        var cv = document.getElementById(canvasId); if (!cv) return;
        var cfgClone = JSON.parse(JSON.stringify(cfg));
        cfgClone.options = { animation: false, responsive: true, maintainAspectRatio: false };
        window.__aiCharts[uid] = new Chart(cv.getContext('2d'), cfgClone);
      });
    }
  };

  var __mbZTop = 10;

  function renderPanelOnCanvas(panel, isStaging) {
    var uid = isStaging ? 'staging' : ('p' + (++window.__aiPanelIdCtr));
    panel._uid = uid;
    window.__aiPanelData[uid] = panel;

    // Remove existing staging card if replacing
    if (isStaging) {
      var old = document.getElementById('mbCard-staging');
      if (old) { if (window.__aiCharts['staging']) { window.__aiCharts['staging'].destroy(); delete window.__aiCharts['staging']; } old.remove(); }
    }

    // Determine initial placement
    var px, py;
    if (isStaging) {
      // Place preview near top-right of visible canvas area
      var canvasEl = document.getElementById('mbCanvas');
      px = Math.max(10, canvasEl.clientWidth - 430);
      py = canvasEl.scrollTop + 10;
    } else {
      // Cascade permanent panels
      px = __mbNextX; py = __mbNextY;
      __mbNextX += 20; __mbNextY += 20;
      if (__mbNextX > 160) { __mbNextX = 10; __mbNextY = 10; }
    }

    var card = document.createElement('div');
    card.id = 'mbCard-' + uid;

    // Cards type: no panel box, just dark KPI cards directly
    if (panel.chartType === 'cards' && panel.hasData) {
      var numCards = Math.min((panel.labels||[]).length, 20);
      var cols = Math.min(numCards, 4);
      var cardW = cols * 140 + (cols - 1) * 10 + 20;
      var rows = Math.ceil(numCards / cols);
      var cardH = rows * 90 + (rows - 1) * 10 + 50;
      card.style.cssText = 'position:absolute;width:' + cardW + 'px;height:' + cardH + 'px;display:flex;flex-direction:column;background:transparent;overflow:visible;' +
        'left:' + px + 'px;top:' + py + 'px;z-index:' + (++__mbZTop) + ';';

      // Tiny toolbar (no title for cards)
      var toolbar = '<div data-panel-header style="display:flex;align-items:center;justify-content:flex-end;padding:2px 4px;margin-bottom:4px;cursor:move">' +
        '<div style="display:flex;gap:4px;align-items:center">';
      if (isStaging) {
        toolbar += '<button class="btn btn-primary btn-sm py-0 px-2" onclick="addPanelToQueue()" style="font-size:0.65rem"><i class="bi bi-plus-circle me-1"></i>Add</button>' +
                   '<button class="btn btn-sm btn-link text-secondary p-0" onclick="clearPreview()" title="Dismiss"><i class="bi bi-x-lg" style="font-size:0.65rem"></i></button>';
      } else {
        toolbar += '<button class="btn btn-sm btn-link text-danger p-0" onclick="removeMbCanvasPanel(\'' + uid + '\')" title="Remove"><i class="bi bi-x-lg" style="font-size:0.65rem"></i></button>';
      }
      toolbar += '</div></div>';

      var cardsHtml = '<div id="mbCardBody-' + uid + '" style="display:flex;flex-wrap:wrap;gap:10px;padding:0"></div>';
      var grip = '<div data-resize-grip style="position:absolute;right:-1px;bottom:-1px;width:18px;height:18px;cursor:se-resize;z-index:20;display:flex;align-items:flex-end;justify-content:flex-end;padding:2px">' +
        '<svg width="10" height="10" viewBox="0 0 10 10" style="opacity:0.35"><line x1="10" y1="2" x2="2" y2="10" stroke="#6b7280" stroke-width="1.5"/><line x1="10" y1="6" x2="6" y2="10" stroke="#6b7280" stroke-width="1.5"/></svg></div>';
      card.innerHTML = toolbar + cardsHtml + grip;
      document.getElementById('mbPanelGrid').appendChild(card);
      makePanelInteractive(card, uid);
      renderCardsInPanel(uid, panel);
      var grid = document.getElementById('mbPanelGrid');
      grid.style.minHeight = (card.offsetTop + card.offsetHeight + 20) + 'px';
      updateEmptyState();
      return;
    }

    card.style.cssText = 'position:absolute;width:420px;height:300px;display:flex;flex-direction:column;background:#fff;border-radius:8px;' +
      'box-shadow:0 2px 8px rgba(0,0,0,0.12);overflow:visible;' +
      'left:' + px + 'px;top:' + py + 'px;z-index:' + (++__mbZTop) + ';' +
      (isStaging ? 'border:2px dashed #3b82f6;' : 'border:1px solid #e2e8f0;');

    // Header
    var hdrBg = isStaging ? '#eff6ff' : '#f8fafc';
    var hdrBorder = isStaging ? 'border-bottom:1px solid #bfdbfe' : 'border-bottom:1px solid #f1f5f9';
    var hdr = '<div data-panel-header style="background:' + hdrBg + ';padding:8px 10px;' + hdrBorder + ';display:flex;align-items:center;justify-content:space-between;border-radius:8px 8px 0 0">' +
      '<div style="display:flex;align-items:center;gap:6px;min-width:0;overflow:hidden">' +
      '<i class="bi bi-grip-vertical" style="color:#9ca3af;font-size:0.75rem;flex-shrink:0;cursor:move"></i>' +
      (isStaging ? '<span style="font-size:0.58rem;background:#3b82f6;color:#fff;padding:1px 5px;border-radius:3px;font-weight:700;flex-shrink:0;letter-spacing:0.4px">PREVIEW</span>' : '') +
      '<span style="font-size:0.82rem;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + _esc(panel.title || 'Panel') + '</span>' +
      '</div><div style="display:flex;gap:4px;align-items:center;flex-shrink:0">';
    if (isStaging) {
      hdr += '<button class="btn btn-primary btn-sm py-0 px-2" onclick="addPanelToQueue()" style="font-size:0.7rem"><i class="bi bi-plus-circle me-1"></i>Add to Dashboard</button>' +
             '<button class="btn btn-sm btn-link text-secondary p-0 ms-1" onclick="clearPreview()" title="Dismiss"><i class="bi bi-x-lg" style="font-size:0.7rem"></i></button>';
    } else {
      var _mbTypes = ['bar','line','pie','doughnut','table','cards'];
      hdr += '<select onchange="mbChangeChartType(\''+uid+'\',this.value)" style="font-size:0.6rem;padding:1px 4px;border:1px solid #e2e8f0;border-radius:4px;background:#f8fafc;color:#6b7280;cursor:pointer">';
      _mbTypes.forEach(function(t){ hdr += '<option value="'+t+'"'+(t===(panel.chartType||'bar')?' selected':'')+'>'+t+'</option>'; });
      hdr += '</select>' +
             '<button class="btn btn-sm btn-link text-danger p-0 ms-1" onclick="removeMbCanvasPanel(\'' + uid + '\')" title="Remove"><i class="bi bi-x-lg" style="font-size:0.7rem"></i></button>';
    }
    hdr += '</div></div>';

    // Body -- flex:1 so it fills whatever height the card has
    var body = '<div data-mb-panel-body style="flex:1;min-height:0;padding:8px;overflow:hidden;display:flex;flex-direction:column">';
    if (!panel.hasData) {
      body += '<div style="text-align:center;padding:2rem;color:#9ca3af;font-size:0.82rem"><i class="bi bi-inbox" style="font-size:1.8rem;display:block;opacity:0.3;margin-bottom:6px"></i>No data returned</div>';
    } else if (panel.chartType === 'cards') {
      body += '<div id="mbCardBody-' + uid + '" style="display:flex;flex-wrap:wrap;gap:7px;padding:4px"></div>';
    } else if (panel.chartType === 'table' || !panel.chartConfig) {
      body += buildTableBodyHTML(panel);
    } else {
      body += '<div style="position:relative;flex:1;min-height:0"><canvas id="mbCanvas-' + uid + '"></canvas></div>';
    }
    body += '</div>';

    // SE resize grip (overlays the bottom-right corner; card overflow:visible lets it show)
    var grip = '<div data-resize-grip style="position:absolute;right:-1px;bottom:-1px;width:18px;height:18px;cursor:se-resize;z-index:20;display:flex;align-items:flex-end;justify-content:flex-end;padding:2px;background:transparent">' +
      '<svg width="10" height="10" viewBox="0 0 10 10" style="opacity:0.45"><line x1="10" y1="2" x2="2" y2="10" stroke="#6b7280" stroke-width="1.5"/><line x1="10" y1="6" x2="6" y2="10" stroke="#6b7280" stroke-width="1.5"/></svg></div>';

    // Inner clip wrapper so body content doesn't overflow the rounded card
    var clipOpen  = '<div style="position:absolute;inset:0;display:flex;flex-direction:column;border-radius:8px;overflow:hidden;pointer-events:none"><div style="pointer-events:auto;display:flex;flex-direction:column;height:100%">';
    var clipClose = '</div></div>';

    card.innerHTML = clipOpen + hdr + body + clipClose + grip;
    document.getElementById('mbPanelGrid').appendChild(card);

    makePanelInteractive(card, uid);

    // Render chart / cards after DOM insertion
    if (panel.hasData) {
      if (panel.chartType === 'cards') {
        renderCardsInPanel(uid, panel);
      } else if (panel.chartConfig && panel.chartType !== 'table') {
        requestAnimationFrame(function() {
          var canvas = document.getElementById('mbCanvas-' + uid); if (!canvas) return;
          var cfg = JSON.parse(JSON.stringify(panel.chartConfig));
          cfg.options = cfg.options || {};
          cfg.options.animation = false; cfg.options.responsive = true; cfg.options.maintainAspectRatio = false;
          window.__aiCharts[uid] = new Chart(canvas.getContext('2d'), cfg);
          // Add click handler to select chart for configuration
          canvas.addEventListener('click', function() { selectMbChartForConfig(uid); });
        });
      }
    }

    // Expand canvas floor so scroll works
    var grid = document.getElementById('mbPanelGrid');
    grid.style.minHeight = (card.offsetTop + card.offsetHeight + 20) + 'px';
    updateEmptyState();
  }

  // ── Update selected chart configuration ───────────────────────────────────────
  window.updateSelectedChartConfig = function() {
    var uid = window.__selectedPanelForConfig;
    if (!uid || !window.__aiPanelData[uid]) return;

    var panel = window.__aiPanelData[uid];
    var newChartType = (document.querySelector('input[name="mbChart"]:checked') || {}).value || 'bar';
    
    console.log('Updating chart config for:', uid, 'New chart type:', newChartType, 'Panel has table:', !!panel.table);
    
    // Get new values from Panel Configuration form fields
    var newConfig = {
      table: document.getElementById('mbTable').value,
      joinTable: document.getElementById('mbJoinTable').value || null,
      dimension: document.getElementById('mbDimension').value || null,
      measure: document.getElementById('mbMeasure').value || null,
      aggregation: (document.querySelector('input[name="mbAgg"]:checked') || {}).value || 'COUNT',
      chartType: newChartType,
      limit: parseInt(document.getElementById('mbLimit').value) || 20,
      sourceId: document.getElementById('mbSourceSel').value || null,
      filters: getFilters()
    };

    // Update panel data
    panel.chartType = newConfig.chartType;
    if (newConfig.table) panel.table = newConfig.table;
    if (newConfig.dimension !== null) panel.dimension = newConfig.dimension;
    if (newConfig.measure !== null) panel.measure = newConfig.measure;
    if (newConfig.aggregation) panel.aggregation = newConfig.aggregation;
    if (newConfig.limit) panel.limit = newConfig.limit;

    // Only fetch new data if we have complete table/dimension/measure configuration
    if (newConfig.table && newConfig.dimension && newConfig.measure) {
      console.log('Have complete config, fetching new data');
      
      // Show loading state on the chart
      var card = document.getElementById('mbCard-' + uid) || document.getElementById('aiCard-' + uid);
      var body = card ? (card.querySelector('[data-mb-panel-body]') || card.querySelector('[id^="aiCardBody-"]')) : null;
      if (body && !body.classList.contains('updating')) {
        body.classList.add('updating');
      }

      // Fetch updated panel data from server
      fetch('/dashboard/manual-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sourceId: newConfig.sourceId,
          tableKey: newConfig.table,
          joinTableKey: newConfig.joinTable,
          dimension: newConfig.dimension,
          measure: newConfig.measure,
          aggregation: newConfig.aggregation,
          chartType: newConfig.chartType,
          limit: newConfig.limit,
          filters: newConfig.filters,
          title: panel.title
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(updatedPanel) {
        if (updatedPanel.error) {
          console.error('Error updating chart:', updatedPanel.error);
          return;
        }

        // Update panel data with new response data
        panel.hasData = updatedPanel.hasData;
        panel.labels = updatedPanel.labels;
        panel.datasets = updatedPanel.datasets;
        panel.chartConfig = updatedPanel.chartConfig;

        // Update the chart on canvas
        updateChartOnCanvas(uid, updatedPanel);
      })
      .catch(function(e) {
        console.error('Failed to update chart:', e);
      })
      .finally(function() {
        if (body) body.classList.remove('updating');
      });
    } else {
      // No complete config, just change the chart type visualization
      console.log('Incomplete config, just changing chart type visualization');
      
      if (!panel.chartConfig || !panel.labels) {
        console.log('Panel has no chartConfig, cannot change visualization');
        return;
      }

      // Rebuild chartConfig with new chart type but same data
      var oldConfig = panel.chartConfig;
      panel.chartConfig = {
        type: newChartType,
        data: oldConfig.data || { labels: panel.labels || [], datasets: panel.datasets || [] },
        options: oldConfig.options || {}
      };

      // Update the chart visualization
      updateChartOnCanvas(uid, panel);
    }
  };

  // ── Update chart instance on canvas ────────────────────────────────────────────
  function updateChartOnCanvas(uid, updatedPanel) {
    var panel = window.__aiPanelData[uid];
    if (!panel) return;

    // For cards type panels - try both ID patterns
    if (updatedPanel.chartType === 'cards' && updatedPanel.hasData) {
      var cardBody = document.getElementById('mbCardBody-' + uid) || document.getElementById('aiCardBody-' + uid);
      if (cardBody) {
        renderCardsInPanel(uid, updatedPanel);
      }
      return;
    }

    // For table type panels - try both card ID patterns
    if (updatedPanel.chartType === 'table' || !updatedPanel.chartConfig) {
      var card = document.getElementById('mbCard-' + uid) || document.getElementById('aiCard-' + uid);
      if (card) {
        var body = card.querySelector('[data-mb-panel-body]') || card.querySelector('[id^="aiCardBody-"]');
        if (body) {
          if (updatedPanel.hasData) {
            body.innerHTML = buildTableBodyHTML(updatedPanel);
          } else {
            body.innerHTML = '<div style="text-align:center;padding:2rem;color:#9ca3af;font-size:0.82rem"><i class="bi bi-inbox" style="font-size:1.8rem;display:block;opacity:0.3;margin-bottom:6px"></i>No data returned</div>';
          }
        }
      }
      return;
    }

    // For chart type panels (bar, line, pie, etc.)
    var chart = window.__aiCharts[uid];
    if (chart) {
      chart.destroy();
      delete window.__aiCharts[uid];
    }

    if (updatedPanel.hasData && updatedPanel.chartConfig) {
      // Try both canvas ID patterns (manually created vs preloaded)
      var canvas = document.getElementById('mbCanvas-' + uid) || document.getElementById('chart-' + uid);
      if (canvas) {
        requestAnimationFrame(function() {
          var cfg = JSON.parse(JSON.stringify(updatedPanel.chartConfig));
          cfg.options = cfg.options || {};
          cfg.options.animation = false;
          cfg.options.responsive = true;
          cfg.options.maintainAspectRatio = false;
          window.__aiCharts[uid] = new Chart(canvas.getContext('2d'), cfg);
          canvas.addEventListener('click', function() { selectMbChartForConfig(uid); });
        });
      }
    } else {
      // No data returned - try both card ID patterns
      var card = document.getElementById('mbCard-' + uid) || document.getElementById('aiCard-' + uid);
      if (card) {
        var body = card.querySelector('[data-mb-panel-body]') || card.querySelector('[id^="aiCardBody-"]');
        if (body) {
          body.innerHTML = '<div style="text-align:center;padding:2rem;color:#9ca3af;font-size:0.82rem"><i class="bi bi-inbox" style="font-size:1.8rem;display:block;opacity:0.3;margin-bottom:6px"></i>No data returned</div>';
        }
      }
    }
  }

  // ── Preview on canvas ─────────────────────────────────────────────────────────
  window.previewPanel = function() {
    var tableKey = document.getElementById('mbTable').value;
    if (!tableKey) { alert('Please select a table.'); return; }
    var dimVal = document.getElementById('mbDimension').value;
    var mesVal = document.getElementById('mbMeasure').value;
    var chartType = (document.querySelector('input[name="mbChart"]:checked') || {}).value || 'bar';
    if (chartType !== 'cards' && !dimVal) { alert('Please select a dimension.'); return; }
    if (chartType !== 'cards' && !mesVal) { alert('Please select a measure.'); return; }
    var joinKey   = document.getElementById('mbJoinTable').value;
    var agg       = (document.querySelector('input[name="mbAgg"]:checked') || {}).value || 'COUNT';
    var limit     = document.getElementById('mbLimit').value;
    var title     = document.getElementById('mbTitle').value.trim();
    var sourceId  = document.getElementById('mbSourceSel').value;
    var filters   = getFilters();
    var btn = document.getElementById('mbPreviewBtn');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Loading...';
    fetch('/dashboard/manual-panel', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ sourceId:sourceId||null, tableKey:tableKey, joinTableKey:joinKey||null,
        dimension:dimVal||null, measure:mesVal, aggregation:agg, chartType:chartType,
        limit:parseInt(limit), filters:filters, title:title }),
    })
    .then(function(r){ return r.json(); })
    .then(function(panel) {
      if (panel.error) { alert('Error: ' + panel.error); return; }
      __preview = panel;
      renderPanelOnCanvas(panel, true);
      document.getElementById('mbAddBtn').disabled = false;
      // Scroll canvas to show the new card
      var canvas = document.getElementById('mbCanvas');
      if (canvas) canvas.scrollTop = canvas.scrollHeight;
    })
    .catch(function(e){ alert('Request failed: ' + e.message); })
    .finally(function(){ btn.disabled = false; btn.innerHTML = '<i class="bi bi-play-fill me-1"></i>Preview on Canvas'; });
  };

  window.clearPreview = function() {
    var old = document.getElementById('mbCard-staging');
    if (old) { if (window.__aiCharts['staging']) { window.__aiCharts['staging'].destroy(); delete window.__aiCharts['staging']; } old.remove(); }
    document.getElementById('mbAddBtn').disabled = true;
    __preview = null;
    updateEmptyState();
  };

  window.addPanelToQueue = function() {
    if (!__preview) return;
    var panel = JSON.parse(JSON.stringify(__preview));
    clearPreview();
    window.__aiQueue.push(panel);
    renderPanelOnCanvas(panel, false);
    updateQueueCount();
    // Reset title for next panel
    document.getElementById('mbTitle').value = '';
    document.getElementById('mbTitle').dataset.userEdited = '';
    updateTitle();
  };

  // ── Drag-to-resize panels ───────────────────────────────────────────────────
  (function initResizers() {
    function makeResizer(handleId, panelId, side) {
      // side: 'left' = resizing schema panel (drag right = wider)
      //       'right' = resizing config panel (drag left = wider)
      var handle = document.getElementById(handleId);
      var panel  = document.getElementById(panelId);
      if (!handle || !panel) return;

      handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        var startX    = e.clientX;
        var startWidth = panel.getBoundingClientRect().width;
        var workspace  = document.getElementById('mbWorkspace');
        var ww = workspace ? workspace.getBoundingClientRect().width : window.innerWidth;

        handle.style.background = '#3b82f6';
        document.body.style.cursor = 'col-resize';

        function onMove(ev) {
          var dx = ev.clientX - startX;
          var newW = side === 'left' ? startWidth + dx : startWidth - dx;
          var minW  = 120;
          var maxW  = ww * 0.45;
          newW = Math.max(minW, Math.min(maxW, newW));
          panel.style.width    = newW + 'px';
          panel.style.minWidth = '0';
        }

        function onUp() {
          handle.style.background = '#e5e7eb';
          document.body.style.cursor = '';
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup',   onUp);
        }

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup',   onUp);
      });

      // Hover highlight
      handle.addEventListener('mouseenter', function() { if (handle.style.background !== 'rgb(59, 130, 246)') handle.style.background = '#c7d2fe'; });
      handle.addEventListener('mouseleave', function() { if (handle.style.background !== 'rgb(59, 130, 246)') handle.style.background = '#e5e7eb'; });
    }

    makeResizer('mbResizeSchema', 'mbSchemaPanel', 'left');
    makeResizer('mbResizeConfig', 'mbConfigPanel', 'right');
  })();

  // ── Select chart for configuration ──────────────────────────────────────────
  window.selectMbChartForConfig = function(uid) {
    var panel = window.__aiPanelData[uid];
    if (!panel) {
      console.error('Panel not found for uid:', uid);
      return;
    }

    // Store selected panel UID for use in updateSelectedChartConfig()
    window.__selectedPanelForConfig = uid;

    // Remove previous highlight from both mode card patterns
    var allCards = document.querySelectorAll('[id^="mbCard-"],[id^="aiCard-"]');
    allCards.forEach(function(card) {
      card.style.borderColor = '';
      card.style.boxShadow = '';
    });

    // Highlight selected chart - check both ID patterns
    var card = document.getElementById('mbCard-' + uid) || document.getElementById('aiCard-' + uid);
    if (card) {
      card.style.borderColor = '#3b82f6';
      card.style.boxShadow = '0 0 0 3px rgba(59, 130, 246, 0.1), 0 2px 8px rgba(59, 130, 246, 0.2)';
    }

    // Log for debugging
    console.log('Selected panel UID:', uid, 'Panel data:', panel);

    // Check if this is an AI-generated panel (no table property)
    var isAiGenerated = !panel.table;
    
    // Populate Panel Configuration panel
    var tableEl = document.getElementById('mbTable');
    if (tableEl) {
      if (isAiGenerated) {
        tableEl.value = '';
        tableEl.disabled = true;
        tableEl.title = 'This panel was AI-generated. Create a new panel in Manual Builder to configure from a table.';
      } else {
        tableEl.value = panel.table || '';
        tableEl.disabled = false;
      }
      console.log('Set table to:', tableEl.value, 'AI-Generated:', isAiGenerated);
    }

    var joinEl = document.getElementById('mbJoinTable');
    if (joinEl) {
      if (isAiGenerated) {
        joinEl.value = '';
        joinEl.disabled = true;
      } else {
        joinEl.value = panel.joinTable || '';
        joinEl.disabled = false;
      }
    }

    var dimEl = document.getElementById('mbDimension');
    if (dimEl) {
      if (isAiGenerated) {
        dimEl.value = '';
        dimEl.disabled = true;
        dimEl.title = 'This panel was AI-generated. Create a new panel in Manual Builder to configure dimensions.';
      } else {
        dimEl.value = panel.dimension || '';
        dimEl.disabled = false;
      }
      console.log('Set dimension to:', dimEl.value);
    }

    var mesEl = document.getElementById('mbMeasure');
    if (mesEl) {
      if (isAiGenerated) {
        mesEl.value = '';
        mesEl.disabled = true;
        mesEl.title = 'This panel was AI-generated. Create a new panel in Manual Builder to configure measures.';
      } else {
        mesEl.value = panel.measure || '';
        mesEl.disabled = false;
      }
      console.log('Set measure to:', mesEl.value);
    }

    // Aggregation
    var aggRadios = document.querySelectorAll('input[name="mbAgg"]');
    var agg = panel.aggregation || 'COUNT';
    aggRadios.forEach(function(radio) {
      radio.checked = (radio.value === agg);
      radio.disabled = isAiGenerated;
    });
    console.log('Set aggregation to:', agg);

    // Chart Type (always enabled - user can change visualization)
    var chartRadios = document.querySelectorAll('input[name="mbChart"]');
    var chartType = panel.chartType || 'bar';
    chartRadios.forEach(function(radio) {
      radio.checked = (radio.value === chartType);
      // Chart type radio remains ENABLED - user can always change visualization
    });
    console.log('Set chart type to:', chartType);
    
    // Limit
    var limitEl = document.getElementById('mbLimit');
    if (limitEl) {
      limitEl.value = panel.limit || 20;
      limitEl.disabled = isAiGenerated;
    }
    
    // Add visual indicator for AI-generated panels
    if (isAiGenerated) {
      var configPanel = document.getElementById('mbConfigPanel');
      if (configPanel) {
        var existing = configPanel.querySelector('.ai-generated-badge');
        if (!existing) {
          var badge = document.createElement('div');
          badge.className = 'ai-generated-badge';
          badge.style.cssText = 'background:#f0f9ff;border:1px solid #bae6fd;border-radius:4px;padding:8px 12px;margin-bottom:12px;color:#0c4a6e;font-size:0.75rem;font-weight:600;display:flex;align-items:center;gap:6px';
          badge.innerHTML = '<i class="bi bi-stars" style="color:#0284c7;font-size:0.9rem"></i>AI-Generated Panel - Change chart type as needed';
          configPanel.insertBefore(badge, configPanel.firstChild);
        }
      }
    } else {
      var configPanel = document.getElementById('mbConfigPanel');
      if (configPanel) {
        var existing = configPanel.querySelector('.ai-generated-badge');
        if (existing) existing.remove();
      }
    }
    
    // Trigger change event to update visibility of dimension field
    var checkedRadio = document.querySelector('input[name="mbChart"]:checked');
    if (checkedRadio) {
      var event = new Event('change', { bubbles: true });
      checkedRadio.dispatchEvent(event);
    }

    // Scroll config panel to top
    var configPanel = document.getElementById('mbConfigPanel');
    if (configPanel) configPanel.scrollTop = 0;
  };

  window.submitManualDashboard = function() {
    if (window.__aiQueue.length === 0) return;
    document.getElementById('mbPanelsJson').value = JSON.stringify(window.__aiQueue);
    document.getElementById('mbGenerateForm').submit();
  };

  window.submitMbFullDashboard = function() {
    // Sync source selection then switch to AI Mode and run full dashboard
    var sourceId = (document.getElementById('mbSourceSel') || {}).value || '';
    var aiSel = document.getElementById('aiSourceSel');
    if (aiSel && sourceId) aiSel.value = sourceId;
    switchMode('ai');
    setTimeout(function() { submitAiFullDashboard(); }, 300);
  };

})();
</script>


