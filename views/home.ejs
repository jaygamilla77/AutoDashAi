<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AutoDash AI – Home</title>
  <meta name="description" content="AutoDash AI authenticated home — KPIs, recent dashboards, quick actions, and activity. Powered by Liknaya.com.">
  <meta name="theme-color" content="#3366FF">
  <meta name="robots" content="noindex,nofollow">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">

  <style>
    /* ───────────────── Modern SaaS dashboard — scoped to /dashboard home ───────────────── */
    :root {
      --bg: #F7F8FA;
      --surface: #FFFFFF;
      --border: #ECEEF2;
      --border-strong: #E2E5EB;
      --text: #0F172A;
      --text-muted: #64748B;
      --text-soft: #94A3B8;
      --primary: #3366FF;
      --primary-50: #EEF3FF;
      --primary-600: #2952E6;
      --success: #10B981;
      --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
      --shadow-md: 0 4px 14px -6px rgba(15, 23, 42, 0.08);
      --radius: 14px;
      --radius-sm: 10px;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body.home-shell {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      font-size: 14px;
    }

    /* Sidebar — use the shared/global sidebar styles (no home-specific overrides). */

    /* Main content wrapper — unified app-page spec */
    body.home-shell .home-main {
      margin-left: 80px;
      max-width: calc(1600px + 80px);
      padding: 24px 10px 32px 10px;
    }

    /* Top bar */
    .home-topbar {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; margin-bottom: 28px;
    }
    .home-topbar-left h1 {
      font-size: 22px; font-weight: 700; letter-spacing: -0.01em;
      margin: 0 0 4px; color: var(--text);
    }
    .home-topbar-left p { margin: 0; color: var(--text-muted); font-size: 13.5px; }

    .topbar-actions { display: flex; align-items: center; gap: 12px; }
    .icon-btn {
      width: 36px; height: 36px;
      display: inline-flex; align-items: center; justify-content: center;
      border-radius: 8px; border: 1px solid var(--border);
      background: var(--surface); color: var(--text-muted);
      cursor: pointer; text-decoration: none;
      position: relative;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .icon-btn:hover { background: #F3F5F9; color: var(--text); }
    .icon-btn .dot {
      position: absolute; top: 8px; right: 9px;
      width: 7px; height: 7px; border-radius: 50%;
      background: #EF4444; border: 2px solid var(--surface);
    }

    .user-chip {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 4px 10px 4px 4px;
      border: 1px solid var(--border); border-radius: 999px;
      background: var(--surface);
    }
    .user-chip .avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, #3366FF, #4F46E5);
      color: #fff; font-weight: 700; font-size: 12px;
      display: inline-flex; align-items: center; justify-content: center;
    }
    .user-chip .meta { display: flex; flex-direction: column; line-height: 1.1; }
    .user-chip .meta .nm { font-size: 13px; font-weight: 600; color: var(--text); }
    .user-chip .meta .role { font-size: 11px; color: var(--text-soft); }
    .user-chip .caret { color: var(--text-soft); margin-right: 6px; font-size: 12px; }

    .btn-create {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--primary); color: #fff !important;
      border: 0; border-radius: 8px;
      padding: 9px 16px;
      font-weight: 600; font-size: 13.5px;
      box-shadow: 0 4px 12px -4px rgba(51,102,255,0.5);
      cursor: pointer; text-decoration: none;
      transition: background 0.15s, transform 0.1s;
    }
    .btn-create:hover { background: var(--primary-600); }
    .btn-create:active { transform: translateY(1px); }
    .btn-create-split {
      display: inline-flex; align-items: stretch;
      border-radius: 8px; overflow: hidden;
      box-shadow: 0 4px 12px -4px rgba(51,102,255,0.5);
    }
    .btn-create-split .btn-create { box-shadow: none; border-radius: 0; }
    .btn-create-split .caret-btn {
      background: var(--primary-600); color: #fff;
      border: 0; padding: 0 10px;
      cursor: pointer; font-size: 12px;
      display: inline-flex; align-items: center;
    }
    .btn-create-split .caret-btn:hover { background: #1F3FCC; }

    /* KPI grid */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 22px;
    }
    .kpi-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      box-shadow: var(--shadow-sm);
      display: flex; align-items: center; gap: 14px;
      transition: box-shadow 0.15s, transform 0.1s;
    }
    .kpi-card:hover { box-shadow: var(--shadow-md); }
    .kpi-icon {
      width: 44px; height: 44px; border-radius: 10px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .kpi-icon.blue   { background: #EEF3FF; color: #3366FF; }
    .kpi-icon.green  { background: #ECFDF5; color: #10B981; }
    .kpi-icon.violet { background: #F3EEFF; color: #7C3AED; }
    .kpi-icon.amber  { background: #FFF7ED; color: #F59E0B; }
    .kpi-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .kpi-label { font-size: 12.5px; color: var(--text-muted); font-weight: 500; }
    .kpi-value-row { display: flex; align-items: baseline; gap: 8px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: var(--text); letter-spacing: -0.01em; line-height: 1.1; }
    .kpi-trend { font-size: 11.5px; color: var(--success); font-weight: 600; display: inline-flex; align-items: center; gap: 2px; }
    .kpi-sub { font-size: 11.5px; color: var(--text-soft); }

    /* Two-column row */
    .home-row {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 16px;
      margin-bottom: 22px;
    }

    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      padding: 22px 22px;
    }
    .panel-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px;
    }
    .panel-title { font-size: 15px; font-weight: 700; color: var(--text); margin: 0; }
    .panel-link {
      font-size: 12.5px; color: var(--primary); font-weight: 600;
      text-decoration: none;
    }
    .panel-link:hover { text-decoration: underline; }

    /* Wizard hero */
    .wizard-hero {
      background: linear-gradient(180deg, #EEF3FF 0%, #F8FAFF 100%);
      border: 1px solid #DCE5FF;
    }
    .wizard-hero .hero-icon {
      width: 44px; height: 44px; border-radius: 10px;
      background: var(--surface); color: var(--primary);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 20px; box-shadow: var(--shadow-sm);
      margin-bottom: 14px;
    }
    .wizard-hero h2 {
      font-size: 19px; font-weight: 700; margin: 0 0 8px;
      letter-spacing: -0.01em;
    }
    .wizard-hero p { font-size: 13.5px; color: var(--text-muted); margin: 0 0 18px; max-width: 460px; }

    .btn-primary-solid {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--primary); color: #fff !important;
      border: 0; border-radius: 8px;
      padding: 10px 18px;
      font-weight: 600; font-size: 13.5px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .btn-primary-solid:hover { background: var(--primary-600); }

    /* Quick actions grid */
    .qa-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .qa-card {
      display: flex; align-items: center; gap: 12px;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      text-decoration: none; color: inherit;
      transition: border-color 0.15s, background 0.15s, transform 0.1s;
    }
    .qa-card:hover { border-color: #C7D2FE; background: #FAFBFF; transform: translateY(-1px); }
    .qa-icon {
      width: 40px; height: 40px; border-radius: 10px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .qa-text { display: flex; flex-direction: column; gap: 2px; }
    .qa-text .t { font-size: 13.5px; font-weight: 600; color: var(--text); }
    .qa-text .s { font-size: 11.5px; color: var(--text-muted); }

    /* List items (recent dashboards & activity feed) */
    .list-item {
      display: flex; align-items: center; gap: 14px;
      padding: 12px 4px;
      border-bottom: 1px solid var(--border);
      text-decoration: none; color: inherit;
    }
    .list-item:last-child { border-bottom: 0; }
    .list-icon {
      width: 38px; height: 38px; border-radius: 9px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 17px; flex-shrink: 0;
    }
    .list-icon.blue   { background: #EEF3FF; color: #3366FF; }
    .list-icon.green  { background: #ECFDF5; color: #10B981; }
    .list-icon.violet { background: #F3EEFF; color: #7C3AED; }
    .list-icon.amber  { background: #FFF7ED; color: #F59E0B; }
    .list-icon.pink   { background: #FFF1F2; color: #EC4899; }
    .list-body { flex: 1; min-width: 0; }
    .list-title { font-size: 13.5px; font-weight: 600; color: var(--text); margin: 0 0 2px; }
    .list-sub { font-size: 12px; color: var(--text-muted); }

    .badge-pill {
      display: inline-flex; align-items: center;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 11px; font-weight: 600;
      background: #F3F5F9; color: var(--text-muted);
    }
    .badge-pill.team { background: #ECFDF5; color: #047857; }

    .row-actions-btn {
      width: 28px; height: 28px;
      border: 0; background: transparent;
      border-radius: 6px; color: var(--text-soft);
      cursor: pointer;
    }
    .row-actions-btn:hover { background: #F3F5F9; color: var(--text); }

    .empty {
      text-align: center; padding: 28px 12px; color: var(--text-muted); font-size: 13px;
    }

    /* Responsive */
    @media (max-width: 1100px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .home-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      body.home-shell .sidebar { display: none; }
      body.home-shell .home-main { margin-left: 0; padding: 16px 16px 24px; }
      .qa-grid { grid-template-columns: 1fr; }
      .home-topbar { flex-direction: column; align-items: stretch; }
      .topbar-actions { justify-content: flex-end; }
    }
  </style>
</head>
<body class="home-shell">
<%
  // Defensive defaults so this template renders even if a caller forgets locals.
  var stats = (typeof stats !== 'undefined' && stats) ? stats : { dashboards: 0, sources: 0, insights: 0, members: 1 };
  var activity = (typeof activity !== 'undefined' && activity) ? activity : [];
  var recentDashboards = (typeof recentDashboards !== 'undefined' && recentDashboards) ? recentDashboards : [];
  var userDisplayName = (typeof userDisplayName !== 'undefined' && userDisplayName) ? userDisplayName : 'there';
%>

  <%- include('partials/sidebar') %>

  <main class="home-main">

    <!-- ───── Top bar ───── -->
    <div class="home-topbar">
      <div class="home-topbar-left">
        <h1>Welcome back, <%= userDisplayName || 'there' %>! <span aria-hidden="true">👋</span></h1>
        <p>Create intelligent dashboards in minutes with the power of AI.</p>
      </div>
      <div class="topbar-actions">
        <a href="/admin/inquiries" class="icon-btn" title="Help &amp; support" aria-label="Help">
          <i class="bi bi-question-circle"></i>
        </a>
        <a href="/admin/inquiries" class="icon-btn" title="Notifications" aria-label="Notifications">
          <i class="bi bi-bell"></i>
          <span class="dot" aria-hidden="true"></span>
        </a>
        <div class="user-chip" title="<%= userDisplayName %>">
          <span class="avatar"><%= (userDisplayName || 'U').trim().charAt(0).toUpperCase() %></span>
          <span class="meta">
            <span class="nm"><%= userDisplayName || 'User' %></span>
            <span class="role">Admin</span>
          </span>
          <i class="bi bi-chevron-down caret"></i>
        </div>
        <div class="btn-create-split" role="group" aria-label="Create dashboard">
          <a href="/wizard" class="btn-create"><i class="bi bi-plus-lg"></i> Create Dashboard</a>
          <button class="caret-btn" type="button" aria-label="More create options" onclick="window.location.href='/ai-builder'">
            <i class="bi bi-chevron-down"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- ───── KPI cards ───── -->
    <section class="kpi-grid" aria-label="Key metrics">
      <div class="kpi-card">
        <div class="kpi-icon blue"><i class="bi bi-grid-3x3-gap-fill"></i></div>
        <div class="kpi-body">
          <div class="kpi-label">Total Dashboards</div>
          <div class="kpi-value-row">
            <span class="kpi-value"><%= stats.dashboards %></span>
            <span class="kpi-trend"><i class="bi bi-arrow-up"></i> 12.5%</span>
          </div>
          <div class="kpi-sub">vs last month</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon green"><i class="bi bi-database-fill"></i></div>
        <div class="kpi-body">
          <div class="kpi-label">Total Data Sources</div>
          <div class="kpi-value-row">
            <span class="kpi-value"><%= stats.sources %></span>
            <span class="kpi-trend"><i class="bi bi-arrow-up"></i> 8.3%</span>
          </div>
          <div class="kpi-sub">vs last month</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon violet"><i class="bi bi-stars"></i></div>
        <div class="kpi-body">
          <div class="kpi-label">AI Insights Generated</div>
          <div class="kpi-value-row">
            <span class="kpi-value"><%= stats.insights %></span>
            <span class="kpi-trend"><i class="bi bi-arrow-up"></i> 15.7%</span>
          </div>
          <div class="kpi-sub">vs last month</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon amber"><i class="bi bi-people-fill"></i></div>
        <div class="kpi-body">
          <div class="kpi-label">Team Members</div>
          <div class="kpi-value-row">
            <span class="kpi-value"><%= stats.members %></span>
            <span class="kpi-trend"><i class="bi bi-arrow-up"></i> 14.2%</span>
          </div>
          <div class="kpi-sub">vs last month</div>
        </div>
      </div>
    </section>

    <!-- ───── Wizard hero + Quick actions ───── -->
    <section class="home-row">
      <div class="panel wizard-hero">
        <div class="hero-icon"><i class="bi bi-magic"></i></div>
        <h2>Create Dashboard via Wizard</h2>
        <p>Answer a few questions and let AI build the perfect dashboard for your data.</p>
        <a href="/wizard" class="btn-primary-solid">Get Started <i class="bi bi-arrow-right"></i></a>
      </div>

      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Quick Actions</h2>
        </div>
        <div class="qa-grid">
          <a href="/sources" class="qa-card">
            <span class="qa-icon" style="background:#ECFDF5;color:#10B981;"><i class="bi bi-database-fill"></i></span>
            <span class="qa-text">
              <span class="t">Connect Data Source</span>
              <span class="s">Add new data source</span>
            </span>
          </a>
          <a href="/templates" class="qa-card">
            <span class="qa-icon" style="background:#EEF3FF;color:#3366FF;"><i class="bi bi-grid-1x2-fill"></i></span>
            <span class="qa-text">
              <span class="t">Explore Templates</span>
              <span class="s">Browse dashboard templates</span>
            </span>
          </a>
          <a href="/ai-builder" class="qa-card">
            <span class="qa-icon" style="background:#F3EEFF;color:#7C3AED;"><i class="bi bi-stars"></i></span>
            <span class="qa-text">
              <span class="t">AI Builder</span>
              <span class="s">Build with AI assistance</span>
            </span>
          </a>
          <a href="/" class="qa-card">
            <span class="qa-icon" style="background:#FFF7ED;color:#F59E0B;"><i class="bi bi-file-earmark-text-fill"></i></span>
            <span class="qa-text">
              <span class="t">Documentation</span>
              <span class="s">Learn how to use AutoDash</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- ───── Recent dashboards + Activity feed ───── -->
    <section class="home-row">
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Recent Dashboards</h2>
          <a class="panel-link" href="/dashboard/history">View all</a>
        </div>
        <% if (recentDashboards && recentDashboards.length > 0) { %>
          <% recentDashboards.slice(0, 4).forEach(function (d, idx) {
               var tones = ['blue','green','violet','amber'];
               var tone = tones[idx % tones.length];
               var visibility = d.visibility || (idx % 3 === 2 ? 'team' : 'private');
               var when = new Date(d.updatedAt || d.createdAt);
               var now = new Date();
               var diffH = Math.max(0, Math.round((now - when) / 36e5));
               var sub = diffH < 1 ? 'Updated just now'
                       : diffH < 24 ? 'Updated ' + diffH + ' hour' + (diffH === 1 ? '' : 's') + ' ago'
                       : 'Updated ' + Math.round(diffH / 24) + ' day' + (Math.round(diffH / 24) === 1 ? '' : 's') + ' ago';
          %>
            <a class="list-item" href="/dashboard/<%= d.id %>">
              <span class="list-icon <%= tone %>"><i class="bi bi-bar-chart-line-fill"></i></span>
              <span class="list-body">
                <div class="list-title"><%= d.title || 'Untitled dashboard' %></div>
                <div class="list-sub"><%= sub %></div>
              </span>
              <span class="badge-pill <%= visibility === 'team' ? 'team' : '' %>"><%= visibility === 'team' ? 'Team' : 'Private' %></span>
              <button type="button" class="row-actions-btn" aria-label="More" onclick="event.preventDefault(); event.stopPropagation();">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
            </a>
          <% }); %>
        <% } else { %>
          <div class="empty">
            <i class="bi bi-bar-chart" style="font-size:24px; color:var(--text-soft);"></i>
            <div style="margin-top:8px;">No dashboards yet. <a href="/wizard" style="color:var(--primary); font-weight:600;">Create your first dashboard</a>.</div>
          </div>
        <% } %>
      </div>

      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Activity Feed</h2>
          <a class="panel-link" href="/dashboard/history">View all</a>
        </div>
        <% if (activity && activity.length > 0) { %>
          <% activity.forEach(function (a) {
               var when = new Date(a.at);
               var now = new Date();
               var diffH = Math.max(0, Math.round((now - when) / 36e5));
               var sub = diffH < 1 ? 'just now'
                       : diffH < 24 ? diffH + ' hour' + (diffH === 1 ? '' : 's') + ' ago'
                       : Math.round(diffH / 24) + ' day' + (Math.round(diffH / 24) === 1 ? '' : 's') + ' ago';
          %>
            <div class="list-item">
              <span class="list-icon <%= a.tone %>"><i class="bi <%= a.icon %>"></i></span>
              <span class="list-body">
                <div class="list-title"><%= a.text %></div>
                <div class="list-sub"><%= sub %></div>
              </span>
            </div>
          <% }); %>
        <% } else { %>
          <div class="empty">
            <i class="bi bi-activity" style="font-size:24px; color:var(--text-soft);"></i>
            <div style="margin-top:8px;">Activity will appear here as you create dashboards.</div>
          </div>
        <% } %>
      </div>
    </section>

  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
