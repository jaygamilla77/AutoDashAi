    </div>

    <!-- Center: Dashboard Canvas -->
    <div id="mbCanvas" style="flex:1;overflow-y:auto;background:#e8eef5;padding:14px;min-width:0">
      <div id="mbEmptyState" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:90%;color:#9ca3af;text-align:center;pointer-events:none">
        <i class="bi bi-grid-1x2" style="font-size:4rem;margin-bottom:14px;opacity:0.2"></i>
        <div style="font-size:1rem;font-weight:600;color:#6b7280">Canvas is empty</div>
        <div style="font-size:0.8rem;margin-top:6px;color:#9ca3af">
          Configure a panel in the <strong style="color:#3b82f6">Config</strong> panel →<br>click <strong style="color:#3b82f6">Preview on Canvas</strong>
