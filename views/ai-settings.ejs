<div class="container py-4" style="max-width:900px">

  <div class="d-flex align-items-center gap-3 mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center"
         style="width:48px;height:48px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;font-size:1.4rem">
      <i class="bi bi-robot"></i>
    </div>
    <div>
      <h2 class="mb-0">AI Settings</h2>
      <p class="text-muted mb-0">Azure OpenAI integration for intelligent prompt parsing and narrative insights</p>
    </div>
  </div>

  <!-- Status Card -->
  <div class="card mb-4" style="border-left:4px solid <%= aiEnabled ? '#22c55e' : '#ef4444' %>">
    <div class="card-body d-flex align-items-center gap-3">
      <div class="rounded-circle d-flex align-items-center justify-content-center"
           style="width:40px;height:40px;background:<%= aiEnabled ? '#dcfce7' : '#fef2f2' %>;color:<%= aiEnabled ? '#16a34a' : '#dc2626' %>;font-size:1.2rem">
        <i class="bi bi-<%= aiEnabled ? 'check-circle-fill' : 'x-circle-fill' %>"></i>
      </div>
      <div class="flex-grow-1">
        <h5 class="mb-1"><%= aiEnabled ? 'AI Connected' : 'AI Not Connected' %></h5>
        <p class="text-muted mb-0 small">
          <% if (aiEnabled) { %>
            Azure OpenAI is active. LLM-powered prompt parsing and narrative insights are enabled.
          <% } else { %>
            Configure your Azure OpenAI credentials in the <code>.env</code> file to enable AI features.
          <% } %>
        </p>
      </div>
      <button id="btnTestAI" class="btn btn-sm <%= aiEnabled ? 'btn-outline-success' : 'btn-outline-secondary' %>"
              onclick="testAIConnection()" <%= aiEnabled ? '' : 'disabled' %>>
        <i class="bi bi-lightning-charge"></i> Test Connection
      </button>
    </div>
  </div>

  <!-- Configuration -->
  <div class="card mb-4">
    <div class="card-header bg-white">
      <h5 class="mb-0"><i class="bi bi-gear"></i> Configuration</h5>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <tbody>
            <tr>
              <td class="text-muted" style="width:180px">Endpoint</td>
              <td><code><%= config.endpoint || 'Not configured' %></code></td>
            </tr>
            <tr>
              <td class="text-muted">Deployment</td>
              <td><code><%= config.deploymentName || 'Not configured' %></code></td>
            </tr>
            <tr>
              <td class="text-muted">API Version</td>
              <td><code><%= config.apiVersion || 'Not configured' %></code></td>
            </tr>
            <tr>
              <td class="text-muted">API Key</td>
              <td>
                <% if (config.hasApiKey) { %>
                  <span class="badge bg-success">Configured</span>
                <% } else { %>
                  <span class="badge bg-danger">Not set</span>
                <% } %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="alert alert-light mt-3 mb-0 small">
        <i class="bi bi-info-circle"></i>
        To update credentials, edit <code>.env</code> in the project root and restart the server:
        <pre class="mt-2 mb-0 small" style="background:#f8f9fa;padding:8px;border-radius:4px">AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=your-model-deployment
AZURE_OPENAI_API_VERSION=2024-02-15-preview</pre>
      </div>
    </div>
  </div>

  <!-- AI Features -->
  <div class="card mb-4">
    <div class="card-header bg-white">
      <h5 class="mb-0"><i class="bi bi-stars"></i> AI-Powered Features</h5>
    </div>
    <div class="card-body p-0">
      <div class="list-group list-group-flush">
        <div class="list-group-item d-flex align-items-start gap-3 py-3">
          <div class="rounded d-flex align-items-center justify-content-center"
               style="min-width:36px;height:36px;background:#ede9fe;color:#7c3aed;font-size:1rem">
            <i class="bi bi-chat-dots"></i>
          </div>
          <div>
            <h6 class="mb-1">Intelligent Prompt Parsing</h6>
            <p class="text-muted small mb-0">
              Natural language questions are interpreted by GPT instead of regex patterns.
              Understands complex queries like "Why did Q1 revenue drop?" or "Compare departments by ticket resolution time."
            </p>
          </div>
          <span class="badge bg-<%= aiEnabled ? 'success' : 'secondary' %> ms-auto"><%= aiEnabled ? 'Active' : 'Off' %></span>
        </div>

        <div class="list-group-item d-flex align-items-start gap-3 py-3">
          <div class="rounded d-flex align-items-center justify-content-center"
               style="min-width:36px;height:36px;background:#fef3c7;color:#d97706;font-size:1rem">
            <i class="bi bi-lightbulb"></i>
          </div>
          <div>
            <h6 class="mb-1">Narrative Insights</h6>
            <p class="text-muted small mb-0">
              Every chart gets an AI-generated explanation: what the data means, key findings,
              and actionable implications — not just numbers, but interpretations.
            </p>
          </div>
          <span class="badge bg-<%= aiEnabled ? 'success' : 'secondary' %> ms-auto"><%= aiEnabled ? 'Active' : 'Off' %></span>
        </div>

        <div class="list-group-item d-flex align-items-start gap-3 py-3">
          <div class="rounded d-flex align-items-center justify-content-center"
               style="min-width:36px;height:36px;background:#dcfce7;color:#16a34a;font-size:1rem">
            <i class="bi bi-magic"></i>
          </div>
          <div>
            <h6 class="mb-1">Smart Suggestions</h6>
            <p class="text-muted small mb-0">
              AI analyzes your data schema and suggests the most valuable questions to ask —
              surfacing insights you might not think to look for.
            </p>
          </div>
          <span class="badge bg-<%= aiEnabled ? 'success' : 'secondary' %> ms-auto"><%= aiEnabled ? 'Active' : 'Off' %></span>
        </div>

        <div class="list-group-item d-flex align-items-start gap-3 py-3">
          <div class="rounded d-flex align-items-center justify-content-center"
               style="min-width:36px;height:36px;background:#dbeafe;color:#2563eb;font-size:1rem">
            <i class="bi bi-file-earmark-text"></i>
          </div>
          <div>
            <h6 class="mb-1">Executive Summary</h6>
            <p class="text-muted small mb-0">
              After generating a full dashboard, get a synthesized executive brief —
              key findings across all panels in 4-5 sentences.
            </p>
          </div>
          <span class="badge bg-<%= aiEnabled ? 'success' : 'secondary' %> ms-auto"><%= aiEnabled ? 'Active' : 'Off' %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Test Result -->
  <div id="testResult" class="alert d-none mb-4" role="alert"></div>

</div>

<script>
async function testAIConnection() {
  const btn = document.getElementById('btnTestAI');
  const result = document.getElementById('testResult');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Testing...';
  result.className = 'alert d-none';

  try {
    const resp = await fetch('/ai/test', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await resp.json();
    result.className = 'alert ' + (data.success ? 'alert-success' : 'alert-danger');
    result.innerHTML = '<i class="bi bi-' + (data.success ? 'check-circle' : 'x-circle') + '"></i> ' + data.message;
    if (data.reply) result.innerHTML += '<br><small class="text-muted">Response: ' + data.reply + '</small>';
  } catch (err) {
    result.className = 'alert alert-danger';
    result.innerHTML = '<i class="bi bi-x-circle"></i> Connection test failed: ' + err.message;
  }

  btn.disabled = false;
  btn.innerHTML = '<i class="bi bi-lightning-charge"></i> Test Connection';
}
</script>
