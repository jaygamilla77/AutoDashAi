<div class="container py-4" style="max-width:960px">

  <div class="d-flex align-items-center gap-3 mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center"
         style="width:48px;height:48px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;font-size:1.4rem">
      <i class="bi bi-robot"></i>
    </div>
    <div>
      <h2 class="mb-0">AI Settings</h2>
      <p class="text-muted mb-0">Configure how this workspace talks to Azure OpenAI</p>
    </div>
  </div>

  <!-- Flash messages -->
  <% if (typeof query !== 'undefined') { %><% } %>
  <% var qs = (typeof query !== 'undefined' && query) ? query : (typeof locals !== 'undefined' ? (locals.query || {}) : {}); %>

  <!-- Effective status -->
  <div class="card mb-4" style="border-left:4px solid <%= aiEnabled ? '#22c55e' : '#ef4444' %>">
    <div class="card-body d-flex align-items-center gap-3">
      <div class="rounded-circle d-flex align-items-center justify-content-center"
           style="width:40px;height:40px;background:<%= aiEnabled ? '#dcfce7' : '#fef2f2' %>;color:<%= aiEnabled ? '#16a34a' : '#dc2626' %>;font-size:1.2rem">
        <i class="bi bi-<%= aiEnabled ? 'check-circle-fill' : 'x-circle-fill' %>"></i>
      </div>
      <div class="flex-grow-1">
        <h5 class="mb-1">
          <%= aiEnabled ? 'AI Connected' : 'AI Not Connected' %>
          <% if (aiEnabled) { %>
            <span class="badge bg-<%= effectiveMode === 'custom' ? 'primary' : 'secondary' %> ms-2">
              <%= effectiveMode === 'custom' ? 'Dedicated Endpoint' : 'Shared System Endpoint' %>
            </span>
          <% } %>
        </h5>
        <p class="text-muted mb-0 small">
          <% if (aiEnabled && effectiveMode === 'custom') { %>
            This workspace is using its own dedicated Azure OpenAI deployment.
            Your prompts and data never traverse the shared system endpoint.
          <% } else if (aiEnabled) { %>
            Using the shared system Azure OpenAI deployment. Switch to a custom
            endpoint below for more privacy and dedicated processing capacity.
          <% } else if (provider === 'custom') { %>
            Custom endpoint is selected but the configuration is incomplete or invalid. Update credentials below.
          <% } else { %>
            No AI is configured for this workspace.
          <% } %>
        </p>
      </div>
      <button class="btn btn-outline-success btn-sm" onclick="testEffective()">
        <i class="bi bi-lightning-charge"></i> Test Connection
      </button>
    </div>
  </div>

  <% var qsAny = (typeof query !== 'undefined' && query) ? query : null; %>
  <% if (qsAny && qsAny.saved) { %>
    <div class="alert alert-success">AI settings saved.</div>
  <% } %>
  <% if (qsAny && qsAny.error) { %>
    <div class="alert alert-danger"><%= qsAny.error %></div>
  <% } %>

  <!-- Mode toggle -->
  <form method="POST" action="/ai-settings" id="aiSettingsForm">
    <div class="card mb-4">
      <div class="card-header bg-light fw-semibold">
        <i class="bi bi-shield-lock"></i> AI Provider
      </div>
      <div class="card-body">

        <!-- Option A: System -->
        <label class="d-flex align-items-start gap-3 p-3 border rounded mb-3 mode-card"
               style="cursor:pointer;" data-mode="system">
          <input class="form-check-input mt-1" type="radio" name="provider" value="system"
                 <%= provider === 'system' ? 'checked' : '' %>>
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2">
              <strong>Use System Built-in (default)</strong>
              <span class="badge bg-secondary">Shared</span>
            </div>
            <div class="text-muted small mt-1">
              Uses AutoDash's managed Azure OpenAI deployment. Quick to start — no setup needed.
              Requests share capacity with other workspaces, so processing time and rate limits depend on overall load.
            </div>
            <% if (systemConfig.endpoint) { %>
              <div class="small text-muted mt-2">
                Endpoint: <code><%= systemConfig.endpoint %></code> · Deployment: <code><%= systemConfig.deploymentName %></code>
              </div>
            <% } else { %>
              <div class="small text-danger mt-2">
                <i class="bi bi-exclamation-triangle"></i> The system endpoint isn't configured on the server.
              </div>
            <% } %>
          </div>
        </label>

        <!-- Option B: Custom -->
        <label class="d-flex align-items-start gap-3 p-3 border rounded mode-card"
               style="cursor:pointer;" data-mode="custom">
          <input class="form-check-input mt-1" type="radio" name="provider" value="custom"
                 <%= provider === 'custom' ? 'checked' : '' %>>
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2">
              <strong>Use Your Own Azure OpenAI Endpoint</strong>
              <span class="badge bg-primary">Recommended for sensitive data</span>
            </div>
            <div class="text-muted small mt-1">
              Plug in your organization's dedicated Azure OpenAI resource.
              <strong class="text-dark">Higher privacy</strong> — your prompts and data only ever hit your own tenant's endpoint, never shared infrastructure.
              <strong class="text-dark">Faster processing</strong> — no contention with other workspaces; your quota and throughput are exclusively yours.
              You stay in control of regional residency, content filtering policies, and audit logs.
            </div>
          </div>
        </label>

        <!-- Custom config fields -->
        <div id="customFields" class="mt-3" style="display:<%= provider === 'custom' ? 'block' : 'none' %>;">
          <div class="row g-3">
            <div class="col-md-12">
              <label class="form-label small fw-semibold">Azure OpenAI Endpoint</label>
              <input type="url" name="endpoint" class="form-control" placeholder="https://your-resource.cognitiveservices.azure.com/"
                     value="<%= customConfig.endpoint || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label small fw-semibold">Deployment Name</label>
              <input type="text" name="deployment" class="form-control" placeholder="gpt-4o"
                     value="<%= customConfig.deployment || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label small fw-semibold">API Version</label>
              <input type="text" name="apiVersion" class="form-control" placeholder="2024-02-15-preview"
                     value="<%= customConfig.apiVersion || '' %>">
            </div>
            <div class="col-md-12">
              <label class="form-label small fw-semibold">
                API Key
                <% if (customConfig.hasApiKey) { %>
                  <span class="badge bg-success ms-1">Stored</span>
                <% } %>
              </label>
              <input type="password" name="apiKey" class="form-control" autocomplete="off"
                     placeholder="<%= customConfig.hasApiKey ? '•••••••••••••• (leave blank to keep)' : 'sk-...' %>">
              <div class="form-text">
                Encrypted at rest with AES-256-GCM before being written to the database. The key is never sent back to the browser.
              </div>
            </div>
            <div class="col-12">
              <button type="button" class="btn btn-outline-success btn-sm" onclick="testCustomFromForm()">
                <i class="bi bi-lightning-charge"></i> Test these credentials
              </button>
              <span id="customTestResult" class="ms-2 small"></span>
            </div>
          </div>
        </div>

      </div>
      <div class="card-footer text-end bg-white">
        <a href="/ai-settings" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary" type="submit"><i class="bi bi-save"></i> Save AI Settings</button>
      </div>
    </div>
  </form>

  <!-- Features -->
  <div class="card mb-4">
    <div class="card-header bg-light fw-semibold">
      <i class="bi bi-stars"></i> AI-Powered Features
    </div>
    <div class="card-body">
      <ul class="list-unstyled mb-0 small">
        <li class="py-2 border-bottom"><strong>Intelligent Prompt Parsing</strong> — Natural-language questions are interpreted by GPT instead of regex.</li>
        <li class="py-2 border-bottom"><strong>Narrative Insights</strong> — Every chart gets an AI explanation: what it means and why it matters.</li>
        <li class="py-2 border-bottom"><strong>Smart Suggestions</strong> — AI surfaces the most valuable questions to ask of your schema.</li>
        <li class="py-2"><strong>Executive Summary</strong> — A synthesized brief of key findings across all panels in 4–5 sentences.</li>
      </ul>
    </div>
  </div>
</div>

<script>
  // Toggle visibility of custom fields when the radio changes
  document.querySelectorAll('input[name="provider"]').forEach(function(r){
    r.addEventListener('change', function(){
      document.getElementById('customFields').style.display =
        (r.value === 'custom' && r.checked) ? 'block' : 'none';
    });
  });
  document.querySelectorAll('.mode-card').forEach(function(card){
    card.addEventListener('click', function(e){
      if (e.target.tagName === 'INPUT') return;
      var mode = card.getAttribute('data-mode');
      var radio = card.querySelector('input[type="radio"]');
      radio.checked = true;
      radio.dispatchEvent(new Event('change'));
    });
  });

  async function testEffective() {
    var btn = event.currentTarget;
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Testing...';
    try {
      var res = await fetch('/ai/test', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
      var data = await res.json();
      alert((data.success ? '✅ ' : '❌ ') + data.message + (data.mode ? '\n\nMode: ' + data.mode : ''));
    } catch (e) { alert('Error: ' + e.message); }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-lightning-charge"></i> Test Connection';
  }

  async function testCustomFromForm() {
    var form = document.getElementById('aiSettingsForm');
    var fd = new FormData(form);
    var body = {
      endpoint: fd.get('endpoint'),
      deployment: fd.get('deployment'),
      apiVersion: fd.get('apiVersion'),
      apiKey: fd.get('apiKey'),
    };
    var hasStored = <%= customConfig.hasApiKey ? 'true' : 'false' %>;
    if (!body.apiKey && hasStored) body.useStoredKey = '1';
    var resultEl = document.getElementById('customTestResult');
    resultEl.textContent = 'Testing...';
    try {
      var res = await fetch('/ai/test', {
        method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body)
      });
      var data = await res.json();
      resultEl.innerHTML = data.success
        ? '<span class="text-success">✅ ' + data.message + '</span>'
        : '<span class="text-danger">❌ ' + data.message + '</span>';
    } catch (e) {
      resultEl.innerHTML = '<span class="text-danger">❌ ' + e.message + '</span>';
    }
  }
</script>
